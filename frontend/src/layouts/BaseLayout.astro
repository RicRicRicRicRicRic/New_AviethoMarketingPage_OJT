---
// Base layout component with global styles and navigation
import '../styles/global.css';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import ChatWidget from '../components/ui/ChatWidget.astro';
import ColorPaletteWidget from '../components/ui/ColorPaletteWidget.astro';
import FollowUsPopup from '../components/ui/FollowUsPopup.astro';

interface Props {
	title?: string;
}

const { title = 'Avietho' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/AviethoFavicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</head>
<body class="bg-background text-foreground min-h-screen flex flex-col">
	<Navbar />
	<main class="flex-grow">
		<slot />
	</main>
	<Footer />
		<FollowUsPopup />
    	<ChatWidget />
    	<ColorPaletteWidget />
</body>
</html>