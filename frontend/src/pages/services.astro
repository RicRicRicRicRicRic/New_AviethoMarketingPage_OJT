// Every image belonging to a category (hero shot + each sub-service's
// photo, de-duplicated) — used to fill the panel's sliding image frame.
const getCategoryImages = (cat: Category): string[] => {
  const all = [cat.heroImage, ...cat.services.map((s) => s.image)];
  return Array.from(new Set(all));
};
---

<BaseLayout title="Avietho - Our Services">
  <main class="services-page" style={`--background:${theme.background}; --accent:${theme.accent}; --text-primary:${theme.textPrimary}; --text-muted:${theme.textMuted}; --surface:${theme.surface}; --border:${theme.border};`}>

    <!-- Hero -->
    <section class="hero reveal">
      <p class="eyebrow">Services</p>
      <h1 class="hero-title">
        Comprehensive digital marketing solutions tailored to elevate your brand presence and drive results
      </h1>

      <!-- Quick nav -->
      <nav class="cat-nav" aria-label="Service categories">
        {categories.map((cat) => (
          <a href={`#${cat.slug}`} class="cat-nav-link">
            <span class="cat-num">{cat.number}.</span> {cat.title}
          </a>
        ))}
      </nav>
    </section>

    <!-- Category panels -->
    {categories.map((cat, i) => {
      const images = getCategoryImages(cat);
      // Doubled so the track can loop seamlessly (translate by -50%, then
      // reset with no visible seam).
      const loopImages = [...images, ...images];
      const slideDuration = `${images.length * 4}s`;

      return (
        <section id={cat.slug} class={`panel reveal ${i % 2 === 1 ? 'panel-reverse' : ''}`}>
          <a
            href={`/projects?category=${encodeURIComponent(cat.title)}#gallery`}
            class="panel-media panel-media-link"
            aria-label={`View ${cat.title} projects in our portfolio`}
          >
            <div class="panel-media-track" style={`--slide-duration:${slideDuration};`}>
              {loopImages.map((src, idx) => (
                <img src={src} alt="" loading="lazy" aria-hidden={idx >= images.length ? 'true' : 'false'} />
              ))}
            </div>
            <span class="panel-media-cta">View {cat.title} Projects →</span>
          </a>
          <div class="panel-scrim"></div>
          <div class="panel-body">
            <span class="panel-number">{cat.number}</span>
            <h2 class="panel-title">{cat.title}</h2>
            <p class="panel-intro">{cat.intro}</p>

            <div class="service-grid">
              {cat.services.map((s) => (
                <div class="service-item">
                  <h3 class="service-title">{s.title}</h3>
                  <p class="service-subtitle">{s.subtitle}</p>
                  <p class="service-desc">{s.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    })}

    <!-- Closing CTA -->
    <section class="cta reveal">
      <h2 class="cta-title">Let&rsquo;s build your next campaign</h2>
      <div class="cta-actions">
        <a href="tel:+6397831987" class="cta-primary">Book a call</a>
        <a href="mailto:marketing.avietho@gmail.com" class="cta-secondary">marketing.avietho@gmail.com</a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Scroll-reveal: panels fade/rise into place as they enter the viewport,
  // mirroring the quiet, orchestrated motion of bloom3d.studio rather than
  // scattering effects everywhere.
  const items = document.querySelectorAll<HTMLElement>('.reveal');

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
  );

  items.forEach((el) => io.observe(el));
</script>

<style>
  .services-page {
    background: var(--background);
    color: var(--text-primary);
  }

  /* ---------- Hero ---------- */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 24px 56px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .hero-title {
    font-size: clamp(2rem, 4.4vw, 3.6rem);
    line-height: 1.12;
    font-weight: 600;
    max-width: 900px;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .cat-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 44px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
    width: 100%;
  }
  .cat-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .cat-nav-link:hover {
    color: var(--text-primary);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .cat-num {
    color: var(--accent);
    font-weight: 600;
  }

  /* ---------- Panels ---------- */
  .panel {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 72px 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    border-top: 1px solid var(--border);
    scroll-margin-top: 90px;
  }

  /* Mobile only: the photo becomes the panel's full-bleed background so
     text stays readable, instead of stacking above it as its own block.
     Desktop layout/motion below is untouched. */
  .panel-scrim {
    display: none;
  }
  @media (max-width: 899px) {
    .panel {
      overflow: hidden;
      isolation: isolate;
    }
    .panel-media {
      position: absolute;
      inset: 0;
      z-index: 0;
      border-radius: 0;
      border: none;
      opacity: 0;
      transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .panel.is-visible .panel-media {
      opacity: 1;
    }
    .panel-media img {
      max-height: none;
      height: 100%;
    }
    .panel-media-track img {
      height: 100%;
    }
    .panel-media-cta {
      display: none;
    }
    .panel-scrim {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        180deg,
        rgba(10, 10, 10, 0.55) 0%,
        rgba(10, 10, 10, 0.85) 45%,
        var(--background) 90%
      );
      opacity: 0;
      transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .panel.is-visible .panel-scrim {
      opacity: 1;
    }
    .panel-body {
      position: relative;
      z-index: 2;
    }
  }

  @media (min-width: 900px) {
    .panel {
      grid-template-columns: 0.85fr 1.15fr;
      align-items: start;
      gap: 64px;
    }
    .panel-reverse {
      grid-template-columns: 1.15fr 0.85fr;
    }
    .panel-reverse .panel-media {
      order: 2;
    }
    .panel-reverse .panel-body {
      order: 1;
    }
  }

  .panel-media {
    position: sticky;
    top: 96px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .panel-media-link {
    display: block;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }
  .panel-media img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
    filter: saturate(0.92);
    transition: transform 0.6s ease;
  }
  .panel-media:hover img {
    transform: scale(1.03);
  }

  /* Infinite sliding track: the frame (.panel-media) clips via
     overflow:hidden above, this track scrolls its doubled image set
     leftward forever, pausing on hover/focus so it reads as clickable. */
  .panel-media-track {
    display: flex;
    height: 100%;
    width: max-content;
    animation: panel-media-slide var(--slide-duration, 20s) linear infinite;
  }
  .panel-media-track img {
    width: auto;
    height: 420px;
    max-height: none;
    flex: 0 0 auto;
    object-fit: cover;
    filter: saturate(0.92);
    transition: none;
  }
  .panel-media:hover .panel-media-track,
  .panel-media:focus-visible .panel-media-track {
    animation-play-state: paused;
  }
  @keyframes panel-media-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .panel-media-cta {
    position: absolute;
    inset: auto 16px 16px auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(10, 10, 10, 0.65);
    backdrop-filter: blur(4px);
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .panel-media:hover .panel-media-cta,
  .panel-media:focus-visible .panel-media-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .panel-number {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .panel-title {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--text-primary);
  }
  .panel-intro {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 52ch;
    margin-bottom: 36px;
  }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .service-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .service-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .service-item:nth-child(odd) {
      padding-right: 24px;
      border-right: 1px solid var(--border);
    }
    .service-item:nth-child(even) {
      padding-left: 24px;
    }
  }
  .service-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .service-subtitle {
    font-size: 12px;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .service-desc {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* ---------- CTA ---------- */
  .cta {
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 24px 120px;
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-title {
    font-size: clamp(1.8rem, 3.6vw, 2.8rem);
    font-weight: 600;
    margin-bottom: 32px;
    color: var(--text-primary);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 20px;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--background);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  .cta-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .cta-secondary {
    color: var(--text-muted);
    font-size: 15px;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .cta-secondary:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }

  /* ---------- Scroll reveal ---------- */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .panel-media img {
      transition: none;
    }
    .panel-media-track {
      animation: none;
      transform: none;
    }
  }
</style>