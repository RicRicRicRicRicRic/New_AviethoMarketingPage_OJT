---

<BaseLayout title="Avietho - Our Services">
  <main class="services-page" style={`--background:${theme.background}; --accent:${theme.accent}; --text-primary:${theme.textPrimary}; --text-muted:${theme.textMuted}; --surface:${theme.surface}; --border:${theme.border};`}>

    <!-- Hero -->
    <section class="hero reveal">
      <p class="eyebrow">Services</p>
      <h1 class="hero-title">
        Comprehensive digital marketing solutions tailored to elevate your brand presence and drive results
      </h1>

      <!-- Quick nav -->
      <nav class="cat-nav" aria-label="Service categories">
        {categories.map((cat) => (
          <a href={`#${cat.slug}`} class="cat-nav-link">
            <span class="cat-num">{cat.number}.</span> {cat.title}
          </a>
        ))}
      </nav>
    </section>

    <!-- Category panels -->
    {categories.map((cat, i) => (
      <section id={cat.slug} class={`panel reveal ${i % 2 === 1 ? 'panel-reverse' : ''}`}>
        <div class="panel-media">
          <img src={cat.heroImage} alt={cat.title} loading="lazy" />
        </div>
        <div class="panel-body">
          <span class="panel-number">{cat.number}</span>
          <h2 class="panel-title">{cat.title}</h2>
          <p class="panel-intro">{cat.intro}</p>

          <div class="service-grid">
            {cat.services.map((s) => (
              <div class="service-item">
                <h3 class="service-title">{s.title}</h3>
                <p class="service-subtitle">{s.subtitle}</p>
                <p class="service-desc">{s.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- Closing CTA -->
    <section class="cta reveal">
      <h2 class="cta-title">Let&rsquo;s build your next campaign</h2>
      <div class="cta-actions">
        <a href="tel:+6397831987" class="cta-primary">Book a call</a>
        <a href="mailto:marketing.avietho@gmail.com" class="cta-secondary">marketing.avietho@gmail.com</a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Scroll-reveal: panels fade/rise into place as they enter the viewport,
  // mirroring the quiet, orchestrated motion of bloom3d.studio rather than
  // scattering effects everywhere.
  const items = document.querySelectorAll<HTMLElement>('.reveal');

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
  );

  items.forEach((el) => io.observe(el));
</script>

<style>
  .services-page {
    background: var(--background);
    color: var(--text-primary);
  }

  /* ---------- Hero ---------- */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 24px 56px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .hero-title {
    font-size: clamp(2rem, 4.4vw, 3.6rem);
    line-height: 1.12;
    font-weight: 600;
    max-width: 900px;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .cat-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 44px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
    width: 100%;
  }
  .cat-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .cat-nav-link:hover {
    color: var(--text-primary);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .cat-num {
    color: var(--accent);
    font-weight: 600;
  }

  /* ---------- Panels ---------- */
  .panel {
    max-width: 1200px;
    margin: 0 auto;
    padding: 72px 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    border-top: 1px solid var(--border);
    scroll-margin-top: 90px;
  }
  @media (min-width: 900px) {
    .panel {
      grid-template-columns: 0.85fr 1.15fr;
      align-items: start;
      gap: 64px;
    }
    .panel-reverse {
      grid-template-columns: 1.15fr 0.85fr;
    }
    .panel-reverse .panel-media {
      order: 2;
    }
    .panel-reverse .panel-body {
      order: 1;
    }
  }

  .panel-media {
    position: sticky;
    top: 96px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .panel-media img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
    filter: saturate(0.92);
    transition: transform 0.6s ease;
  }
  .panel-media:hover img {
    transform: scale(1.03);
  }

  .panel-number {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .panel-title {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--text-primary);
  }
  .panel-intro {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 52ch;
    margin-bottom: 36px;
  }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .service-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .service-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .service-item:nth-child(odd) {
      padding-right: 24px;
      border-right: 1px solid var(--border);
    }
    .service-item:nth-child(even) {
      padding-left: 24px;
    }
  }
  .service-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .service-subtitle {
    font-size: 12px;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .service-desc {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* ---------- CTA ---------- */
  .cta {
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 24px 120px;
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-title {
    font-size: clamp(1.8rem, 3.6vw, 2.8rem);
    font-weight: 600;
    margin-bottom: 32px;
    color: var(--text-primary);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 20px;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--background);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  .cta-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .cta-secondary {
    color: var(--text-muted);
    font-size: 15px;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .cta-secondary:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }

  /* ---------- Scroll reveal ---------- */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .panel-media img {
      transition: none;
    }
  }
</style>