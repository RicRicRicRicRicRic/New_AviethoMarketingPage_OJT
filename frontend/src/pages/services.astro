---
// Our Services page
// Layout/motion rhythm modeled on bloom3d.studio/services (eyebrow label,
// oversized headline, alternating image/text panels, closing CTA).
// Content is the exact service catalogue from
// marketing.aviethodigital.com/services/. Theme is sourced from skills.md's
// content-collection entry, same pattern as ChatWidget.astro / Navbar.astro.

import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const skillsEntry = await getEntry('docs', 'skills');

// If the CMS supplies a theme entry, honor it exactly as before. Otherwise,
// fall back to the site's design tokens from global.css (via var(--...))
// instead of duplicating hardcoded hex values here. This keeps the page in
// sync with the global palette by default while still allowing a CMS
// override, same pattern as ChatWidget.astro / Navbar.astro.
const themeData = skillsEntry?.data?.theme ?? null;

const theme = {
  background: themeData?.background ?? 'var(--color-background)',
  accent: themeData?.accent ?? 'var(--color-accent)',
  textPrimary: themeData?.textPrimary ?? 'var(--color-foreground)',
  textMuted: themeData
    ? (themeData.mode === 'dark' ? '#9A9A9A' : '#5A5A5A')
    : 'var(--color-text-muted)',
  surface: themeData
    ? (themeData.mode === 'dark' ? '#131313' : '#F3F3F3')
    : 'var(--color-surface)',
  border: themeData
    ? (themeData.mode === 'dark' ? 'rgba(245,245,245,0.10)' : 'rgba(10,10,10,0.10)')
    : 'var(--color-border)',
};

interface SubService {
  title: string;
  subtitle: string;
  description: string;
  image: string;
}

interface Category {
  number: string;
  slug: string;
  title: string;
  intro: string;
  heroImage: string;
  services: SubService[];
}

