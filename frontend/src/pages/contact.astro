---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Contact — Avietho Digital">
  <!-- Reduced top vertical padding on main container from py-12/py-20 to pt-4 pb-12 -->
  <main class="max-w-7xl mx-auto px-6 md:px-12 pt-4 pb-12 font-body">

    <!-- HERO / AGENCY BANNER SECTION -->
    <!-- Reduced top padding from p-8/p-16 to pt-6 pb-8 px-8 md:pt-8 md:pb-12 md:px-16 -->
    <section class="relative overflow-hidden rounded-3xl pt-6 pb-8 px-8 md:pt-8 md:pb-12 md:px-16 mb-12 shadow-2xl backdrop-blur-md">
      <!-- Glow effect backdrop -->
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative z-10 max-w-3xl">
        <!-- UPDATED HEADER TAGLINE TO MATCH DESIGN IMAGE -->
        <div class="inline-flex items-center gap-3 text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-accent mb-4">
          <span class="w-8 h-[1px] bg-accent/60"></span>
          <span>Contact · Advertise · Collaborate · Partner</span>
        </div>

        <h1 class="text-4xl sm:text-6xl md:text-7xl font-heading font-bold tracking-tight text-foreground leading-[1.05]">
          Let’s scale your <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-hover italic">digital footprint.</span>
        </h1>

        <p class="mt-4 text-lg md:text-xl text-text-subtle font-body max-w-xl leading-relaxed">
          Ready to launch campaigns, discuss story pitches, or enter strategic partnerships? Our desk reads every brief.
        </p>
      </div>

      <!-- Quick Agency Stats / Contact Strip -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 pt-8 mt-8 border-border/80">
        <div class="bg-surface/50 border border-border/60 p-4 rounded-2xl flex flex-col justify-between hover:border-accent/40 transition">
          <div class="text-xs uppercase tracking-widest text-text-muted mb-2 font-semibold">Landline</div>
          <a href="tel:+63270001366" class="text-base sm:text-lg font-heading font-bold hover:text-accent truncate">
            +63 2 7000 1366
          </a>
        </div>

        <div class="bg-surface/50 border border-border/60 p-4 rounded-2xl flex flex-col justify-between hover:border-accent/40 transition">
          <div class="text-xs uppercase tracking-widest text-text-muted mb-2 font-semibold">Mobile</div>
          <a href="tel:+6397831987" class="text-base sm:text-lg font-heading font-bold text-foreground hover:text-accent transition truncate">
            +63 9783 1987
          </a>
        </div>

        <div class="bg-surface/50 border border-border/60 p-4 rounded-2xl flex flex-col justify-between hover:border-accent/40 transition">
          <div class="text-xs uppercase tracking-widest text-text-muted mb-2 font-semibold">Marketing & Partnerships</div>
          <a href="mailto:marketing.avietho@gmail.com" class="text-sm sm:text-base font-heading font-bold hover:text-accent truncate" title="marketing.avietho@gmail.com">
            marketing.avietho@gmail.com
          </a>
        </div>

        <div class="bg-surface/50 border border-border/60 p-4 rounded-2xl flex flex-col justify-between hover:border-accent/40 transition">
          <div class="text-xs uppercase tracking-widest text-text-muted mb-2 font-semibold">General Inquiries</div>
          <a href="mailto:aviethodigital@gmail.com" class="text-sm sm:text-base font-heading font-bold text-foreground hover:text-accent transition truncate" title="aviethodigital@gmail.com">
            aviethodigital@gmail.com
          </a>
        </div>
      </div>
    </section>

    <!-- MAIN INTERACTIVE SECTION (ALIGNED HEIGHTS & PADDING) -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-stretch">
      
      <!-- LEFT COLUMN: AGENCY BRIEF FORM PANEL -->
      <div class="lg:col-span-7 bg-background-elevated/60 border border-border rounded-3xl p-8 shadow-xl backdrop-blur-md flex flex-col justify-between">
        
        <div>
          <div class="mb-6">
            <h2 class="text-2xl font-heading font-semibold text-foreground mb-2">Submit a Project Brief</h2>
            <p class="text-sm text-text-muted">Select an objective below and provide details regarding your inquiry.</p>
          </div>

          <!-- PILL OBJECTIVE SELECTORS WITH INTERACTIVE TOGGLE -->
          <div class="mb-8">
            <label class="block text-xs uppercase tracking-widest font-semibold text-text-subtle mb-3">INQUIRY TYPE</label>
            <div class="flex flex-wrap gap-2" id="inquiry-pills">
              <button type="button" class="inquiry-btn active border border-accent bg-accent text-background font-semibold px-4 py-2 rounded-full text-xs tracking-wider uppercase transition shadow-md shadow-accent/20">
                Digital PR
              </button>
              <button type="button" class="inquiry-btn border border-border bg-surface/50 text-text-subtle hover:border-accent hover:text-foreground px-4 py-2 rounded-full text-xs tracking-wider uppercase transition">
                Video & Live Streaming Services
              </button>
              <button type="button" class="inquiry-btn border border-border bg-surface/50 text-text-subtle hover:border-accent hover:text-foreground px-4 py-2 rounded-full text-xs tracking-wider uppercase transition">
                Multimedia & Branding
              </button>
              <button type="button" class="inquiry-btn border border-border bg-surface/50 text-text-subtle hover:border-accent hover:text-foreground px-4 py-2 rounded-full text-xs tracking-wider uppercase transition">
                Digital & Social Media Marketing
              </button>
              <button type="button" class="inquiry-btn border border-border bg-surface/50 text-text-subtle hover:border-accent hover:text-foreground px-4 py-2 rounded-full text-xs tracking-wider uppercase transition">
                Web development
              </button>
            </div>
          </div>

          <!-- FORM FIELDS -->
          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">First Name *</label>
                <input type="text" class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition" />
              </div>
              <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">Last Name *</label>
                <input type="text" class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">Work Email *</label>
                <input type="email" class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition" />
              </div>
              <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">Phone Number</label>
                <input type="tel" class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">Organization / Brand</label>
              <input type="text" class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition" />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-text-subtle mb-1">Project Brief / Message</label>
              <textarea rows="3" placeholder="Tell us about your campaign goals, timeline, or pitch overview..." class="w-full bg-transparent border-b border-border/80 rounded-none py-2 text-foreground placeholder:text-text-muted/40 focus:border-accent focus:outline-none transition resize-none"></textarea>
            </div>
          </form>
        </div>

        <!-- FORM FOOTER & SUBMIT BUTTON -->
        <div class="pt-6 mt-6 flex flex-col sm:flex-row items-center justify-between gap-6 border-t border-border/60">
          <span class="text-[11px] text-text-muted max-w-xs leading-normal">
            By submitting, you agree to our editorial standards and privacy terms.
          </span>
          <button type="submit" class="w-full sm:w-auto bg-gradient-to-r from-accent to-accent-hover text-background font-bold text-xs uppercase tracking-widest px-8 py-4 rounded-xl hover:opacity-90 transition shadow-lg shadow-accent/10">
            Send Message
          </button>
        </div>

      </div>

      <!-- RIGHT COLUMN: HQ LOCATION & DIRECT CONTACT PANELS -->
      <div class="lg:col-span-5 flex flex-col justify-between gap-8">
        
        <!-- HQ OFFICE CARD -->
        <div class="bg-background-elevated/60 border border-border rounded-3xl p-8 shadow-xl backdrop-blur-md flex-1 flex flex-col justify-between">
          <div>
            <div class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-accent mb-4">
              <span class="w-2 h-2 rounded-full bg-accent"></span>
              <span>Headquarters</span>
            </div>

            <h2 class="text-3xl font-heading font-bold text-foreground mb-4">
              Madrigal Business Park, <br/>
              <span class="text-accent italic font-normal">Ayala Alabang.</span>
            </h2>

            <address class="not-italic text-text-subtle text-sm leading-relaxed space-y-1 mb-6">
              <p class="font-medium text-foreground">Admiralty Bldg. 1101</p>
              <p>Alabang-Zapote Rd., Madrigal Business Park</p>
              <p>Brgy. Ayala Alabang, Muntinlupa City, Philippines</p>
            </address>
          </div>

          <div>
            <a href="https://maps.app.goo.gl/KyDMwmYMADs5c5LC7" class="inline-flex items-center gap-2 bg-surface hover:bg-background-card border border-border px-5 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider text-foreground hover:text-accent transition">
              <span>View on Google Maps</span>
              <span>↗</span>
            </a>
          </div>
        </div>

        <!-- DIRECT LINES CARD -->
        <div class="bg-background-elevated/60 border border-border rounded-3xl p-8 shadow-xl backdrop-blur-md space-y-4 flex-1 flex flex-col justify-center">
          <div class="text-xs font-semibold uppercase tracking-widest text-accent mb-2">
            Direct Communications
          </div>

          <div class="space-y-3">
            <div class="flex justify-between items-center py-2.5 border-b border-border/60 text-sm">
              <span class="text-xs uppercase tracking-wider text-text-muted">Landline</span>
              <span class="font-mono text-xs font-semibold text-foreground">+63 2 7000 1366</span>
            </div>

            <div class="flex justify-between items-center py-2.5 border-b border-border/60 text-sm">
              <span class="text-xs uppercase tracking-wider text-text-muted">Mobile</span>
              <span class="font-mono text-xs font-semibold text-foreground">+63 9783 1987</span>
            </div>

            <div class="flex justify-between items-center py-2.5 border-b border-border/60 text-sm">
              <span class="text-xs uppercase tracking-wider text-text-muted">General</span>
              <a href="mailto:aviethodigital@gmail.com" class="text-xs font-medium text-foreground hover:text-accent transition truncate max-w-[200px]">aviethodigital@gmail.com</a>
            </div>

            <div class="flex justify-between items-center py-2.5 text-sm">
              <span class="text-xs uppercase tracking-wider text-text-muted">Marketing</span>
              <a href="mailto:marketing.avietho@gmail.com" class="text-xs font-medium text-accent hover:underline transition truncate max-w-[200px]">marketing.avietho@gmail.com</a>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

</BaseLayout>

<!-- SCRIPT TO HANDLE TOGGLE HIGHLIGHT ON INQUIRY BUTTONS -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.inquiry-btn');

    // Classes for inactive state
    const inactiveClasses = ['border-border', 'bg-surface/50', 'text-text-subtle'];
    // Classes for active state
    const activeClasses = ['border-accent', 'bg-accent', 'text-background', 'shadow-md', 'shadow-accent/20'];

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Reset all buttons to inactive
        buttons.forEach((b) => {
          b.classList.remove(...activeClasses);
          b.classList.add(...inactiveClasses);
        });

        // Set clicked button to active state
        btn.classList.remove(...inactiveClasses);
        btn.classList.add(...activeClasses);
      });
    });
  });
</script>