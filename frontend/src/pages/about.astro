---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Avietho - About">
	<section
	class="relative min-h-[calc(100vh-72px)] flex items-center px-4 pt-32 pb-20 overflow-hidden bg-cover bg-center bg-no-repeat"
	style="
		background-image:
			linear-gradient(
				90deg,
				rgba(0,0,0,.88) 0%,
				rgba(0,0,0,.72) 35%,
				rgba(0,0,0,.60) 60%,
				rgba(0,0,0,.82) 100%
			),
			linear-gradient(
				180deg,
				rgba(0,0,0,.55) 0%,
				rgba(0,0,0,.25) 45%,
				rgba(0,0,0,.75) 100%
			),
			url('/digitalmarketing.png');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	"
>
		<div class="relative z-10 max-w-7xl mx-auto w-full">
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center">
				<div class="lg:col-span-3 animate-fade-up">
					<p class="text-sm md:text-base font-semibold tracking-widest text-accent mb-6">ABOUT AVIETHO</p>

					<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-foreground mb-6 leading-tight">
						About<br />
						<span class="text-accent">Digital Marketing</span>
					</h1>

					<p class="text-lg md:text-xl text-text-subtle mb-10 leading-relaxed max-w-2xl">
						At Avietho Digital Marketing, we help businesses grow through creative strategies, innovative technology, and impactful digital experiences.
						We believe every brand has a unique story, and our mission is to transform those stories into meaningful connections that drive real business results.
					</p>

					<a href="#learn-more" class="inline-block px-10 py-4 bg-accent text-background font-semibold rounded hover:bg-accent-hover transition-all duration-300 hover:scale-105 shadow-lg shadow-accent/20">
						Learn More
					</a>
				</div>

				<div class="lg:col-span-2">
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<a href="#experience" class="group relative bg-foreground/5 backdrop-blur-sm border border-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.3)] cursor-pointer">
							<div class="text-3xl md:text-4xl font-bold text-accent mb-2">5+</div>
							<div class="text-base font-semibold text-foreground mb-3">Years of Experience</div>
							<p class="text-sm text-text-muted leading-relaxed">Delivering creative digital marketing solutions since 2018 while helping businesses establish a stronger online presence.</p>
						</a>

						<a href="#projects" class="group relative bg-foreground/5 backdrop-blur-sm border border-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.3)] cursor-pointer">
							<div class="text-3xl md:text-4xl font-bold text-accent mb-2">100+</div>
							<div class="text-base font-semibold text-foreground mb-3">Projects Completed</div>
							<p class="text-sm text-text-muted leading-relaxed">Successfully completed branding, web development, social media, and digital 
							marketing campaigns across multiple industries.</p>
						</a>

						<a href="#clients" class="group relative bg-foreground/5 backdrop-blur-sm border border-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.3)] cursor-pointer">
							<div class="text-3xl md:text-4xl font-bold text-accent mb-2">50+</div>
							<div class="text-base font-semibold text-foreground mb-3">Happy Clients</div>
							<p class="text-sm text-text-muted leading-relaxed">Trusted by businesses that continue to partner with Avietho for long-term digital growth and marketing success.</p>
						</a>

						<a href="#satisfaction" class="group relative bg-foreground/5 backdrop-blur-sm border border-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.3)] cursor-pointer">
							<div class="text-3xl md:text-4xl font-bold text-accent mb-2">95%</div>
							<div class="text-base font-semibold text-foreground mb-3">Client Satisfaction</div>
							<p class="text-sm text-text-muted leading-relaxed">Maintaining strong client relationships by delivering quality work, measurable results, and reliable support.</p>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="relative py-28 px-4 overflow-hidden bg-background">
		
		<div class="absolute inset-0 pointer-events-none overflow-hidden">
			<div class="absolute -top-40 -left-40 w-[650px] h-[650px] rounded-full bg-accent/10 blur-[220px]"></div>
			<div class="absolute -bottom-40 -right-40 w-[650px] h-[650px] rounded-full bg-accent/10 blur-[220px]"></div>
		</div>

		<div class="relative z-10 max-w-7xl mx-auto">
			<div class="text-center mb-16 animate-fade-up">
				<p class="text-sm md:text-base font-semibold tracking-widest text-accent mb-4">OUR COMMUNITY</p>
				<h2 class="text-3xl md:text-5xl lg:text-6xl font-bold text-foreground mb-6">
					Connect With <span class="text-accent">Avietho</span>
				</h2>
				<p class="text-lg text-text-subtle max-w-3xl mx-auto leading-relaxed">
					Stay connected with Avietho Digital through our official social media platforms.
					Discover our latest projects, creative campaigns, client success stories, behind-the-scenes content, and company updates.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
				<div class="lg:col-span-3 animate-fade-up" style="animation-delay: 0.1s;">
					<div class="group relative bg-background backdrop-blur-sm border border-border rounded-3xl overflow-hidden shadow-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(201,164,76,0.15)]">

						<div class="relative h-64 md:h-80 bg-background overflow-hidden">
							<img 
								src="/avietho.png"
								alt="Avietho Digital Facebook Page" 
								class="w-full h-full object-cover object-top"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-70"></div>
						</div>

						<div class="relative px-6 md:px-8 pb-6">
							<div class="flex items-start gap-4 mb-4">
								<div class="w-16 h-16 md:w-20 md:h-20 bg-foreground rounded-full border-4 border-background flex items-center justify-center shadow-xl flex-shrink-0 -mt-12">
									<span class="text-2xl md:text-3xl font-bold text-background">A</span>
								</div>
								<div class="pt-2">
									<div class="flex items-center gap-2 mb-1">
										<h3 class="text-xl md:text-2xl font-bold text-foreground">Avietho Digital</h3>
										<svg class="w-5 h-5 md:w-6 md:h-6 text-blue-500" fill="currentColor" viewBox="0 0 24 24">
											<path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
										</svg>
									</div>
									<p class="text-base md:text-lg text-accent font-semibold">46K Followers</p>
									<p class="text-sm text-text-muted italic">Innovate, Create and Connect</p>
								</div>
							</div>

							<p class="text-sm md:text-base text-text-subtle leading-relaxed mb-6">
								Explore our official Facebook page to stay updated with our newest projects, digital marketing campaigns, creative works, client success stories, and company announcements.
							</p>

							<a href="https://www.facebook.com/aviethodigital" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-background font-semibold rounded-full transition-all duration-300 hover:bg-accent-hover hover:scale-105 shadow-lg shadow-accent/20">
								Visit Official Facebook Page
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
								</svg>
							</a>
						</div>
					</div>
				</div>

				<div class="lg:col-span-2 animate-fade-up" style="animation-delay: 0.2s;">
					<div class="mb-6">
						<h3 class="text-2xl md:text-3xl font-bold text-foreground mb-2">Follow Us Everywhere</h3>
						<div class="w-16 h-1 bg-accent rounded-full"></div>
					</div>

					<div class="space-y-4">
						<a href="https://www.facebook.com/aviethodigital" target="_blank" rel="noopener noreferrer" class="group relative bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.15)]">
							<div class="flex items-start gap-4">
								<div class="w-12 h-12 bg-background-card border border-border rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-accent group-hover:border-accent">
									<svg class="w-6 h-6 text-accent transition-colors duration-300 group-hover:text-background" fill="currentColor" viewBox="0 0 24 24">
										<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
									</svg>
								</div>
								<div class="flex-1">
									<h4 class="text-lg font-bold text-foreground mb-1 group-hover:text-accent transition-colors duration-300">Facebook</h4>
									<p class="text-sm text-text-muted leading-relaxed">Latest company updates and community posts</p>
								</div>
								<svg class="w-5 h-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
								</svg>
							</div>
						</a>

						<a href="https://www.instagram.com/aviethodigital/" target="_blank" rel="noopener noreferrer" class="group relative bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.15)]">
							<div class="flex items-start gap-4">
								<div class="w-12 h-12 bg-background-card border border-border rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-accent group-hover:border-accent">
									<svg class="w-6 h-6 text-accent transition-colors duration-300 group-hover:text-background" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
									</svg>
								</div>
								<div class="flex-1">
									<h4 class="text-lg font-bold text-foreground mb-1 group-hover:text-accent transition-colors duration-300">Instagram</h4>
									<p class="text-sm text-text-muted leading-relaxed">Creative branding and visual content</p>
								</div>
								<svg class="w-5 h-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
								</svg>
							</div>
						</a>

						<a href="https://www.tiktok.com/@aviethodigital" target="_blank" rel="noopener noreferrer" class="group relative bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.15)]">
							<div class="flex items-start gap-4">
								<div class="w-12 h-12 bg-background-card border border-border rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-accent group-hover:border-accent">
									<svg class="w-6 h-6 text-accent transition-colors duration-300 group-hover:text-background" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
									</svg>
								</div>
								<div class="flex-1">
									<h4 class="text-lg font-bold text-foreground mb-1 group-hover:text-accent transition-colors duration-300">TikTok</h4>
									<p class="text-sm text-text-muted leading-relaxed">Short-form videos and marketing trends</p>
								</div>
								<svg class="w-5 h-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
								</svg>
							</div>
						</a>

						<a href="https://www.youtube.com/@aviethodigital" target="_blank" rel="noopener noreferrer" class="group relative bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-[0_0_30px_rgba(201,164,76,0.15)]">
							<div class="flex items-start gap-4">
								<div class="w-12 h-12 bg-background-card border border-border rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-accent group-hover:border-accent">
									<svg class="w-6 h-6 text-accent transition-colors duration-300 group-hover:text-background" fill="currentColor" viewBox="0 0 24 24">
										<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
