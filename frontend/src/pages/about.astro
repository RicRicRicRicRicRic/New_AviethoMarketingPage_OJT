---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAbout from '../components/sections/about_sections/HeroAbout.astro';
import CommunityAbout from '../components/sections/about_sections/CommunityAbout.astro';
import JourneyAbout from '../components/sections/about_sections/JourneyAbout.astro';
import IdentityAbout from '../components/sections/about_sections/IdentityAbout.astro';
import ServicesAbout from '../components/sections/about_sections/ServicesAbout.astro';
import CTAAbout from '../components/sections/about_sections/CTAAbout.astro';
import ValuesAbout from '../components/sections/about_sections/ValuesAbout.astro';
import ClientsAbout from '../components/sections/about_sections/ClientsAbout.astro';
---

<BaseLayout title="Avietho - About">
	<HeroAbout />
	<CommunityAbout />
	<JourneyAbout />
	<IdentityAbout />
	<ServicesAbout />
	<CTAAbout />
	<ValuesAbout />
	<ClientsAbout />
</BaseLayout>

<style>
	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-up {
		opacity: 0;
		animation: fadeUp 0.8s ease-out forwards;
	}

	@media (prefers-reduced-motion: reduce) {
		.animate-fade-up {
			animation: none;
			opacity: 1;
		}
	}
</style>