</BaseLayout>

<script>
	declare global {
		interface Window {
			YT?: any;
			onYouTubeIframeAPIReady?: () => void;
		}
	}

	let player: any = null;
	let currentVideoId = "";

	function loadYouTubeAPI() {
		if (window.YT && window.YT.Player) return Promise.resolve();

		return new Promise<void>((resolve) => {
			const tag = document.createElement("script");
			tag.src = "https://www.youtube.com/iframe_api";
			const firstScript = document.getElementsByTagName("script")[0];
			firstScript.parentNode?.insertBefore(tag, firstScript);

			window.onYouTubeIframeAPIReady = () => {
				resolve();
			};
		});
	}

	async function playVideo(videoId: string | null | undefined) {
		if (!videoId) {
			alert("Video unavailable.");
			return;
		}

		currentVideoId = videoId;
		const playerEl = document.getElementById("video-player") as HTMLElement;
		playerEl.classList.remove("hidden");
		document.body.style.overflow = "hidden";

		await loadYouTubeAPI();

		if (player) {
			player.loadVideoById(videoId);
		} else {
			player = new window.YT.Player("player-container", {
				height: "100%",
				width: "100%",
				videoId: videoId,
				playerVars: {
					autoplay: 1,
					modestbranding: 1,
					rel: 0,
				},
				events: {
					onReady: (event: any) => event.target.playVideo(),
				},
			});
		}
	}

	function closePlayer() {
		const playerEl = document.getElementById("video-player") as HTMLElement;
		playerEl.classList.add("hidden");
		document.body.style.overflow = "";
		if (player && typeof player.pauseVideo === "function") {
			player.pauseVideo();
		}
	}

	document.addEventListener("DOMContentLoaded", () => {
		const grid = document.getElementById("video-grid");
		const sortButtons = document.querySelectorAll(".sort-btn");
		const filterButtons = document.querySelectorAll(".filter-btn");
		const videoItems = Array.from(document.querySelectorAll(".video-item"));
		const paginationControls = document.getElementById(
			"pagination-controls",
		);

		// Pagination state
		let currentPage = 1;
		const videosPerPage = 9;

		function renderPage(itemsToDisplay: HTMLElement[]) {
			// Hide all video items first
			videoItems.forEach((item) => item.classList.add("hidden"));

			// Calculate start and end indices
			const startIndex = (currentPage - 1) * videosPerPage;
			const endIndex = currentPage * videosPerPage;

			// Show only items in the current page range
			itemsToDisplay.slice(startIndex, endIndex).forEach((item) => {
				item.classList.remove("hidden");
			});

			// Update pagination controls
			if (!paginationControls) return;

			const totalPages = Math.ceil(itemsToDisplay.length / videosPerPage);
			paginationControls.innerHTML = "";

			if (totalPages <= 1) return;

			// Create page buttons
			for (let i = 1; i <= totalPages; i++) {
				const button = document.createElement("button");
				button.textContent = String(i);
				button.className = `rounded-full border px-4 py-2 text-sm font-medium transition-colors cursor-pointer ${
					i === currentPage
						? "border-accent bg-accent text-zinc-950"
						: "border-white/10 bg-zinc-900/50 text-zinc-400 hover:border-accent/50 hover:text-white"
				}`;
				button.addEventListener("click", () => {
					currentPage = i;
					renderPage(itemsToDisplay);
				});
				paginationControls.appendChild(button);
			}
		}

		function sortVideos(criteria: "latest" | "popular" | "oldest") {
			if (!grid) return;

			const sorted = [...videoItems].sort((a, b) => {
				const dateA = new Date(
					a.getAttribute("data-publish-date") || "",
				).getTime();
				const dateB = new Date(
					b.getAttribute("data-publish-date") || "",
				).getTime();
				const viewsA = parseInt(
					a.getAttribute("data-views") || "0",
					10,
				);
				const viewsB = parseInt(
					b.getAttribute("data-views") || "0",
					10,
				);

				if (criteria === "latest") return dateB - dateA;
				if (criteria === "oldest") return dateA - dateB;
				if (criteria === "popular") return viewsB - viewsA;
				return 0;
			});

			sorted.forEach((item) => grid.appendChild(item));

			// Reset to first page and render
			currentPage = 1;
			renderPage(videoItems as HTMLElement[]);
		}

		function filterVideos(category: string) {
			if (!grid) return;

			videoItems.forEach((item) => {
				const title = (
					item.getAttribute("data-title") || ""
				).toUpperCase();
				let shouldShow = false;

				switch (category) {
					case "all":
						shouldShow = true;
						break;
					case "motw":
						shouldShow =
							title.includes("MOTW") ||
							title.includes("MAN OF THE WORLD");
						break;
					case "pov":
						shouldShow = title.includes("POV");
						break;
					case "narrative":
						shouldShow =
							(title.includes("ANO") ||
								title.includes("ANG") ||
								title.includes("BAKIT") ||
								title.includes("SOHOTON") ||
								title.includes("SAND DUNES") ||
								title.includes("PREVENTION") ||
								title.includes("PAANO") ||
								title.includes("NEW YEAR") ||
								title.includes("DYNASTY")) &&
							!title.includes("MIGZ") &&
							!title.includes("PERIOD") &&
							!title.includes("SAY WHAT");
						break;
					case "saywhat":
						shouldShow = title.includes("SAY WHAT");
						break;
					case "fashion":
						shouldShow = title.includes("FASHION");
						break;
					case "anong-bago":
						shouldShow =
							title.includes("BAGO") && title.includes("MIGZ");
						break;
					case "highlights":
						shouldShow =
							title.includes("MONARCH HIGHLIGHTS") ||
							title.includes("DRAGON BOAT") ||
							title.includes("SALTY COCONUT");
						break;
					case "others":
						shouldShow =
							!title.includes("MOTW") &&
							!title.includes("MAN OF THE WORLD") &&
							!title.includes("POV") &&
							!title.includes("SAY WHAT") &&
							!title.includes("FASHION") &&
							!(
								title.includes("BAGO") && title.includes("MIGZ")
							) &&
							!title.includes("MONARCH HIGHLIGHTS") &&
							!title.includes("DRAGON BOAT") &&
							!title.includes("SALTY COCONUT") &&
							!title.includes("ANO") &&
							!title.includes("ANG") &&
							!title.includes("BAKIT") &&
							!title.includes("SOHOTON") &&
							!title.includes("SAND DUNES") &&
							!title.includes("PREVENTION") &&
							!title.includes("PAANO") &&
							!title.includes("NEW YEAR") &&
							!title.includes("DYNASTY");
						break;
					default:
						shouldShow = true;
				}

				if (shouldShow) {
					item.classList.remove("hidden");
				} else {
					item.classList.add("hidden");
				}
			});

			// Filter the videoItems array and render paginated results
			const filteredResult = videoItems.filter(
				(item) => !item.classList.contains("hidden"),
			);
			currentPage = 1;
			renderPage(filteredResult as HTMLElement[]);
		}

		sortButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				sortButtons.forEach((b) => {
					b.classList.remove(
						"active",
						"bg-accent",
						"text-zinc-950",
						"border-accent",
					);
					b.classList.add(
						"bg-zinc-900/50",
						"text-zinc-400",
						"border-white/10",
					);
				});

				btn.classList.add(
					"active",
					"bg-accent",
					"text-zinc-950",
					"border-accent",
				);
				btn.classList.remove(
					"bg-zinc-900/50",
					"text-zinc-400",
					"border-white/10",
				);

				const sortId = btn.id;
				if (sortId === "sort-latest") sortVideos("latest");
				if (sortId === "sort-popular") sortVideos("popular");
				if (sortId === "sort-oldest") sortVideos("oldest");
			});
		});

		filterButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				filterButtons.forEach((b) => {
					b.classList.remove(
						"active",
						"bg-accent",
						"text-zinc-950",
						"border-accent",
					);
					b.classList.add(
						"bg-zinc-900/50",
						"text-zinc-400",
						"border-white/10",
					);
				});

				btn.classList.add(
					"active",
					"bg-accent",
					"text-zinc-950",
					"border-accent",
				);
				btn.classList.remove(
					"bg-zinc-900/50",
					"text-zinc-400",
					"border-white/10",
				);

				const filterId = btn.id;
				if (filterId === "filter-all") filterVideos("all");
				if (filterId === "filter-motw") filterVideos("motw");
				if (filterId === "filter-pov") filterVideos("pov");
				if (filterId === "filter-narrative") filterVideos("narrative");
				if (filterId === "filter-saywhat") filterVideos("saywhat");
				if (filterId === "filter-fashion") filterVideos("fashion");
				if (filterId === "filter-anong-bago")
					filterVideos("anong-bago");
				if (filterId === "filter-highlights")
					filterVideos("highlights");
				if (filterId === "filter-others") filterVideos("others");
			});
		});

		videoItems.forEach((item) => {
			item.addEventListener("click", () => {
				const videoId = item.getAttribute("data-video-id");
				playVideo(videoId);
			});
		});

		document
			.getElementById("close-player")
			?.addEventListener("click", closePlayer);
		document
			.getElementById("player-backdrop")
			?.addEventListener("click", closePlayer);

		// Initial render
		renderPage(videoItems as HTMLElement[]);
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			const playerEl = document.getElementById(
				"video-player",
			) as HTMLElement;
			if (playerEl && !playerEl.classList.contains("hidden")) {
				closePlayer();
			}
		}
	});
</script>
