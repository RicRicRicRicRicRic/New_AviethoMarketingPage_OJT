---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;

interface Video {
	title: string;
	description: string;
	url: string;
	publishedAt: string;
	thumbnail?: string;
	videoId?: string;
	views?: number | null;
}

const youtubeApiKey = import.meta.env.YOUTUBE_API_KEY;
const playlistId = "UUEQxQm4eB6lsMuKK2WFyUAA";
const hiddenVideoIds = ["NhLiCOl-gqI"];

// Debug: Check if API key is loaded (safe)
console.log(
	"[production] YouTube API Key loaded:",
	youtubeApiKey ? `${youtubeApiKey.slice(0, 8)}...` : "NOT FOUND",
);
console.log("[production] Playlist ID:", playlistId);

const getVideos = async (): Promise<Video[]> => {
	try {
		if (!youtubeApiKey) {
			throw new Error(
				"YouTube API key is missing. Please set YOUTUBE_API_KEY in your .env file.",
			);
		}

		// Validate playlist ID to prevent corruption issues
		if (
			!playlistId ||
			playlistId.length !== 24 ||
			!playlistId.startsWith("UU")
		) {
			throw new Error(`Invalid playlist ID: ${playlistId}`);
		}

		// Step 1: Fetch all videos with pagination (max 50 per request)
		const allItems: any[] = [];
		let nextPageToken: string | null = null;
		let hasMore = true;
		let pageCount = 0;
		const maxPages = 2; // Reduced to 2 for testing to conserve API quota

		while (hasMore && pageCount < maxPages) {
			pageCount++;
			let playlistUrl = `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=${playlistId}&maxResults=50&key=${youtubeApiKey}`;

			if (nextPageToken) {
				playlistUrl += `&pageToken=${nextPageToken}`;
			}

			const maskedKey = youtubeApiKey
				? `${youtubeApiKey.slice(0, 8)}...`
				: "MISSING";
			console.log(
				`[production] Fetching page ${pageCount}:`,
				playlistUrl.replace(youtubeApiKey, maskedKey),
			);

			const playlistRes = await fetch(playlistUrl, {
				headers: {
					Accept: "application/json",
				},
			});

			if (!playlistRes.ok) {
				const errorText = await playlistRes.text();
				console.error("[production] API Error Response:", errorText);
				throw new Error(
					`YouTube API playlistItems failed with status ${playlistRes.status}: ${errorText}`,
				);
			}

			const playlistData = await playlistRes.json();

			if (!playlistData.items || playlistData.items.length === 0) {
				if (pageCount === 1) {
					throw new Error("No videos found in API response");
				}
				break;
			}

			// Filter out LIVE videos (case-insensitive)
			const filteredItems = playlistData.items.filter(
				(item: any) =>
					!item.snippet?.title?.toUpperCase().includes("LIVE"),
			);

			const liveCount = playlistData.items.length - filteredItems.length;
			if (liveCount > 0) {
				console.log(
					`[production] Filtered out ${liveCount} LIVE video(s) from page ${pageCount}`,
				);
			}

			allItems.push(...filteredItems);
			console.log(
				`[production] Page ${pageCount}: Fetched ${filteredItems.length} videos (Total: ${allItems.length})`,
			);

			// Check if there are more pages
			nextPageToken = playlistData.nextPageToken || null;
			hasMore = !!nextPageToken;
		}

		// Filter out hidden videos
		const itemsBeforeFilter = allItems.length;
		const filteredItems = allItems.filter((item: any) => {
			const videoId = item.snippet?.resourceId?.videoId;
			return !hiddenVideoIds.includes(videoId);
		});
		const hiddenCount = itemsBeforeFilter - filteredItems.length;

		if (hiddenCount > 0) {
			console.log(
				`[production] Filtered out ${hiddenCount} hidden video(s)`,
			);
		}

		// Replace allItems with filtered items
		allItems.length = 0;
		allItems.push(...filteredItems);

		if (allItems.length === 0) {
			throw new Error("No videos found");
		}

		console.log(
			`[production] Successfully fetched ${allItems.length} total videos from ${pageCount} page(s)`,
		);

		// Step 2: Extract video IDs and fetch statistics (in batches of 50)
		const allVideoIds = allItems
			.map((item: any) => item.snippet?.resourceId?.videoId)
			.filter((id: string | undefined) => id);

		if (allVideoIds.length === 0) {
			throw new Error("No valid video IDs found");
		}

		// YouTube API allows max 50 IDs per request, so batch them
		const batchSize = 50;
		const statsMap = new Map<string, number>();

		for (let i = 0; i < allVideoIds.length; i += batchSize) {
			const batch = allVideoIds.slice(i, i + batchSize);
			const batchIds = batch.join(",");
			const batchNum = Math.floor(i / batchSize) + 1;
			const totalBatches = Math.ceil(allVideoIds.length / batchSize);

			console.log(
				`[production] Fetching statistics batch ${batchNum}/${totalBatches} (${batch.length} videos)`,
			);

			const statsUrl = `https://www.googleapis.com/youtube/v3/videos?key=${youtubeApiKey}&id=${batchIds}&part=statistics`;
			const statsRes = await fetch(statsUrl, {
				headers: {
					Accept: "application/json",
				},
			});

			if (!statsRes.ok) {
				const errorText = await statsRes.text();
				console.error(
					`[production] Statistics API Error Response (batch ${batchNum}):`,
					errorText,
				);
				throw new Error(
					`YouTube API statistics fetch failed with status ${statsRes.status}: ${errorText}`,
				);
			}

			const statsData = await statsRes.json();
			const batchStats = new Map<string, number>(
				statsData.items?.map((item: any) => [
					item.id as string,
					parseInt(String(item.statistics?.viewCount || "0")),
				]) || [],
			);

			for (const [key, value] of batchStats) {
				statsMap.set(key, value);
			}
			console.log(
				`[production] Batch ${batchNum}: Fetched statistics for ${batchStats.size} videos`,
			);
		}

		console.log(
			"[production] Successfully fetched statistics for",
			statsMap.size,
			"videos total",
		);

		// Step 3: Map to Video interface (NO SLICE - include all videos)
		const videos: Video[] = allItems.map((item: any) => {
			const snippet = item.snippet;
			const videoId = snippet?.resourceId?.videoId;
			const views = statsMap.get((videoId || "") as string) || null;

			return {
				title: snippet?.title || "Untitled Video",
				description: snippet?.description || "No description available",
				url: `https://www.youtube.com/watch?v=${videoId}`,
				publishedAt: snippet?.publishedAt || new Date().toISOString(),
				thumbnail:
					snippet?.thumbnails?.high?.url ||
					snippet?.thumbnails?.medium?.url ||
					snippet?.thumbnails?.default?.url,
				videoId,
				views: views || undefined,
			};
		});

		console.log(`[production] Returning ${videos.length} videos`);
		return videos;
	} catch (err) {
		console.error("[production] Full error details:", err);
		console.error(
			"[production] Error message:",
			err instanceof Error ? err.message : "Unknown error",
		);
		throw err;
	}
};

const videos = await getVideos();
---

<BaseLayout title="Production - Avietho">
	<div class="section-wrapper">
		<div class="mx-auto max-w-7xl px-6 py-20 md:px-8 lg:px-10">
