										{video.title}
									</h3>
									<p class="mt-2 text-sm text-zinc-400 line-clamp-2">
										{video.description}
									</p>
									<div class="mt-4 flex items-center justify-between text-xs text-zinc-500">
										<span>
											{new Date(
												video.publishedAt,
											).toLocaleDateString(undefined, {
												year: "numeric",
												month: "short",
												day: "numeric",
											})}
										</span>
										<span>
											{video.views !== null &&
											video.views !== undefined
												? `${video.views.toLocaleString()} views`
												: ""}
										</span>
