						))}
					</div>
				) : (
					<div class="mt-10 text-center text-zinc-400">
						<p>
							No videos found. Please check the YouTube API
							configuration.
						</p>
					</div>
				)
			}

			<!-- Pagination Controls -->
			<div
				id="pagination-controls"
				class="mt-25 flex justify-center gap-4"
			>
			</div>

			<!-- Note about Popular sorting -->
			<div
				class="animate-reveal-up mt-8 text-center text-sm text-zinc-500"
				style="animation-delay:300ms"
			>
			</div>
		</div>
	</div>

	<!-- Video pop-up modal -->
	<div
		id="video-player"
		class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
	>
		<div
			id="player-backdrop"
			class="absolute inset-0 bg-black/92 backdrop-blur-[6px]"
		>
		</div>
		<div class="relative w-full max-w-[1100px]">
			<div
				class="relative aspect-video overflow-hidden rounded-2xl border border-white/10 bg-black shadow-[0_30px_80px_rgba(0,0,0,0.6)]"
			>
				<div id="player-container" class="h-full w-full"></div>
				<button
					id="close-player"
					aria-label="Close video"
					class="absolute top-[14px] right-[14px] z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-black/60 text-lg text-white transition-all duration-200 hover:border-accent hover:bg-accent hover:text-zinc-950"
					>✕</button
				>
			</div>
		</div>
