---
// Home page composed of modular section components
// Centralized layout control for consistent section heights and alignment
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/index_sections/Hero.astro';
import ServicesPreview from '../components/sections/index_sections/ServicesPreview.astro';
import WebsiteDevelopment from '../components/sections/index_sections/WebsiteDevelopment.astro';
import TeamPreview from '../components/sections/index_sections/TeamPreview.astro';
import Socials from '../components/sections/index_sections/Socials.astro';
import WorkShowcase from '../components/sections/index_sections/WorkShowcase.astro';
---

<BaseLayout >
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<Hero />
	</div>
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<ServicesPreview/>
	</div>
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<WebsiteDevelopment />
	</div>
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<TeamPreview/>
	</div>
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<Socials/>
	</div>
	<div class="section-wrapper min-h-[60vh] flex flex-col items-center justify-center">
		<WorkShowcase/>
	</div>
</BaseLayout>

<style>
	/* Centralized section height and layout control */
	/* Single source of truth for vertical spacing across all sections */
	.section-wrapper {
		min-height: 60vh;
		width: 100%;
	}
</style>
