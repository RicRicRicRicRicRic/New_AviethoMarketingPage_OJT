---
// Home page composed of modular section components
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/index_sections/Hero.astro';
import ServicesPreview from '../components/sections/index_sections/ServicesPreview.astro';
import WebsiteDevelopment from '../components/sections/index_sections/WebsiteDevelopment.astro';
import TeamPreview from '../components/sections/index_sections/TeamPreview.astro';
import Socials from '../components/sections/index_sections/Socials.astro';
import WorkShowcase from '../components/sections/index_sections/WorkShowcase.astro';
---

<BaseLayout title="Avietho - Home">
	<Hero 
		title="Avietho"
		subtitle="Independent journalism for a complex world."
	>
		<slot name="cta-primary" slot="cta-primary">
			<a href="#services" class="px-8 py-3 bg-accent text-background font-semibold rounded hover:bg-accent-hover transition-colors">
				Explore Services
			</a>
		</slot>
		<slot name="cta-secondary" slot="cta-secondary">
			<a href="#work" class="px-8 py-3 border border-accent text-accent font-semibold rounded hover:bg-accent hover:text-background transition-colors">
				View Our Work
			</a>
		</slot>
	</Hero>

	<ServicesPreview title="Our Services" />

	<WebsiteDevelopment 
		title="Website Development"
		description="We build high-performance, accessible websites for media organizations and independent journalists. Our solutions prioritize speed, security, and user experience."
	>
		<slot name="features" slot="features">
			<ul class="space-y-3">
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Static-first architecture for optimal performance</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">WCAG 2.1 AA accessibility compliance</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Secure, decoupled backend integration</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Responsive design for all devices</span>
				</li>
			</ul>
		</slot>
		<slot name="visual" slot="visual">
			<div class="aspect-video bg-background rounded flex items-center justify-center">
				<p class="text-gray-500 text-sm">Technology Stack Visualization</p>
			</div>
		</slot>
	</WebsiteDevelopment>

	<TeamPreview title="Our Team">
		<slot name="team-member-1" slot="team-member-1">
			<div class="text-center">
				<div class="w-32 h-32 mx-auto bg-background-card rounded-full mb-4 flex items-center justify-center">
					<span class="text-accent text-2xl">AR</span>
				</div>
				<h3 class="text-lg font-semibold text-accent">Alex Rivera</h3>
				<p class="text-gray-400 text-sm">Founder & Editor-in-Chief</p>
			</div>
		</slot>
		<slot name="team-member-2" slot="team-member-2">
			<div class="text-center">
				<div class="w-32 h-32 mx-auto bg-background-card rounded-full mb-4 flex items-center justify-center">
					<span class="text-accent text-2xl">JC</span>
				</div>
				<h3 class="text-lg font-semibold text-accent">Jordan Chen</h3>
				<p class="text-gray-400 text-sm">Lead Developer</p>
			</div>
		</slot>
		<slot name="team-member-3" slot="team-member-3">
			<div class="text-center">
				<div class="w-32 h-32 mx-auto bg-background-card rounded-full mb-4 flex items-center justify-center">
					<span class="text-accent text-2xl">MP</span>
				</div>
				<h3 class="text-lg font-semibold text-accent">Morgan Park</h3>
				<p class="text-gray-400 text-sm">Senior Journalist</p>
			</div>
		</slot>
		<slot name="team-member-4" slot="team-member-4">
			<div class="text-center">
				<div class="w-32 h-32 mx-auto bg-background-card rounded-full mb-4 flex items-center justify-center">
					<span class="text-accent text-2xl">ST</span>
				</div>
				<h3 class="text-lg font-semibold text-accent">Sam Taylor</h3>
				<p class="text-gray-400 text-sm">Data Analyst</p>
			</div>
		</slot>
	</TeamPreview>

	<Socials>
		<slot name="social-links" slot="social-links">
			<div class="flex flex-wrap justify-center gap-4">
				<a href="#" class="px-6 py-3 bg-background-card border border-gray-800 rounded hover:border-accent transition-colors">
					<span class="text-accent">Twitter</span>
				</a>
				<a href="#" class="px-6 py-3 bg-background-card border border-gray-800 rounded hover:border-accent transition-colors">
					<span class="text-accent">LinkedIn</span>
				</a>
				<a href="#" class="px-6 py-3 bg-background-card border border-gray-800 rounded hover:border-accent transition-colors">
					<span class="text-accent">RSS Feed</span>
				</a>
				<a href="#" class="px-6 py-3 bg-background-card border border-gray-800 rounded hover:border-accent transition-colors">
					<span class="text-accent">Email</span>
				</a>
			</div>
		</slot>
	</Socials>

	<WorkShowcase>
		<slot name="work-item-1" slot="work-item-1">
			<div class="bg-background-card p-6 rounded-lg border border-gray-800">
				<h3 class="text-lg font-semibold text-accent mb-2">Investigation Series</h3>
				<p class="text-gray-300 text-sm mb-4">Award-winning investigative reporting on environmental issues.</p>
				<a href="#" class="text-accent text-sm hover:underline">Read More →</a>
			</div>
		</slot>
		<slot name="work-item-2" slot="work-item-2">
			<div class="bg-background-card p-6 rounded-lg border border-gray-800">
				<h3 class="text-lg font-semibold text-accent mb-2">Digital Archive</h3>
				<p class="text-gray-300 text-sm mb-4">Comprehensive digital archive preserving independent journalism.</p>
				<a href="#" class="text-accent text-sm hover:underline">Explore Archive →</a>
			</div>
		</slot>
		<slot name="work-item-3" slot="work-item-3">
			<div class="bg-background-card p-6 rounded-lg border border-gray-800">
				<h3 class="text-lg font-semibold text-accent mb-2">Community Impact</h3>
				<p class="text-gray-300 text-sm mb-4">Stories that drive meaningful change in local communities.</p>
				<a href="#" class="text-accent text-sm hover:underline">Learn More →</a>
			</div>
		</slot>
	</WorkShowcase>

</BaseLayout>