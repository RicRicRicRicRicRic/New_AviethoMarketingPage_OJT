---
import BaseLayout from "../layouts/BaseLayout.astro";

type StreamItem = {
	title: string;
	description: string;
	url: string;
	publishedAt: string;
	// Real view counts are fetched separately via the YouTube Data API's
	// videos.list statistics field (see fetchStreamsFromApi below) — null
	// means "couldn't determine it," not "zero views."
	views: number | null;
	duration: string;
	badge: string;
	thumbnail?: string;
	videoId?: string;
};

const youtubeApiKey = import.meta.env.YOUTUBE_API_KEY;
const channelId = "UCEQxQm4eB6lsMuKK2WFyUAA";

// Short-lived in-memory cache so a burst of page views doesn't re-hit the
// YouTube API (and its quota) on every single request. Lives for the
// lifetime of the server process/instance — on a long-running Node server
// that means it's shared across all visitors until it expires; on
// serverless/edge platforms each cold-start instance keeps its own copy,
// so the effective TTL there is closer to "per warm instance" than
// global. Good enough to smooth out normal traffic; if you need a
// guaranteed cross-instance cache on serverless, that's what a real KV
// (Cloudflare KV, Vercel KV, Upstash, etc.) is for.
const CACHE_TTL_MS = 10 * 60 * 1000; // 10 minutes
let streamsCache: { data: StreamItem[]; fetchedAt: number } | null = null;

// Real YouTube Live Stream Videos from @aviethodigital
const fallbackStreams: StreamItem[] = [
	{
		title: "LIVE | The 8th Annual Man of the World Finals Night at Palacio de Maynila",
		description:
			"The 8th Annual Man of the World Finals Night at Palacio de Maynila Powered by Avietho Digital. #ManoftheWorld2026 #AviethoDigital.",
		url: "https://www.youtube.com/watch?v=AhegrxF80J4",
		publishedAt: "2026-06-06T18:30:00Z",
		views: 47000,
		duration: "Live replay",
		badge: "Popular",
		videoId: "AhegrxF80J4",
		thumbnail: "https://i.ytimg.com/vi/AhegrxF80J4/hqdefault.jpg",
	},
	{
		title: "LIVE | The Philippine International D' Elite Gala of Man of the World 2026",
		description:
			"The Philippine International D' Elite Gala of Man of the World 2026 at Palacio de Maynila. #ManoftheWorld2026 #AviethoDigital.",
		url: "https://www.youtube.com/watch?v=Uw29e-tUW3Y",
		publishedAt: "2026-06-01T15:00:00Z",
		views: 10500,
		duration: "Live replay",
		badge: "Recent",
		videoId: "Uw29e-tUW3Y",
		thumbnail: "https://i.ytimg.com/vi/Uw29e-tUW3Y/hqdefault.jpg",
	},
	{
		title: "Avietho Digital POV Episode 7 (Marj De Leon)",
		description:
			"Avietho Digital's exclusive interview with Landco Sales Director and Licensed Real Estate Broker Ms. Marj De Leon as she talks about the gift of life—family, friends, and career. Voices that lead. Stories that inspire.",
		url: "https://www.youtube.com/watch?v=cFRLpDkrZWw",
		publishedAt: "2025-09-11T12:00:00Z",
		views: 249,
		duration: "Interview",
		badge: "POV",
		videoId: "cFRLpDkrZWw",
		thumbnail: "https://i.ytimg.com/vi/cFRLpDkrZWw/hqdefault.jpg",
	},
	{
		title: "AVIETHO DIGITAL PROGRAM (Intro)",
		description:
			"Explore the world of news, entertainment, food, and travels at Avietho Digital. Stay informed and entertained through our digital programs such as Period Podcast, KaladKain, Istorya, Transparency Talk, Say What, and Legaltok.",
		url: "https://www.youtube.com/watch?v=up-QvShfPrw",
		publishedAt: "2025-03-25T08:00:00Z",
		views: 1210,
		duration: "Program",
		badge: "Intro",
		videoId: "up-QvShfPrw",
		thumbnail: "https://i.ytimg.com/vi/up-QvShfPrw/hqdefault.jpg",
	},
];

// search.list with eventType=live/completed turned out to be an unreliable
// filter — YouTube's search index isn't the authoritative source for
// "was this video actually broadcast live," so it was letting regular
// uploads (and premieres) slip into the results. The reliable way to
// check that is a video's own liveStreamingDetails field, which is only
// present on videos that actually went live — the same signal YouTube
// itself uses for the channel's Live tab
// (https://www.youtube.com/@aviethodigital/streams).
//
// That means walking the channel's real upload list first (there's no
// "give me only past broadcasts" list endpoint), then checking each
// video individually.

const fetchUploadsPlaylistId = async (): Promise<string> => {
	const url = `https://www.googleapis.com/youtube/v3/channels?part=contentDetails&id=${channelId}&key=${youtubeApiKey}`;
	const res = await fetch(url, { headers: { Accept: "application/json" } });
	if (!res.ok) {
		const errorText = await res.text();
		throw new Error(
			`YouTube API channels lookup failed with status ${res.status}: ${errorText}`,
		);
	}

	const data = await res.json();
	const uploadsPlaylistId =
		data.items?.[0]?.contentDetails?.relatedPlaylists?.uploads;
	if (!uploadsPlaylistId) {
		throw new Error(
			"Could not resolve uploads playlist ID for this channel",
		);
	}

	return uploadsPlaylistId;
};

const fetchAllUploadedVideoIds = async (
	playlistId: string,
): Promise<string[]> => {
	const ids: string[] = [];
	let nextPageToken: string | null = null;
	let hasMore = true;
	let pageCount = 0;
	const maxPages = 20; // up to 1000 videos — safety limit

	while (hasMore && pageCount < maxPages) {
		pageCount++;
		let url = `https://www.googleapis.com/youtube/v3/playlistItems?part=contentDetails&playlistId=${playlistId}&maxResults=50&key=${youtubeApiKey}`;
		if (nextPageToken) {
			url += `&pageToken=${nextPageToken}`;
		}

		const res = await fetch(url, {
			headers: { Accept: "application/json" },
		});
		if (!res.ok) {
			const errorText = await res.text();
			throw new Error(
				`YouTube API playlistItems fetch failed with status ${res.status}: ${errorText}`,
			);
		}

		const data = await res.json();
		for (const item of data.items || []) {
			const videoId = item.contentDetails?.videoId;
			if (videoId) ids.push(videoId);
		}

		nextPageToken = data.nextPageToken || null;
		hasMore = !!nextPageToken;
	}

	return ids;
};

const fetchVideoDetails = async (videoIds: string[]): Promise<any[]> => {
	const details: any[] = [];
	const batchSize = 50; // the API's per-request max for a videos.list id list

	for (let i = 0; i < videoIds.length; i += batchSize) {
		const batchIds = videoIds.slice(i, i + batchSize).join(",");
		const url = `https://www.googleapis.com/youtube/v3/videos?part=snippet,statistics,liveStreamingDetails&id=${batchIds}&key=${youtubeApiKey}`;
		const res = await fetch(url, {
			headers: { Accept: "application/json" },
		});
		if (!res.ok) {
			const errorText = await res.text();
			throw new Error(
				`YouTube API videos fetch failed with status ${res.status}: ${errorText}`,
			);
		}

		const data = await res.json();
		details.push(...(data.items || []));
	}

	return details;
};

const fetchStreamsFromApi = async (): Promise<StreamItem[]> => {
	if (!youtubeApiKey) {
		throw new Error(
			"YouTube API key is missing. Please set YOUTUBE_API_KEY in your .env file.",
		);
	}

	if (!channelId || channelId.length !== 24 || !channelId.startsWith("UC")) {
		throw new Error(`Invalid channel ID: ${channelId}`);
	}

	const uploadsPlaylistId = await fetchUploadsPlaylistId();
	const videoIds = await fetchAllUploadedVideoIds(uploadsPlaylistId);

	if (videoIds.length === 0) {
		throw new Error("Channel has no uploaded videos");
	}

	const details = await fetchVideoDetails(videoIds);

	// The one filter that actually matches YouTube's own "Live" tab:
	// only videos that have an actualStartTime (meaning they genuinely
	// went live at some point), not just any video that happened to show
	// up in a keyword search.
	const liveOnly = details.filter(
		(v) => v.liveStreamingDetails?.actualStartTime,
	);

	if (liveOnly.length === 0) {
		throw new Error("No live stream broadcasts found for this channel");
	}

	liveOnly.sort(
		(a, b) =>
			new Date(b.liveStreamingDetails.actualStartTime).getTime() -
			new Date(a.liveStreamingDetails.actualStartTime).getTime(),
	);

	return liveOnly.map((v) => {
		const snippet = v.snippet;
		const videoId = v.id;
		const lsd = v.liveStreamingDetails;
		const isLive = Boolean(lsd.actualStartTime) && !lsd.actualEndTime;

		return {
			title: snippet?.title || "Untitled Stream",
			description: snippet?.description || "No description available",
			url: `https://www.youtube.com/watch?v=${videoId}`,
			publishedAt:
				lsd.actualStartTime ||
				snippet?.publishedAt ||
				new Date().toISOString(),
			views: v.statistics?.viewCount
				? parseInt(v.statistics.viewCount, 10)
				: null,
			duration: isLive ? "Live now" : "Live replay",
			badge: isLive ? "Live" : "Replay",
			thumbnail:
				snippet?.thumbnails?.high?.url ||
				snippet?.thumbnails?.medium?.url ||
				snippet?.thumbnails?.default?.url,
			videoId,
		};
	});
};

const getStreams = async (): Promise<StreamItem[]> => {
	// Serve straight from cache if it's still fresh — skips the YouTube
	// API entirely.
	if (streamsCache && Date.now() - streamsCache.fetchedAt < CACHE_TTL_MS) {
		console.log("[streams] Serving from in-memory cache");
		return streamsCache.data;
	}

	try {
		const data = await fetchStreamsFromApi();
		streamsCache = { data, fetchedAt: Date.now() };
		return data;
	} catch (err) {
		console.error("[streams] Fetch failed:", err);

		// Prefer serving a stale cached copy over the hardcoded fallback —
		// "a bit old" beats "not real data" — and don't refresh the cache
		// timestamp, so the next request tries the API again instead of
		// locking in the stale copy for another full TTL window.
		if (streamsCache) {
			console.warn("[streams] Serving stale cache after fetch failure");
			return streamsCache.data;
		}

		console.warn(
			"[streams] No cache available — falling back to static stream list",
		);
		return fallbackStreams;
	}
};

const streams = await getStreams();
---

<BaseLayout title="Livestreams - Avietho">
	<div class="section-wrapper">
		<div class="mx-auto max-w-7xl px-6 py-20 md:px-8 lg:px-10">
			<!-- Header -->
			<header
				class="reveal-on-load flex flex-col items-center mx-auto max-w-2xl text-center"
				style="animation-delay:0ms"
			>
				<div
					class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-accent"
				>
					<span class="h-2 w-2 rounded-full bg-accent animate-pulse"
					></span>
					Live Showcase
				</div>
				<h1
					class="mt-5 text-4xl md:text-5xl font-bold text-white tracking-tight"
				>
					Livestreams
				</h1>
				<p class="mt-4 text-lg text-zinc-400">
					Broadcasts and replays from <a
						href="https://www.youtube.com/@aviethodigital"
						target="_blank"
						rel="noopener noreferrer"
						class="text-accent underline underline-offset-4 decoration-accent/40 transition-colors hover:decoration-accent"
						>Avietho Digital</a
					>.
				</p>
			</header>

			<hr
				class="reveal-on-load mt-12 border-white/10"
				style="animation-delay:80ms"
			/>

			<!-- Sort controls -->
			<div
				class="reveal-on-load mt-12 flex flex-wrap items-center justify-center gap-2 border-b border-white/10 pb-6"
				style="animation-delay:160ms"
			>
				<span
					class="mr-2 text-xs uppercase tracking-[0.15em] text-zinc-500"
					>Sort by</span
				>
				<button
					id="sort-latest"
					class="sort-btn active rounded-full border border-accent bg-accent px-4 py-1.5 text-sm font-medium text-zinc-950 transition-colors cursor-pointer"
				>
					Latest
				</button>
				<button
					id="sort-popular"
					class="sort-btn rounded-full border border-white/10 bg-zinc-900/50 px-4 py-1.5 text-sm font-medium text-zinc-400 transition-colors cursor-pointer"
				>
					Popular
				</button>
				<button
					id="sort-oldest"
					class="sort-btn rounded-full border border-white/10 bg-zinc-900/50 px-4 py-1.5 text-sm font-medium text-zinc-400 transition-colors cursor-pointer"
				>
					Oldest
				</button>
			</div>

			<!-- Grid -->
			<div
				class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3"
				id="stream-grid"
			>
				{
					streams.map((stream, idx) => (
						<article
							class="stream-item reveal-on-load group cursor-pointer overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/60 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:shadow-xl hover:shadow-black/40"
							data-video-id={stream.videoId || ""}
							data-publish-date={stream.publishedAt}
							data-views={stream.views}
							style={`animation-delay:${220 + idx * 70}ms`}
						>
							<div class="relative aspect-video overflow-hidden bg-zinc-900">
								{stream.thumbnail ? (
									<img
										src={stream.thumbnail}
										alt={stream.title}
										class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
										loading="lazy"
										onerror="this.onerror=null; this.src='/VideoProduction.png'; this.classList.add('object-contain', 'p-4');"
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center bg-zinc-900">
										<svg
											class="h-16 w-16 text-zinc-700"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
											/>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
											/>
										</svg>
									</div>
								)}
								<div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
									<div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/95 text-zinc-950">
										<span class="ml-0.5 text-xl">▶</span>
									</div>
								</div>
								<span class="absolute left-3 top-3 rounded-full bg-black/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-white">
									{stream.badge}
								</span>
							</div>
							<div class="p-6">
								<h3 class="text-lg font-semibold leading-snug text-white transition-colors group-hover:text-accent line-clamp-2">
									{stream.title}
								</h3>
								<p class="mt-2 text-sm text-zinc-400 line-clamp-2">
									{stream.description}
								</p>
								<div class="mt-4 flex items-center justify-between text-xs text-zinc-500">
									<span>
										{new Date(
											stream.publishedAt,
										).toLocaleDateString(undefined, {
											year: "numeric",
											month: "short",
											day: "numeric",
										})}
									</span>
									<span>
										{stream.views !== null
											? `${stream.views.toLocaleString()} views`
											: "Views unavailable"}
									</span>
								</div>
							</div>
						</article>
					))
				}
			</div>

			<!-- Pagination Controls -->
			<div
				id="pagination-controls"
				class="mt-10 flex justify-center gap-2"
			>
			</div>
		</div>
	</div>

	<!-- Video pop-up (was an inline section at the top of the page; now a
	     centered modal overlay that floats above the content instead) -->
	<div id="video-player" class="hidden">
		<div id="player-backdrop"></div>
		<div class="video-modal-frame">
			<div class="video-modal-inner">
				<div id="player-container"></div>
				<button id="close-player" aria-label="Close video">✕</button>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	#video-player {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 16px;
	}
	#video-player:not(.hidden) {
		display: flex;
	}
	#player-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.92);
		backdrop-filter: blur(6px);
	}
	.video-modal-frame {
		position: relative;
		width: 100%;
		max-width: 1100px;
	}
	.video-modal-inner {
		position: relative;
		aspect-ratio: 16 / 9;
		border-radius: 16px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: #000;
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
	}
	#player-container {
		width: 100%;
		height: 100%;
	}
	#close-player {
		position: absolute;
		top: 14px;
		right: 14px;
		z-index: 10;
		width: 40px;
		height: 40px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.15);
		background: rgba(0, 0, 0, 0.6);
		color: #fff;
		font-size: 18px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease;
	}
	#close-player:hover {
		background: var(--color-accent, #c9a44c);
		border-color: var(--color-accent, #c9a44c);
		color: #0a0a0a;
	}

	/* Sort pills: hover styling only applies to whichever isn't the
	   currently-active one (JS toggles the .active class, not this). */
	.sort-btn:hover:not(.active) {
		border-color: rgba(255, 255, 255, 0.3);
		color: #fff;
	}

	/* Page-load entrance motion */
	.reveal-on-load {
		animation: reveal-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	@keyframes reveal-up {
		from {
			opacity: 0;
			transform: translateY(18px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal-on-load {
			animation: none;
			opacity: 1;
			transform: none;
		}
		.stream-item:hover {
			transform: none;
		}
	}
</style>

<script>
	// Declaring YT globally on Window for TypeScript compiler safety
	declare global {
		interface Window {
			YT?: any;
			onYouTubeIframeAPIReady?: () => void;
		}
	}

	let player: any = null;
	let currentVideoId = "";

	function loadYouTubeAPI() {
		if (window.YT && window.YT.Player) return Promise.resolve();

		return new Promise<void>((resolve) => {
			const tag = document.createElement("script");
			tag.src = "https://www.youtube.com/iframe_api";
			const firstScript = document.getElementsByTagName("script")[0];
			firstScript.parentNode?.insertBefore(tag, firstScript);

			window.onYouTubeIframeAPIReady = () => {
				resolve();
			};
		});
	}

	async function playVideo(videoId: string | null | undefined) {
		if (!videoId) {
			alert("Video unavailable.");
			return;
		}

		currentVideoId = videoId;
		const playerEl = document.getElementById("video-player") as HTMLElement;
		playerEl.classList.remove("hidden");
		document.body.style.overflow = "hidden";

		await loadYouTubeAPI();

		if (player) {
			player.loadVideoById(videoId);
		} else {
			player = new window.YT.Player("player-container", {
				height: "100%",
				width: "100%",
				videoId: videoId,
				playerVars: {
					autoplay: 1,
					modestbranding: 1,
					rel: 0,
				},
				events: {
					onReady: (event: any) => event.target.playVideo(),
				},
			});
		}
	}

	function closePlayer() {
		const playerEl = document.getElementById("video-player") as HTMLElement;
		playerEl.classList.add("hidden");
		document.body.style.overflow = "";
		if (player && typeof player.pauseVideo === "function") {
			player.pauseVideo();
		}
	}

	// Attach Event Listeners
	document.addEventListener("DOMContentLoaded", () => {
		const grid = document.getElementById("stream-grid");
		const sortButtons = document.querySelectorAll(".sort-btn");
		const streamItems = Array.from(
			document.querySelectorAll(".stream-item"),
		);
		const paginationControls = document.getElementById(
			"pagination-controls",
		);

		// Pagination state
		let currentPage = 1;
		const streamsPerPage = 9;

		function renderPage(itemsToDisplay: HTMLElement[]) {
			// Hide all stream items first
			streamItems.forEach((item) => item.classList.add("hidden"));

			// Calculate start and end indices
			const startIndex = (currentPage - 1) * streamsPerPage;
			const endIndex = currentPage * streamsPerPage;

			// Show only items in the current page range
			itemsToDisplay.slice(startIndex, endIndex).forEach((item) => {
				item.classList.remove("hidden");
			});

			// Update pagination controls
			if (!paginationControls) return;

			const totalPages = Math.ceil(
				itemsToDisplay.length / streamsPerPage,
			);
			paginationControls.innerHTML = "";

			if (totalPages <= 1) return;

			// Create page buttons
			for (let i = 1; i <= totalPages; i++) {
				const button = document.createElement("button");
				button.textContent = String(i);
				button.className = `rounded-full border px-4 py-2 text-sm font-medium transition-colors cursor-pointer ${
					i === currentPage
						? "border-accent bg-accent text-zinc-950"
						: "border-white/10 bg-zinc-900/50 text-zinc-400 hover:border-accent/50 hover:text-white"
				}`;
				button.addEventListener("click", () => {
					currentPage = i;
					renderPage(itemsToDisplay);
				});
				paginationControls.appendChild(button);
			}
		}

		// 1. Client-Side Sorting Logic
		function sortStreams(criteria: "latest" | "popular" | "oldest") {
			if (!grid) return;

			const sorted = [...streamItems].sort((a, b) => {
				const dateA = new Date(
					a.getAttribute("data-publish-date") || "",
				).getTime();
				const dateB = new Date(
					b.getAttribute("data-publish-date") || "",
				).getTime();
				const viewsA = parseInt(
					a.getAttribute("data-views") || "0",
					10,
				);
				const viewsB = parseInt(
					b.getAttribute("data-views") || "0",
					10,
				);

				if (criteria === "latest") return dateB - dateA;
				if (criteria === "oldest") return dateA - dateB;
				if (criteria === "popular") return viewsB - viewsA;
				return 0;
			});

			// Reorders directly inside the DOM so attached event listeners are kept intact
			sorted.forEach((item) => grid.appendChild(item));

			// Reset to first page and render
			currentPage = 1;
			renderPage(streamItems as HTMLElement[]);
		}

		sortButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				// Style manipulation
				sortButtons.forEach((b) => {
					b.classList.remove(
						"active",
						"bg-accent",
						"text-zinc-950",
						"border-accent",
					);
					b.classList.add(
						"bg-zinc-900/50",
						"text-zinc-400",
						"border-white/10",
					);
				});

				btn.classList.add(
					"active",
					"bg-accent",
					"text-zinc-950",
					"border-accent",
				);
				btn.classList.remove(
					"bg-zinc-900/50",
					"text-zinc-400",
					"border-white/10",
				);

				// Call Sort
				const sortId = btn.id;
				if (sortId === "sort-latest") sortStreams("latest");
				if (sortId === "sort-popular") sortStreams("popular");
				if (sortId === "sort-oldest") sortStreams("oldest");
			});
		});

		// 2. Grid Streams Listeners
		streamItems.forEach((item) => {
			item.addEventListener("click", () => {
				const videoId = item.getAttribute("data-video-id");
				playVideo(videoId);
			});
		});

		// 3. Close Player Listeners (button + backdrop click)
		document
			.getElementById("close-player")
			?.addEventListener("click", closePlayer);
		document
			.getElementById("player-backdrop")
			?.addEventListener("click", closePlayer);

		// Initial render
		renderPage(streamItems as HTMLElement[]);
	});

	// Keyboard escape
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			const playerEl = document.getElementById(
				"video-player",
			) as HTMLElement;
			if (playerEl && !playerEl.classList.contains("hidden")) {
				closePlayer();
			}
		}
	});
</script>
