---
// Vertical Slideshow Component - FIXED
// Displays client logos in a vertical stack with autoplay and manual navigation
import type { SlideData } from './SlideshowData.ts';
import { slideshowData } from './SlideshowData.ts';
 
interface Props {
	slides?: SlideData[];
	autoplayDelay?: number;
}
 
const {
	slides = slideshowData,
	autoplayDelay = 5000
} = Astro.props;
---
 
<div class="vertical-slideshow w-full max-w-md mx-auto pointer-events-none" data-slides={JSON.stringify(slides)} data-autoplay-delay={autoplayDelay}>
		<!-- Title -->
		<h2 class="text-2xl md:text-3xl font-bold text-accent text-center mb-4 relative z-20">
			Clients and Partners
		</h2>
	<!-- Slides Container -->
<div class="slides-container relative h-[360px] overflow-hidden rounded-xl bg-transparent cursor-pointer pointer-events-auto" style="contain: strict;">

		
		<!-- Fade overlays for top and bottom -->
		<div class="absolute top-0 left-0 right-0 h-20 bg-gradient-to-b from-background-overlay to-transparent pointer-events-none z-10"></div>
		<div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-background-overlay to-transparent pointer-events-none z-10"></div>
		
		<div class="slides-wrapper flex flex-col gap-4 h-full overflow-hidden transition-transform duration-700 ease-in-out scrollbar-hide" style="padding: 1100px 16px;">
			{slides.map((slide, index) => (
<div
					class="slide-bar flex items-center gap-4 p-4 rounded-lg bg-white/5 backdrop-blur-md border-2 border-white/30 transition-all duration-700 ease-in-out pointer-events-none opacity-40"
					data-slide-index={index}
				>
					<div class="slide-image flex-shrink-0 w-16 h-16 rounded-md overflow-hidden bg-transparent">
						<img
							src={slide.image.src}
							alt={slide.clientName}
							class="w-full h-full object-contain p-2"
							loading="lazy"
						/>
					</div>
					
				<div class="slide-text flex-1 min-w-0 overflow-hidden">
					<h3 class="text-lg font-semibold text-foreground whitespace-nowrap" data-text={slide.clientName}>
						{slide.clientName}
					</h3>
				</div>
				</div>
			))}
		</div>
	</div>
</div>
 
<script>
	interface SlideData {
		id: number;
		image: string;
		clientName: string;
	}
 
	class VerticalSlideshow {
		private slides: SlideData[];
		private currentIndex: number = 0;
		private autoplayDelay: number;
		private autoplayInterval: number | null = null;
		private slideBars: NodeListOf<Element>;
		private slidesWrapper: HTMLElement | null;
		private currentSlideEl: Element | null;
		private totalSlidesEl: Element | null;
		private container: HTMLElement | null;
		
		// Drag state
		private isDragging: boolean = false;
		private startY: number = 0;
		private currentTranslate: number = 0;
		private prevTranslate: number = 0;
		private dragStartTime: number = 0;
		private animationID: number | null = null;
		private totalSlides: number = 0;

		constructor(slides: SlideData[], autoplayDelay: number) {
			this.slides = slides;
			this.autoplayDelay = autoplayDelay;
			this.slideBars = document.querySelectorAll('.slide-bar');
			this.slidesWrapper = document.querySelector('.slides-wrapper');
			this.currentSlideEl = document.getElementById('current-slide');
			this.totalSlidesEl = document.getElementById('total-slides');
			this.container = document.querySelector('.slides-container');
			this.totalSlides = slides.length;
			this.init();
		}

		private init(): void {
			if (this.totalSlidesEl) {
				this.totalSlidesEl.textContent = String(this.slides.length);
			}

			// Wait for layout + images
			const raf = () => {
				this.updateActiveSlide();
				this.startAutoplay();
				this.attachDragNavigation();
			};

			if (document.readyState === 'complete') {
				requestAnimationFrame(raf);
			} else {
				window.addEventListener('load', () => requestAnimationFrame(raf), { once: true });
			}
		}

		private getTranslateY(): number {
			if (!this.slidesWrapper) return 0;
			const transform = this.slidesWrapper.style.transform;
			const match = transform.match(/translateY\(([-\d.]+)px\)/);
			return match ? parseFloat(match[1]) : 0;
		}

		private setTranslateY(y: number): void {
			if (!this.slidesWrapper) return;
			this.slidesWrapper.style.transform = `translateY(${y}px)`;
		}

		private getSlidePosition(index: number): number {
			if (!this.slidesWrapper) return 0;
			const activeBar = this.slideBars[index] as HTMLElement | null;
			if (!activeBar) return 0;

			const containerH = 400;
			const activeTop = activeBar.offsetTop;
			const activeH = activeBar.offsetHeight;
			const targetY = (containerH / 2) - (activeH / 2);
			return targetY - activeTop;
		}

		private updateActiveSlide(): void {
			this.slideBars.forEach((bar, i) => {
				const el = bar as HTMLElement;
				if (i === this.currentIndex) {
					el.style.opacity = '1';
					el.classList.add('border-accent/50');
					el.classList.remove('border-white/10');
				} else {
					el.style.opacity = '0.4';
					el.classList.remove('border-accent/50');
					el.classList.add('border-white/10');
				}
			});

			this.currentTranslate = this.getSlidePosition(this.currentIndex);
			this.prevTranslate = this.currentTranslate;
			this.setTranslateY(this.currentTranslate);

			if (this.currentSlideEl) {
				this.currentSlideEl.textContent = String(this.currentIndex + 1);
			}

			this.checkTextOverflow();
		}

		private checkTextOverflow(): void {
			this.slideBars.forEach((bar) => {
				const heading = bar.querySelector('h3');
				if (heading) {
					const parent = heading.parentElement;
					if (parent && heading.scrollWidth > parent.clientWidth) {
						heading.classList.add('scrolling-text');
					} else {
						heading.classList.remove('scrolling-text');
					}
				}
			});
		}

		private goToSlide(index: number): void {
			// Allow infinite looping
			this.currentIndex = ((index % this.totalSlides) + this.totalSlides) % this.totalSlides;
			this.updateActiveSlide();
			this.resetAutoplay();
		}

		private nextSlide(): void {
			this.goToSlide(this.currentIndex + 1);
		}

		private prevSlide(): void {
			this.goToSlide(this.currentIndex - 1);
		}

		private startAutoplay(): void {
			this.stopAutoplay();
			this.autoplayInterval = window.setInterval(() => this.nextSlide(), this.autoplayDelay);
		}

		private stopAutoplay(): void {
			if (this.autoplayInterval) {
				clearInterval(this.autoplayInterval);
				this.autoplayInterval = null;
			}
		}

		private resetAutoplay(): void {
			this.stopAutoplay();
			this.startAutoplay();
		}

		private attachDragNavigation(): void {
			if (!this.container) return;

			// Mouse events
			this.container.addEventListener('mousedown', this.dragStart.bind(this));
			this.container.addEventListener('mousemove', this.drag.bind(this));
			this.container.addEventListener('mouseup', this.dragEnd.bind(this));
			this.container.addEventListener('mouseleave', this.dragEnd.bind(this));

			// Touch events
			this.container.addEventListener('touchstart', this.dragStart.bind(this), { passive: true });
			this.container.addEventListener('touchmove', this.drag.bind(this), { passive: true });
			this.container.addEventListener('touchend', this.dragEnd.bind(this));
		}

		private dragStart(event: Event): void {
			if (event.type === 'touchstart') {
				const touchEvent = event as TouchEvent;
				if (touchEvent.touches.length === 1) {
					this.startY = touchEvent.touches[0].clientY;
				} else {
					return;
				}
			} else {
				this.startY = (event as MouseEvent).clientY;
			}

			this.isDragging = true;
			this.dragStartTime = Date.now();
			this.currentTranslate = this.getTranslateY();
			this.prevTranslate = this.currentTranslate;
			
			if (this.slidesWrapper) {
				this.slidesWrapper.style.transition = 'none';
			}
			
			this.stopAutoplay();
		}

		private drag(event: Event): void {
			if (!this.isDragging) return;

			let currentY: number;
			if (event.type === 'touchmove') {
				const touchEvent = event as TouchEvent;
				if (touchEvent.touches.length === 1) {
					currentY = touchEvent.touches[0].clientY;
				} else {
					return;
				}
			} else {
				currentY = (event as MouseEvent).clientY;
			}

			const diff = currentY - this.startY;
			this.currentTranslate = this.prevTranslate + diff;
			this.setTranslateY(this.currentTranslate);
		}

		private dragEnd(event: Event): void {
			if (!this.isDragging) return;
			this.isDragging = false;

			if (this.slidesWrapper) {
				this.slidesWrapper.style.transition = 'transform 0.7s ease-in-out';
			}

			const moved = this.currentTranslate - this.prevTranslate;
			const threshold = 50; // Minimum drag distance to change slide

			if (Math.abs(moved) > threshold) {
				if (moved > 0) {
					// Dragged down - go to previous slide
					this.prevSlide();
				} else {
					// Dragged up - go to next slide
					this.nextSlide();
				}
			} else {
				// Snap back to current slide
				this.updateActiveSlide();
			}

			this.startAutoplay();
		}
	}
 
	// Init
	const init = () => {
		const container = document.querySelector('.vertical-slideshow') as HTMLElement | null;
		if (container) {
			const data = JSON.parse(container.dataset.slides || '[]') as SlideData[];
			const delay = parseInt(container.dataset.autoplayDelay || '5000', 10);
			new VerticalSlideshow(data, delay);
		}
	};
 
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
 
<style>
	@keyframes scroll-text {
		0% {
			transform: translateX(0);
		}
		15% {
			transform: translateX(0);
		}
		35% {
			transform: translateX(calc(-100% + 200px));
		}
		50% {
			transform: translateX(calc(-100% + 200px));
		}
		70% {
			transform: translateX(0);
		}
		85% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(0);
		}
	}
 
	.scrolling-text {
		display: inline-block;
		animation: scroll-text 8s ease-in-out infinite;
		padding-right: 40px;
	}
</style>
 