---
// Team Slideshow Component
// Reusable slideshow for displaying team members.
interface TeamMember {
	name: string;
	jobTitle: string;
	description: string;
	imagePath: string;
}

const teamMembers: TeamMember[] = Astro.props.teamMembers;
const currentIndex: number = Astro.props.currentIndex ?? 0;
const teamData = JSON.stringify(teamMembers);

const slotPositions = ['is-farleft', 'is-left', 'is-center', 'is-right', 'is-farright'];
const slotOffsets = [-2, -1, 0, 1, 2];
---

<div class="team-slideshow w-full flex items-center justify-center" data-team-members={teamData} data-current-index={currentIndex}>
	<div
		class="slideshow-wrapper relative w-full max-w-md h-[350px] md:h-[475px] overflow-hidden cursor-grab select-none"
		id="slideshow-wrapper"
	>
		{slotOffsets.map((offset, i) => {
			const member = teamMembers[(currentIndex + offset + teamMembers.length) % teamMembers.length];
			const isActive = offset === 0;
			const alt = isActive ? member.name : offset < 0 ? 'Previous team member' : 'Next team member';
			return (
				<div
					class={`image-slot ${slotPositions[i]}`}
					id={`image-slot-${i}`}
					data-offset={offset}
				>
					<img
						src={member.imagePath}
						alt={alt}
						draggable="false"
						class={`w-full h-full object-cover rounded-lg pointer-events-none ${isActive ? 'shadow-2xl' : 'shadow-lg'}`}
					/>
				</div>
			);
		})}
	</div>
</div>

<script>
	interface TeamMember {
		name: string;
		jobTitle: string;
		description: string;
		imagePath: string;
	}

	const SLOT_CLASSES = ['is-farleft', 'is-left', 'is-center', 'is-right', 'is-farright'];
	const SLOT_OFFSETS = [-2, -1, 0, 1, 2];
	const AUTOPLAY_DELAY = 4500;
	const DRAG_THRESHOLD = 60;

	class TeamSlideshow {
		private members: TeamMember[];
		private currentIndex: number;
		private wrapper: HTMLElement | null;
		private slotOrder: HTMLElement[];
		private autoplayTimer: ReturnType<typeof setInterval> | null;
		private isDragging: boolean;
		private dragStartX: number;
		private dragDeltaX: number;
		private pointerId: number | null;

		constructor(members: TeamMember[], startIndex: number) {
			this.members = members;
			this.currentIndex = startIndex;
			this.autoplayTimer = null;
			this.isDragging = false;
			this.dragStartX = 0;
			this.dragDeltaX = 0;
			this.pointerId = null;
			this.wrapper = document.getElementById('slideshow-wrapper');
			this.slotOrder = [0, 1, 2, 3, 4]
				.map((i) => document.getElementById(`image-slot-${i}`))
				.filter((el): el is HTMLElement => el !== null);
			this.init();
		}

		private init(): void {
			this.attachDrag();
			this.startAutoplay();
		}

		private applySlots(animate = false): void {
				this.slotOrder.forEach((el, i) => {
						SLOT_CLASSES.forEach((c) => el.classList.remove(c));
						el.classList.add(SLOT_CLASSES[i]);
						
						el.style.transition = animate ? 'all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1)' : 'none';
						el.style.transform = ''; 

						const offset = SLOT_OFFSETS[i];
						const member = this.members[(this.currentIndex + offset + this.members.length) % this.members.length];
						const img = el.querySelector('img');
						if (img) {
								img.src = member.imagePath;
								img.alt = offset === 0 ? member.name : offset < 0 ? 'Previous team member' : 'Next team member';
						}
				});

				// Dispatch the event so TeamPreview can hear it
				const currentMember = this.members[this.currentIndex];
				document.dispatchEvent(new CustomEvent('slideshowChanged', { 
						detail: { member: currentMember }, 
						bubbles: true 
				}));
		}

		private dispatchDirection(dir: 'right' | 'left'): void {
			document.dispatchEvent(new CustomEvent('slideshowDirection', {
				detail: { direction: dir === 'right' ? -1 : 1 },
				bubbles: true
			}));
		}

		private next(userInitiated: boolean = false): void {
			this.currentIndex = (this.currentIndex + 1) % this.members.length;
			// Rotate the DOM elements array rather than moving elements
			const leaving = this.slotOrder.shift()!;
			this.slotOrder.push(leaving);
			if (userInitiated) {
				this.dispatchDirection('right');
			}
			this.applySlots(true);
		}

		private prev(userInitiated: boolean = false): void {
			this.currentIndex = (this.currentIndex - 1 + this.members.length) % this.members.length;
			const entering = this.slotOrder.pop()!;
			this.slotOrder.unshift(entering);
			if (userInitiated) {
				this.dispatchDirection('left');
			}
			this.applySlots(true);
		}

		private startAutoplay(): void {
			this.stopAutoplay();
			this.autoplayTimer = setInterval(() => { if (!this.isDragging) this.next(false); }, AUTOPLAY_DELAY);
		}

		private stopAutoplay(): void {
			if (this.autoplayTimer) {
				clearInterval(this.autoplayTimer);
				this.autoplayTimer = null;
			}
		}

		private attachDrag(): void {
			if (!this.wrapper) return;
			const onPointerDown = (e: PointerEvent) => {
				this.isDragging = true;
				this.pointerId = e.pointerId;
				this.dragStartX = e.clientX;
				this.dragDeltaX = 0;
				this.wrapper?.setPointerCapture(e.pointerId);
				this.stopAutoplay();
			};

			const onPointerMove = (e: PointerEvent) => {
				if (!this.isDragging || e.pointerId !== this.pointerId) return;
				this.dragDeltaX = e.clientX - this.dragStartX;
				const centerSlot = this.slotOrder[2]; // Index 2 is always is-center
				if (centerSlot) {
					centerSlot.style.transition = 'none';
					centerSlot.style.transform = `translateX(${this.dragDeltaX}px) translateY(-50%) scale(1)`;
				}
			};

			const endDrag = (e: PointerEvent) => {
				if (!this.isDragging || e.pointerId !== this.pointerId) return;
				this.isDragging = false;
				
				if (this.dragDeltaX <= -DRAG_THRESHOLD) {
					this.next(true);
				} else if (this.dragDeltaX >= DRAG_THRESHOLD) {
					this.prev(true);
				} else {
					const centerSlot = this.slotOrder[2];
					centerSlot.style.transition = 'transform 0.3s ease-out';
					centerSlot.style.transform = '';
				}
				this.dragDeltaX = 0;
				this.pointerId = null;
				this.startAutoplay();
			};

			this.wrapper.addEventListener('pointerdown', onPointerDown);
			this.wrapper.addEventListener('pointermove', onPointerMove);
			this.wrapper.addEventListener('pointerup', endDrag);
			this.wrapper.addEventListener('pointercancel', endDrag);
		}
	}

	const init = () => {
		const container = document.querySelector('.team-slideshow');
		if (container) {
			const membersData = container.getAttribute('data-team-members');
			const startIndexAttr = container.getAttribute('data-current-index');
			if (membersData) {
				const members: TeamMember[] = JSON.parse(membersData);
				const startIndex = startIndexAttr ? parseInt(startIndexAttr, 10) : 0;
				new TeamSlideshow(members, startIndex);
			}
		}
	};

	if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
	else init();
</script>

<style>
	.slideshow-wrapper { touch-action: none; }

	.image-slot {
		position: absolute;
		top: 50%;
		width: 33.333%;
		border-radius: 0.5rem;
		overflow: hidden;
		--tx: 0%;
		--scale: 1;
		transform: translate(var(--tx), -50%) scale(var(--scale));
		will-change: transform;
	}

	.image-slot img { 
		width: 100%; 
		height: 100%; 
		display: block;
		-webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
		mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
	}

	.image-slot.is-farleft { left: 0; --tx: -100%; --scale: 0.6; opacity: 0; filter: grayscale(1) blur(2px); z-index: 5; height: 14rem; }
	.image-slot.is-left { left: 0; --tx: 0%; --scale: 0.75; opacity: 0.5; filter: grayscale(1) blur(1px); z-index: 10; height: 14rem; }
	.image-slot.is-center { left: 50%; width: 66.666%; height: 16rem; --tx: -50%; --scale: 1; opacity: 1; filter: none; z-index: 20; }
	.image-slot.is-right { left: 100%; --tx: -100%; --scale: 0.75; opacity: 0.5; filter: grayscale(1) blur(1px); z-index: 10; height: 14rem; }
	.image-slot.is-farright { left: 100%; --tx: 0%; --scale: 0.6; opacity: 0; filter: grayscale(1) blur(2px); z-index: 5; height: 14rem; }

	@media (min-width: 768px) {
		.image-slot.is-farleft, .image-slot.is-left, .image-slot.is-right, .image-slot.is-farright { height: 18rem; }
		.image-slot.is-center { height: 20rem; }
	}
</style>