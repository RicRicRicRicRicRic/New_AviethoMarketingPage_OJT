---
// Team Slideshow Component
// Reusable slideshow for displaying team members with interactive navigation
// No autoplay - updates only on user input

interface TeamMember {
	name: string;
	jobTitle: string;
	description: string;
	imagePath: string;
}

const teamMembers: TeamMember[] = Astro.props.teamMembers;
const currentIndex: number = Astro.props.currentIndex ?? 0;
const teamData = JSON.stringify(teamMembers);

// Five fixed slots: far-left, left, center, right, far-right.
const slotPositions = ['is-farleft', 'is-left', 'is-center', 'is-right', 'is-farright'];
const slotOffsets = [-2, -1, 0, 1, 2];
---

<div class="team-slideshow w-full" data-team-members={teamData} data-current-index={currentIndex}>
	<!-- Slideshow Wrapper -->
	<div class="slideshow-wrapper relative w-full max-w-md h-[350px] md:h-[475px] overflow-hidden">
		{slotOffsets.map((offset, i) => {
			const member = teamMembers[(currentIndex + offset + teamMembers.length) % teamMembers.length];
			const isActive = offset === 0;
			const alt = isActive ? member.name : offset < 0 ? 'Previous team member' : 'Next team member';
			return (
				<div
					class={`image-slot ${slotPositions[i]}`}
					id={`image-slot-${i}`}
					data-offset={offset}
				>
					<img
						src={member.imagePath}
						alt={alt}
						class={`w-full h-full object-cover rounded-lg ${isActive ? 'shadow-2xl' : 'shadow-lg'}`}
					/>
				</div>
			);
		})}
	</div>

	<!-- Navigation Buttons -->
	<div class="flex gap-4 mt-6 z-30">
		<button
			id="prev-btn"
			class="px-6 py-3 bg-accent/20 hover:bg-accent/40 text-foreground rounded-lg backdrop-blur-sm border border-accent/30 transition-all duration-300 font-medium hover:translate-y-[-2px] hover:shadow-[0_4px_12px_rgba(0,0,0,0.3)] active:translate-y-0"
			aria-label="Previous team member"
		>
			← Previous
		</button>
		<button
			id="next-btn"
			class="px-6 py-3 bg-accent/20 hover:bg-accent/40 text-foreground rounded-lg backdrop-blur-sm border border-accent/30 transition-all duration-300 font-medium hover:translate-y-[-2px] hover:shadow-[0_4px_12px_rgba(0,0,0,0.3)] active:translate-y-0"
			aria-label="Next team member"
		>
			Next →
		</button>
	</div>
</div>

<script>
	interface TeamMember {
		name: string;
		jobTitle: string;
		description: string;
		imagePath: string;
	}

	const SLOT_CLASSES = ['is-farleft', 'is-left', 'is-center', 'is-right', 'is-farright'];
	const SLOT_OFFSETS = [-2, -1, 0, 1, 2];
	const SLIDE_DURATION = 500;

	class TeamSlideshow {
		private members: TeamMember[];
		private currentIndex: number;
		private prevBtn: HTMLElement | null;
		private nextBtn: HTMLElement | null;
		private slotOrder: HTMLElement[];
		private isAnimating: boolean;

		constructor(members: TeamMember[], startIndex: number) {
			this.members = members;
			this.currentIndex = startIndex;
			this.isAnimating = false;
			this.prevBtn = document.getElementById('prev-btn');
			this.nextBtn = document.getElementById('next-btn');

			this.slotOrder = [0, 1, 2, 3, 4]
				.map((i) => document.getElementById(`image-slot-${i}`))
				.filter((el): el is HTMLElement => el !== null);

			this.init();
		}

		private init(): void {
			this.attachNavigation();
		}

		private applySlots(): void {
			this.slotOrder.forEach((el, i) => {
				SLOT_CLASSES.forEach((c) => el.classList.remove(c));
				el.classList.add(SLOT_CLASSES[i]);

				const offset = SLOT_OFFSETS[i];
				const member = this.members[(this.currentIndex + offset + this.members.length) % this.members.length];
				const img = el.querySelector('img');
				if (img) {
					img.src = member.imagePath;
					img.alt = offset === 0 ? member.name : offset < 0 ? 'Previous team member' : 'Next team member';
				}
			});

			// Dispatch event for text updates
			const currentMember = this.members[this.currentIndex];
			const event = new CustomEvent('slideshowChanged', {
				detail: { member: currentMember },
				bubbles: true
			});
			document.dispatchEvent(event);
		}

		private next(): void {
			if (this.isAnimating) return;
			this.isAnimating = true;

			this.currentIndex = (this.currentIndex + 1) % this.members.length;

			const [leaving, ...rest] = this.slotOrder;
			this.slotOrder = [...rest, leaving];

			this.applySlots();

			setTimeout(() => {
				this.isAnimating = false;
			}, SLIDE_DURATION);
		}

		private prev(): void {
			if (this.isAnimating) return;
			this.isAnimating = true;

			this.currentIndex = (this.currentIndex - 1 + this.members.length) % this.members.length;

			const leaving = this.slotOrder[this.slotOrder.length - 1];
			const rest = this.slotOrder.slice(0, -1);
			this.slotOrder = [leaving, ...rest];

			this.applySlots();

			setTimeout(() => {
				this.isAnimating = false;
			}, SLIDE_DURATION);
		}

		private attachNavigation(): void {
			if (this.nextBtn) {
				this.nextBtn.addEventListener('click', () => this.next());
			}

			if (this.prevBtn) {
				this.prevBtn.addEventListener('click', () => this.prev());
			}

			// Keyboard navigation
			document.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'ArrowRight') {
					this.next();
				} else if (e.key === 'ArrowLeft') {
					this.prev();
				}
			});
		}
	}

	// Initialize
	const init = () => {
		const container = document.querySelector('.team-slideshow');
		if (container) {
			const membersData = container.getAttribute('data-team-members');
			const startIndexAttr = container.getAttribute('data-current-index');
			
			if (membersData) {
				const members: TeamMember[] = JSON.parse(membersData);
				const startIndex = startIndexAttr ? parseInt(startIndexAttr, 10) : 0;
				new TeamSlideshow(members, startIndex);
			}
		}
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>

<style>
	/*
	 * Tailwind-compatible custom styles for slideshow positioning
	 * These styles are necessary for the fixed-slot sliding carousel animation
	 */

	/* Base image slot positioning */
	.image-slot {
		position: absolute;
		top: 50%;
		width: 33.333%;
		border-radius: 0.5rem;
		overflow: hidden;
		--tx: 0%;
		--scale: 1;
		transform: translate(var(--tx), -50%) scale(var(--scale));
		transition: left 0.5s ease-in-out, width 0.5s ease-in-out, transform 0.5s ease-in-out,
			opacity 0.5s ease-in-out, filter 0.5s ease-in-out;
	}

	.image-slot img {
		width: 100%;
		height: 100%;
		display: block;
	}

	/* Off-screen left (fully clipped by overflow-hidden) */
	.image-slot.is-farleft {
		left: 0;
		--tx: -100%;
		--scale: 0.6;
		opacity: 0;
		filter: grayscale(1) blur(2px);
		z-index: 5;
		height: 14rem;
	}

	/* Visible left slot */
	.image-slot.is-left {
		left: 0;
		--tx: 0%;
		--scale: 0.75;
		opacity: 0.5;
		filter: grayscale(1) blur(1px);
		z-index: 10;
		height: 14rem;
	}

	/* Visible center slot */
	.image-slot.is-center {
		left: 50%;
		width: 66.666%;
		height: 16rem;
		--tx: -50%;
		--scale: 1;
		opacity: 1;
		filter: none;
		z-index: 20;
	}

	/* Visible right slot */
	.image-slot.is-right {
		left: 100%;
		--tx: -100%;
		--scale: 0.75;
		opacity: 0.5;
		filter: grayscale(1) blur(1px);
		z-index: 10;
		height: 14rem;
	}

	/* Off-screen right (fully clipped by overflow-hidden) */
	.image-slot.is-farright {
		left: 100%;
		--tx: 0%;
		--scale: 0.6;
		opacity: 0;
		filter: grayscale(1) blur(2px);
		z-index: 5;
		height: 14rem;
	}

	/* Responsive heights for medium screens and up */
	@media (min-width: 768px) {
		.image-slot.is-farleft,
		.image-slot.is-left,
		.image-slot.is-right,
		.image-slot.is-farright {
			height: 18rem;
		}
		.image-slot.is-center {
			height: 20rem;
		}
	}
</style>