---
// Navbar.astro — sticky, glass-blurred navigation
// Refactored to use Tailwind utility classes and design system tokens
import { Image } from "astro:assets";
import logo from "../../assets/logo/Avietho_logo_nav.png";

interface NavLink {
	href: string;
	label: string;
}

const navLinks: NavLink[] = [
	{ href: "/", label: "Home" },
	{ href: "/services", label: "Our Services" },
	{ href: "/projects", label: "Our Projects" },
	{ href: "/streams", label: "Livestreams" },
	{ href: "/production", label: "Production" },
	{ href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;

// "/" only matches the homepage exactly; other links also match their
// own sub-paths (e.g. "/services" matches "/services/seo" too).
const isActiveLink = (href: string): boolean => {
	if (href === "/") return currentPath === "/";
	return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<nav
	id="site-nav"
	class="sticky top-0 z-50 w-full font-body text-foreground animate-nav-enter"
>
	<div
		id="nav-container"
		class="bg-background-overlay/80 backdrop-blur-md border-b border-muted transition-all duration-300"
	>
		<div
			id="nav-inner"
			class="max-w-7xl mx-auto px-6 flex items-center justify-between py-2.5 transition-all duration-300"
		>
			<!-- Logo -->
			<a href="/" class="block font-heading" aria-label="Home">
				<Image
					src={logo}
					alt="Avietho Logo"
					class="h-10 w-auto transition-opacity duration-200 hover:opacity-82"
				/>
			</a>

			<!-- Desktop Navigation -->
			<div class="hidden md:flex items-center gap-x-2">
				{navLinks.map((link) => {
					const active = isActiveLink(link.href);
					return (
						<a
							href={link.href}
							class={`group relative inline-block px-3.5 py-1 text-sm font-medium transition-colors duration-200 ${
								active ? "text-accent" : "text-[var(--color-foreground)] hover:text-[var(--color-accent-hover)]"
							}`}
							aria-current={active ? "page" : undefined}
						>
							<span class="relative">
								{link.label}
								<span
									class={`absolute left-3.5 right-3.5 -bottom-1 h-px bg-accent origin-left transition-transform duration-300 ease-out ${
										active ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100"
									}`}
								></span>
							</span>
						</a>
					);
				})}
			</div>

			<!-- Desktop CTA -->
			<div class="hidden md:block">
				<a
					href="/"
					class="inline-flex items-center px-[18px] py-[7px] rounded-full bg-accent text-background text-sm font-semibold transition-all duration-200 hover:brightness-110 hover:-translate-y-px"
				>
					Get Started
				</a>
			</div>

			<!-- Mobile menu button -->
			<button
				id="menu-toggle"
				type="button"
				class="relative w-8 h-6 bg-transparent border-none cursor-pointer p-0 md:hidden"
				aria-label="Open menu"
				aria-expanded="false"
			>
				<span
					id="menu-bar-1"
					class="menu-bar absolute left-0 right-0 h-0.5 bg-foreground rounded transition-all duration-300"
					style="top: 0;"
				></span>
				<span
					id="menu-bar-2"
					class="menu-bar absolute left-0 right-0 h-0.5 bg-foreground rounded transition-all duration-300"
					style="top: 11px;"
				></span>
				<span
					id="menu-bar-3"
					class="menu-bar absolute left-0 right-0 h-0.5 bg-foreground rounded transition-all duration-300"
					style="top: 22px;"
				></span>
			</button>
		</div>
	</div>

	<!-- Mobile panel -->
	<div
		id="mobile-panel"
		class="max-h-0 overflow-hidden bg-background-overlay/80 backdrop-blur-md border-t border-muted transition-all duration-400 ease-out"
	>
		<div class="flex flex-col items-center px-6 py-2 pb-5">
			{navLinks.map((link, i) => {
				const active = isActiveLink(link.href);
				return (
					<a
						href={link.href}
						class={`mobile-nav-link w-full py-3 text-center text-base font-medium no-underline border-b border-muted transition-colors duration-200 ${
							active ? "text-accent" : "text-[var(--color-foreground)] hover:text-[var(--color-accent-hover)]"
						}`}
						style={`--i: ${i};`}
						aria-current={active ? "page" : undefined}
					>
						{link.label}
					</a>
				);
			})}
			<a
				href="/"
				class="mobile-nav-link w-full py-3 text-center text-base font-semibold text-accent no-underline border-b-0"
				style="--i: {navLinks.length};"
			>
				Get Started
			</a>
		</div>
	</div>
</nav>

<style>
	.mobile-nav-link {
		opacity: 0;
		transform: translateY(6px);
		transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
	}
	.mobile-nav-link.animate-link-in {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	// Scroll state: navbar condenses and glass opacifies on scroll
	const nav = document.getElementById("site-nav") as HTMLElement;
	const navContainer = document.getElementById("nav-container") as HTMLElement;
	const navInner = document.getElementById("nav-inner") as HTMLElement;
	const toggle = document.getElementById("menu-toggle") as HTMLButtonElement;
	const panel = document.getElementById("mobile-panel") as HTMLDivElement;
	const menuBar1 = document.getElementById("menu-bar-1") as HTMLElement;
	const menuBar2 = document.getElementById("menu-bar-2") as HTMLElement;
	const menuBar3 = document.getElementById("menu-bar-3") as HTMLElement;
	const SCROLL_THRESHOLD = 24;

	function onScroll(): void {
		const isScrolled = window.scrollY > SCROLL_THRESHOLD;
		
		// Apply Tailwind classes conditionally based on scroll state
		if (isScrolled) {
			navContainer.classList.remove("bg-background-overlay/80");
			navContainer.classList.add("bg-background-overlay/90", "shadow-lg");
			navInner.classList.remove("py-2.5");
			navInner.classList.add("py-2");
		} else {
			navContainer.classList.remove("bg-background-overlay/90", "shadow-lg");
			navContainer.classList.add("bg-background-overlay/80");
			navInner.classList.remove("py-2");
			navInner.classList.add("py-2.5");
		}
	}

	window.addEventListener("scroll", onScroll, { passive: true });
	onScroll();

	let open = false;
	function setMenu(next: boolean): void {
		open = next;
		toggle.setAttribute("aria-expanded", String(open));
		
		// Toggle menu bar animations directly
		if (open) {
			menuBar1.style.top = "11px";
			menuBar1.classList.add("rotate-45");
			menuBar2.classList.add("opacity-0");
			menuBar3.style.top = "11px";
			menuBar3.classList.add("-rotate-45");
		} else {
			menuBar1.style.top = "0";
			menuBar1.classList.remove("rotate-45");
			menuBar2.classList.remove("opacity-0");
			menuBar3.style.top = "22px";
			menuBar3.classList.remove("-rotate-45");
		}
		
		// Toggle mobile panel
		if (open) {
			panel.style.maxHeight = "420px";
			panel.querySelectorAll("a").forEach((a, i) => {
				a.classList.add("animate-link-in");
				a.style.animationDelay = `${i * 0.05}s`;
			});
		} else {
			panel.style.maxHeight = "0px";
			panel.querySelectorAll("a").forEach((a) => {
				a.classList.remove("animate-link-in");
				a.style.animationDelay = "";
			});
		}
		
		document.body.style.overflow = open ? "hidden" : "";
	}

	toggle.addEventListener("click", () => setMenu(!open));

	panel.querySelectorAll("a").forEach((a) =>
		a.addEventListener("click", () => setMenu(false))
	);

	window.addEventListener("resize", () => {
		if (window.innerWidth >= 768 && open) setMenu(false);
	});
</script>