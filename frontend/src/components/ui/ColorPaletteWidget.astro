---
// Color Palette Widget - Floating draggable component showing theme colors
interface Props {}

import colorPaletteIcon from '../../assets/icons/colorPalette_icon.png';

const {} = Astro.props;
---

<div 
  id="color-palette-widget"
  class="fixed z-[100] select-none"
  style="top: 80px; left: 24px;"
>
  <!-- Expanded Panel -->
  <div 
    id="color-palette-panel"
    class="hidden absolute top-full mt-3 left-0 p-3 rounded-lg bg-background-elevated border border-accent/20 shadow-2xl backdrop-blur-md"
    style="width: 240px;"
  >
    <!-- Theme List -->
    <div class="space-y-2 text-sm">
      <button class="w-full text-left px-3 py-2 rounded bg-accent/10 text-foreground hover:bg-accent/20 transition-colors">
        Default
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Blush Noir
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Deep Forest
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Sunset Ember
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Lavender Slate
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Cyber Neon
      </button>
      <button class="w-full text-left px-3 py-2 rounded text-foreground/80 hover:bg-accent/10 transition-colors">
        Crimson Eclipse
      </button>
    </div>
  </div>

  <!-- Draggable Button -->
  <div
    id="color-palette-button"
    class="h-16 w-16 rounded-full overflow-hidden shadow-2xl cursor-grab active:cursor-grabbing bg-background-elevated border-2 border-accent/20 hover:border-accent/40 transition-all duration-200 hover:scale-110"
  >
    <img 
      src={colorPaletteIcon.src} 
      alt="Color Palette" 
      class="h-full w-full object-cover p-2"
    />
  </div>
</div>

<script>
  (function() {
    // Get DOM elements
    const widgetEl = document.getElementById('color-palette-widget');
    const buttonEl = document.getElementById('color-palette-button');
    const panelEl = document.getElementById('color-palette-panel');
    
    // Type-safe element references
    const widget: HTMLElement = widgetEl!;
    const button: HTMLElement = buttonEl!;
    const panel: HTMLElement = panelEl!;

    // State
    let isExpanded = false;
    let isDragging = false;
    let hasMoved = false;
    let startX = 0;
    let startY = 0;
    let initialLeft = 24;
    let initialTop = 80;
    let currentLeft = 24;
    let currentTop = 80;
    let currentTheme = 'Default';

    // Theme definitions
    const themes = {
      'Default': {
        '--color-background': '#0A0A0A',
        '--color-background-elevated': '#0F0F0F',
        '--color-background-overlay': '#0D0D0D',
        '--color-background-card': '#1A1A1A',
        '--color-foreground': '#F5F5F5',
        '--color-accent': '#C9A44C',
        '--color-accent-hover': '#ffb301',
        '--color-muted': 'rgba(255, 255, 255, 0.1)',
        '--color-muted-hover': 'rgba(255, 255, 255, 0.45)'
      },
      'Blush Noir': {
        '--color-background': '#0F0E0E',
        '--color-background-elevated': '#171515',
        '--color-background-overlay': '#121111',
        '--color-background-card': '#211E1E',
        '--color-foreground': '#F2EFEF',
        '--color-accent': '#E1A7A7',
        '--color-accent-hover': '#F2C4C4',
        '--color-muted': 'rgba(225, 167, 167, 0.08)',
        '--color-muted-hover': 'rgba(225, 167, 167, 0.25)'
      },
      'Deep Forest': {
        '--color-background': '#080D08',
        '--color-background-elevated': '#0D140D',
        '--color-background-overlay': '#0A120A',
        '--color-background-card': '#162116',
        '--color-foreground': '#E8F0E8',
        '--color-accent': '#4CAF50',
        '--color-accent-hover': '#66BB6A',
        '--color-muted': 'rgba(76, 175, 80, 0.15)',
        '--color-muted-hover': 'rgba(76, 175, 80, 0.45)'
      },
      'Sunset Ember': {
        '--color-background': '#0D0C0B',
        '--color-background-elevated': '#141211',
        '--color-background-overlay': '#110F0E',
        '--color-background-card': '#1C1917',
        '--color-foreground': '#E7E5E4',
        '--color-accent': '#D97706',
        '--color-accent-hover': '#F59E0B',
        '--color-muted': 'rgba(217, 119, 6, 0.1)',
        '--color-muted-hover': 'rgba(217, 119, 6, 0.3)'
      },
      'Lavender Slate': {
        '--color-background': '#0F0F14',
        '--color-background-elevated': '#16161D',
        '--color-background-overlay': '#121218',
        '--color-background-card': '#1F1F28',
        '--color-foreground': '#E0E0E6',
        '--color-accent': '#8B5CF6',
        '--color-accent-hover': '#A78BFA',
        '--color-muted': 'rgba(139, 92, 246, 0.1)',
        '--color-muted-hover': 'rgba(139, 92, 246, 0.3)'
      },
      'Cyber Neon': {
        '--color-background': '#090D0F',
        '--color-background-elevated': '#0E1518',
        '--color-background-overlay': '#0B1113',
        '--color-background-card': '#152024',
        '--color-foreground': '#ECFEFF',
        '--color-accent': '#06B6D4',
        '--color-accent-hover': '#22D3EE',
        '--color-muted': 'rgba(6, 182, 212, 0.12)',
        '--color-muted-hover': 'rgba(6, 182, 212, 0.35)'
      },
      'Crimson Eclipse': {
        '--color-background': '#0D0A0A',
        '--color-background-elevated': '#141010',
        '--color-background-overlay': '#110D0D',
        '--color-background-card': '#1C1515',
        '--color-foreground': '#F9F6F6',
        '--color-accent': '#E11D48',
        '--color-accent-hover': '#F43F5E',
        '--color-muted': 'rgba(225, 29, 72, 0.12)',
        '--color-muted-hover': 'rgba(225, 29, 72, 0.35)'
      }
    };

    // Load saved position
    const savedX = localStorage.getItem('colorPaletteX');
    const savedY = localStorage.getItem('colorPaletteY');
    const savedTheme = localStorage.getItem('colorPaletteTheme');
    
    if (savedX && savedY) {
      currentLeft = parseFloat(savedX);
      currentTop = parseFloat(savedY);
      
      // Validate saved position is within viewport
      const widgetSize = 64;
      const padding = 8;
      const isInViewport = currentLeft >= 0 && currentTop >= 0 &&
                          currentLeft <= window.innerWidth - widgetSize &&
                          currentTop <= window.innerHeight - widgetSize;
      
      if (!isInViewport) {
        // Reset to top-left if outside viewport
        currentLeft = padding;
        currentTop = padding;
      }
      
      widget.style.left = currentLeft + 'px';
      widget.style.top = currentTop + 'px';
    }

    // Load saved theme
    if (savedTheme && themes[savedTheme as keyof typeof themes]) {
      currentTheme = savedTheme;
      applyTheme(savedTheme);
      updateThemeHighlight();
    }

    // Apply theme to CSS variables and body class
    function applyTheme(themeName: string) {
      const theme = themes[themeName as keyof typeof themes];
      if (!theme) return;

      const root = document.documentElement;
      const body = document.body;
      
      // Remove all theme classes from body
      Object.keys(themes).forEach(key => {
        const className = 'theme-' + key.toLowerCase().replace(/\s+/g, '-');
        body.classList.remove(className);
      });
      
      // Add current theme class to body
      const themeClass = 'theme-' + themeName.toLowerCase().replace(/\s+/g, '-');
      body.classList.add(themeClass);
      
      // Apply CSS variables
      Object.entries(theme).forEach(([property, value]) => {
        root.style.setProperty(property, value);
      });
    }

    // Update theme button highlighting
    function updateThemeHighlight() {
      const buttons = panel.querySelectorAll('button');
      buttons.forEach(button => {
        const themeName = button.textContent?.trim();
        if (themeName === currentTheme) {
          button.classList.remove('text-foreground/80', 'hover:bg-accent/10');
          button.classList.add('bg-accent/10', 'text-foreground');
        } else {
          button.classList.remove('bg-accent/10', 'text-foreground');
          button.classList.add('text-foreground/80', 'hover:bg-accent/10');
        }
      });
    }

    // Toggle panel with dynamic positioning
    function togglePanel() {
      if (!hasMoved) {
        isExpanded = !isExpanded;
        if (isExpanded) {
          // Calculate available space
          const widgetRect = button.getBoundingClientRect();
          const widgetSize = 64;
          const panelHeight = 200; // Approximate panel height
          const panelWidth = 240;
          const margin = 12;
          
          const spaceBelow = window.innerHeight - widgetRect.bottom - margin;
          const spaceAbove = widgetRect.top - margin;
          const spaceRight = window.innerWidth - widgetRect.right - margin;
          const spaceLeft = widgetRect.left - margin;
          
          // Reset classes
          panel.classList.remove('top-full', 'bottom-full', 'left-0', 'right-0', 'mt-3', 'mb-3');
          
          // Vertical positioning - default is below (top-full)
          if (spaceBelow < panelHeight && spaceAbove > spaceBelow) {
            // Not enough space below, position above
            panel.classList.add('bottom-full', 'mb-3');
          } else {
            // Default: position below
            panel.classList.add('top-full', 'mt-3');
          }
          
          // Horizontal positioning - default is left (left-0)
          if (spaceRight < panelWidth && spaceLeft > spaceRight) {
            // Not enough space to the right, position to the left
            panel.classList.add('right-0');
          } else {
            // Default: position to the left
            panel.classList.add('left-0');
          }
          
          updateThemeHighlight();
          panel.classList.remove('hidden');
        } else {
          panel.classList.add('hidden');
        }
      }
      hasMoved = false;
    }

    button.addEventListener('click', togglePanel);

    // Add click handlers to theme buttons
    const themeButtons = panel.querySelectorAll('button');
    themeButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const themeName = btn.textContent?.trim();
        if (themeName && themes[themeName as keyof typeof themes]) {
          currentTheme = themeName;
          applyTheme(themeName);
          updateThemeHighlight();
          localStorage.setItem('colorPaletteTheme', themeName);
          
          // Close panel after selection
          setTimeout(() => {
            isExpanded = false;
            panel.classList.add('hidden');
          }, 150);
        }
      });
    });

    // Start drag
    function startDrag(e: Event) {
      e.preventDefault();
      
      isDragging = true;
      hasMoved = false;
      
      const clientX = (e as TouchEvent).type === 'touchstart' ? (e as TouchEvent).touches[0].clientX : (e as MouseEvent).clientX;
      const clientY = (e as TouchEvent).type === 'touchstart' ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
      
      startX = clientX;
      startY = clientY;
      initialLeft = currentLeft;
      initialTop = currentTop;

      document.addEventListener('mousemove', onDrag);
      document.addEventListener('mouseup', endDrag);
      document.addEventListener('touchmove', onDrag, { passive: false });
      document.addEventListener('touchend', endDrag);
    }

    // Update panel position dynamically
    function updatePanelPosition() {
      const widgetRect = button.getBoundingClientRect();
      const panelHeight = panel.offsetHeight || 360;; // Approximate panel height
      const panelWidth = 150;
      const margin = 12;
      
      const spaceBelow = window.innerHeight - widgetRect.bottom - margin;
      const spaceAbove = widgetRect.top - margin;
      const spaceRight = window.innerWidth - widgetRect.right - margin;
      const spaceLeft = widgetRect.left - margin;
      
      // Reset classes
      panel.classList.remove('top-full', 'bottom-full', 'left-0', 'right-0', 'mt-3', 'mb-3');
      
      // Vertical positioning - default is below (top-full)
      if (spaceBelow < panelHeight && spaceAbove > spaceBelow) {
        // Not enough space below, position above
        panel.classList.add('bottom-full', 'mb-3');
      } else {
        // Default: position below
        panel.classList.add('top-full', 'mt-3');
      }
      
      // Horizontal positioning - default is left (left-0)
      if (spaceRight < panelWidth && spaceLeft > spaceRight) {
        // Not enough space to the right, position to the left
        panel.classList.add('right-0');
      } else {
        // Default: position to the left
        panel.classList.add('left-0');
      }
    }

    // On drag
    function onDrag(e: Event) {
      e.preventDefault();
      
      const clientX = (e as MouseEvent).type === 'mousemove' ? (e as MouseEvent).clientX : (e as TouchEvent).touches[0].clientX;
      const clientY = (e as MouseEvent).type === 'mousemove' ? (e as MouseEvent).clientY : (e as TouchEvent).touches[0].clientY;

      const deltaX = clientX - startX;
      const deltaY = clientY - startY;

      // Mark as moved if dragged more than 3px
      if (Math.abs(deltaX) > 3 || Math.abs(deltaY) > 3) {
        hasMoved = true;
      }

      // Update position with viewport constraints
      const widgetSize = 64; // 64px (h-16 w-16)
      const padding = 8; // Minimum padding from edges
      
      currentLeft = initialLeft + deltaX;
      currentTop = initialTop + deltaY;
      
      // Constrain to viewport
      currentLeft = Math.max(padding, Math.min(currentLeft, window.innerWidth - widgetSize - padding));
      currentTop = Math.max(padding, Math.min(currentTop, window.innerHeight - widgetSize - padding));
      
      // Reset to top-left if somehow outside viewport
      if (currentLeft < 0 || currentTop < 0 || 
          currentLeft > window.innerWidth - widgetSize || 
          currentTop > window.innerHeight - widgetSize) {
        currentLeft = padding;
        currentTop = padding;
      }
      
      widget.style.left = currentLeft + 'px';
      widget.style.top = currentTop + 'px';
      
      // Update panel position if expanded
      if (isExpanded) {
        updatePanelPosition();
      }
    }

    // End drag
    function endDrag() {
      // Save position to localStorage
      localStorage.setItem('colorPaletteX', currentLeft.toString());
      localStorage.setItem('colorPaletteY', currentTop.toString());

      isDragging = false;

      document.removeEventListener('mousemove', onDrag);
      document.removeEventListener('mouseup', endDrag);
      document.removeEventListener('touchmove', onDrag);
      document.removeEventListener('touchend', endDrag);
    }

    // Add drag listeners
    button.addEventListener('mousedown', startDrag);
    button.addEventListener('touchstart', startDrag, { passive: false });

    // Keep widget in viewport on window resize
    function keepInViewport() {
      const widgetSize = 64;
      const padding = 8;
      
      currentLeft = Math.max(padding, Math.min(currentLeft, window.innerWidth - widgetSize - padding));
      currentTop = Math.max(padding, Math.min(currentTop, window.innerHeight - widgetSize - padding));
      
      widget.style.left = currentLeft + 'px';
      widget.style.top = currentTop + 'px';
    }

    window.addEventListener('resize', keepInViewport);
    window.addEventListener('orientationchange', () => {
      setTimeout(keepInViewport, 100);
    });

    // Close panel when clicking away
    document.addEventListener('click', (e) => {
      if (isExpanded && !widget.contains(e.target as Node)) {
        isExpanded = false;
        panel.classList.add('hidden');
      }
    });
  })();
</script>

<style>
  /* Prevent text selection while dragging */
  #color-palette-widget {
    touch-action: none;
  }
</style>