---
// Footer.astro — site footer with contact information
// Uses design system tokens and Tailwind utilities
import logo from '../../assets/logo/Avietho_logo.png';
import mapImg from '../../assets/imgs/avietho_map.png';
import landmarkImg from '../../assets/imgs/landmark.png';
import phoneIcon from '../../assets/icons/telephone_icon.png';
import emailIcon from '../../assets/icons/email_icon.png';
import facebookIcon from '../../assets/icons/facebook_icon.png';
---


<footer class="w-fullbg-background-elevated border-t border-muted">
	<div class="max-w-7xl mx-auto px-4 py-12 lg:py-16">
		<!-- Main content grid -->
		<div class="flex flex-col lg:flex-row gap-6">
			<!-- Left Column: Services Accordion -->
			<div class="w-full lg:w-6/10 ">
				<img src={logo.src} alt="Avietho Logo" class="h-10 w-auto mb-4" />
				<p class="text-text-subtle text-base mb-8 ">
					Professional digital marketing solutions for businesses of all sizes. From website development to social media management, we help you grow your online presence.
				</p>
				<h3 class="font-heading text-accent text-xl font-semibold mb-4">
					OUR SERVICES
				</h3>

				<!-- Services Grid -->
				<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
					<!-- Digital PR -->
					<div class="flex flex-col w-full">
						<h4 class="font-semibold text-accent text-sm mb-2">Digital PR</h4>
						<ul class="flex flex-col space-y-1 text-text-subtle text-sm">
							<li class="pl-2 -indent-2">• Online Media Relations</li>
							<li class="pl-2 -indent-2">• Influencer Marketing</li>
							<li class="pl-2 -indent-2">• Online Reputation Management</li>
							<li class="pl-2 -indent-2">• Digital Content Creation</li>
							<li class="pl-2 -indent-2">• Social Media PR</li>
						</ul>
					</div>

					<!-- Social Media -->
					<div class="flex flex-col w-full">
						<h4 class="font-semibold text-accent text-sm mb-2">Social Media</h4>
						<ul class="flex flex-col space-y-1 text-text-subtle text-sm">
							<li class="pl-2 -indent-2">• Social Media Strategy</li>
							<li class="pl-2 -indent-2">• Content Creation</li>
							<li class="pl-2 -indent-2">• Community Management</li>
							<li class="pl-2 -indent-2">• Analytics & Reporting</li>
							<li class="pl-2 -indent-2">• Brand Management</li>
						</ul>
					</div>

					<!-- Video Production -->
					<div class="flex flex-col w-full">
						<h4 class="font-semibold text-accent text-sm mb-2">Video Production</h4>
						<ul class="flex flex-col space-y-1 text-text-subtle text-sm">
							<li class="pl-2 -indent-2">• Corporate Videos</li>
							<li class="pl-2 -indent-2">• Event Videography</li>
							<li class="pl-2 -indent-2">• Live Streaming</li>
							<li class="pl-2 -indent-2">• Commercial Production</li>
							<li class="pl-2 -indent-2">• Post-Production</li>
						</ul>
					</div>

					<!-- Web Development -->
					<div class="flex flex-col w-full">
						<h4 class="font-semibold text-accent text-sm mb-2">Web Development</h4>
						<ul class="flex flex-col space-y-1 text-text-subtle text-sm">
							<li class="pl-2 -indent-2">• Website Design</li>
							<li class="pl-2 -indent-2">• Frontend Development</li>
							<li class="pl-2 -indent-2">• Backend Development</li>
							<li class="pl-2 -indent-2">• E-commerce Solutions</li>
							<li class="pl-2 -indent-2">• SEO & Analytics</li>
						</ul>
					</div>
				</div>
			</div>

			<!-- Right Column: Contact Information -->
			<div class="w-full lg:w-4/10">
			<h3 class="font-heading text-accent text-xl font-semibold mb-6 ">
				CONTACT US
			</h3>
				<div class="flex flex-col gap-4">
				<!-- Phone -->
				<a
					href="tel:+6397831987"
					class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
				>
					<img src={phoneIcon.src} alt="Phone" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
					<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
						+639 783 1987
					</span>
				</a>

				<!-- Email -->
				<a
					href="mailto:marketing.avietho@gmail.com"
					class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
				>
					<img src={emailIcon.src} alt="Email" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
					<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
						marketing.avietho@gmail.com
					</span>
				</a>

				<!-- Social Media -->
				<a
					href="https://www.facebook.com/avietho"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
				>
					<img src={facebookIcon.src} alt="Facebook" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
					<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
						Facebook
					</span>
				</a>
				</div>
				
				<div class="mt-8 flex justify-end relative group">
					<img src={mapImg.src} alt="Avietho Location Map" class="w-90 h-90 rounded-full object-cover shadow-lg border-2 border-muted" />
					<a 
						href="https://maps.app.goo.gl/KyDMwmYMADs5c5LC7" 
						target="_blank" 
						rel="noopener noreferrer"
						class="absolute bottom-4 right-35 top-29 w-20 h-20 z-10"
					>
					<img 
						src={landmarkImg.src} 
						alt="Avietho Landmark" 
						class="w-full h-full object-contain drop-shadow-xl transition-all duration-500 animate-bob hover:scale-110 icon-hover cursor-pointer" 
					/>
					</a>
				</div>
			</div>
		</div>




		<style>
			@keyframes bob {
				0%, 100% { transform: translateY(0); }
				50% { transform: translateY(-12px); }
			}
			.animate-bob {
				animation: bob 5s ease-in-out infinite;
			}
		</style>

		<!-- Bottom Section: Copyright -->
		<div class="mt-12 pt-8 border-t border-muted">
			<p class="text-center text-text-muted text-sm">
				© 2025 Avietho Digital Marketing. All rights reserved.
			</p>
		</div>
	</div>
</footer>