---
// Footer.astro — site footer with contact information
// Uses design system tokens and Tailwind utilities
import logo from '../../assets/logo/Avietho_logo.png';
import mapImg from '../../assets/imgs/avietho_map.png';
import landmarkImg from '../../assets/imgs/landmark.png';
import cellPhoneIcon from '../../assets/icons/cellphoneContanct_icon.png';
import telephoneIcon from '../../assets/icons/telephone_icon.png';
import emailIcon from '../../assets/icons/email_icon.png';
import facebookIcon from '../../assets/icons/facebook_icon.png';
---


<footer class="w-full bg-background-elevated border-t border-muted">
	<div class="max-w-7xl mx-auto -px-4 py-40 lg:py-16">
	<!-- Top Section: Logo/Description + Services -->
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16 ">
		<!-- Left Column: Logo and Description -->
		<div class="w-full lg:col-span-1 flex flex-col items-center text-center lg:items-start lg:text-left">
			<img src={logo.src} alt="Avietho Logo" class="h-19 w-auto mb-4" />
			<p class="text-text-subtle text-base mb-8 w-80 font-body">
				Professional digital marketing solutions for businesses of all sizes. From website development to social media management, we help you grow your online presence.
			</p>
		</div>

		<!-- Right Column: Services -->
		<div class="w-full lg:col-span-2">
		<!-- Services Grid -->
		<div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-2">
			<!-- Digital PR -->
			<div class="flex flex-col w-full items-center text-center sm:items-start sm:text-left">
					<h4 class="font-heading font-semibold text-accent text-lg mb-2">Digital PR</h4>
					<ul class="flex flex-col space-y-1 text-text-subtle text-base gap-2 w-32 text-sm font-body">
						<li > Online Media Relations</li>
						<li > Influencer Marketing</li>
						<li > Online Reputation Management</li>
						<li > Digital Content Creation</li>
						<li > Social Media PR</li>
					</ul>
				</div>

			<!-- Social Media -->
			<div class="flex flex-col w-full items-center text-center sm:items-start sm:text-left">
					<h4 class="font-heading font-semibold text-accent text-lg mb-2">Social Media</h4>
					<ul class="flex flex-col space-y-1 text-text-subtle text-base gap-2 w-32 text-sm font-body">
						<li > Social Media Strategy</li>
						<li > Content Creation</li>
						<li > Community Management</li>
						<li > Analytics & Reporting</li>
						<li > Brand Management</li>
					</ul>
				</div>

			<!-- Video Production -->
			<div class="flex flex-col w-full items-center text-center sm:items-start sm:text-left">
					<h4 class="font-semibold text-accent text-lg mb-2">Video Production</h4>
					<ul class="flex flex-col space-y-1 text-text-subtle text-base gap-2 w-32 text-sm">
						<li > Corporate Videos</li>
						<li > Event Videography</li>
						<li > Live Streaming</li>
						<li > Commercial Production</li>
						<li > Post-Production</li>
					</ul>
				</div>

			<!-- Web Development -->
			<div class="flex flex-col w-full items-center text-center sm:items-start sm:text-left">
					<h4 class="font-semibold text-accent text-lg mb-2">Web Development</h4>
					<ul class="flex flex-col space-y-1 text-text-subtle text-base gap-2 w-32 text-sm">
						<li > Website Design</li>
						<li > Frontend Development</li>
						<li > Backend Development</li>
						<li > E-commerce Solutions</li>
						<li > SEO & Analytics</li>
					</ul>
				</div>
			</div>
		</div>
	</div>

	<!-- Horizontal Divider -->
	<hr class="border-t border-muted my-16" />

	<!-- Bottom Section: Contact, Address, Testimonials, Newsletter, and Map -->
	<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8">
		<!-- Left Section: Contact, Address, Testimonials, and Newsletter -->
		<div class="flex flex-col gap-8">
		<!-- Top Row: Contact, Address, and Testimonials -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 items-center lg:items-start">
			<!-- Column 1: Contact Information -->
			<div class="flex flex-col items-center text-center lg:text-left">
					<div class="w-fit">
						<h3 class="font-heading text-accent text-lg font-semibold mb-6">
							CONTACT US
						</h3>
						<div class="flex flex-col gap-4">
							<!-- Landline -->
							<a
								href="tel:+63270001366"
								class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
							>
								<img src={telephoneIcon.src} alt="Phone" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
								<span class="text-sm group-hover:translate-x-1 transition-transform duration-200">
									+63 2 7000 1366
								</span>
							</a>
							<!-- Phone -->
							<a
								href="tel:+6397831987"
								class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
							>
								<img src={cellPhoneIcon.src} alt="Phone" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
								<span class="text-sm group-hover:translate-x-1 transition-transform duration-200">
									+639 783 1987
								</span>
							</a>

							<!-- Email -->
							<a
								href="mailto:marketing.avietho@gmail.com"
								class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
							>
								<img src={emailIcon.src} alt="Email" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
								<span class="text-sm group-hover:translate-x-1 transition-transform duration-200">
									marketing.avietho@gmail.com
								</span>
							</a>

							<!-- Social Media -->
							<a
								href="https://www.facebook.com/aviethodigital"
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
							>
								<img src={facebookIcon.src} alt="Facebook" class="w-5 h-5 icon-idle transition-transform duration-300 group-hover:scale-110 group-hover:icon-hover" />
								<span class="text-sm group-hover:translate-x-1 transition-transform duration-200">
									https:/facebook.com/aviethodigital
								</span>
							</a>
						</div>
					</div>
				</div>
				<!-- Column 2: Address -->
				<!-- The outer div centers this entire block on the screen -->
				<div class="flex flex-col items-center text-center lg:text-left">
					<div class="w-fit">
						<h3 class="font-heading text-accent text-lg font-semibold mb-4">
							The Office
						</h3>
						<ul class="text-text-subtle text-sm space-y-3">
							<li>Admiralty Bldg. 1101</li>
							<li>Alabang-Zapote Rd.</li>
							<li>Madrigal Business Park</li>
							<li>Brgy. Ayala Alabang</li>
							<li>Muntinlupa City, Philippines</li>
						</ul>
					</div>
				</div>
				<!-- Column 3: Case Studies -->
				<div class="flex flex-col items-center text-center lg:text-left">
					<div class="w-fit">
						<h3 class="font-heading text-accent text-lg font-semibold mb-4">
							Case Studies
						</h3>
				<ul class="text-text-subtle text-sm space-y-3">
					<!-- Placeholder content, replace as needed -->
					<li><a href='https://tanauancity.gov.ph/' target='_blank' rel='noopener noreferrer' class='block transition-all duration-200 hover:text-accent group'><span class='group-hover:translate-x-1 transition-transform duration-200 inline-block'>tanauancity.gov.ph</span></a></li>
					<li><a href='https://gad.tanauancity.gov.ph/' target='_blank' rel='noopener noreferrer' class='block transition-all duration-200 hover:text-accent group'><span class='group-hover:translate-x-1 transition-transform duration-200 inline-block'>gad.tanauancity.gov.ph</span></a></li>
					<li><a href='https://www.youtube.com/watch?v=AhegrxF80J4&t=8669s' target='_blank' rel='noopener noreferrer' class='block transition-all duration-200 hover:text-accent group'><span class='group-hover:translate-x-1 transition-transform duration-200 inline-block'>8th Annual MOTW</span></a></li>
					<li><a href='https://www.facebook.com/watch/?v=1033529352173106' target='_blank' rel='noopener noreferrer' class='block transition-all duration-200 hover:text-accent group'><span class='group-hover:translate-x-1 transition-transform duration-200 inline-block'>Siklabuhay same day</span></a></li>
					<li><a href='https://aviethodigital.com/article/mwpl-2025-a-queen-in-the-making' target='_blank' rel='noopener noreferrer' class='block transition-all duration-200 hover:text-accent group'><span class='group-hover:translate-x-1 transition-transform duration-200 inline-block'>MWPL 2025</span></a></li>
				</ul>
					</div>
				</div>
			</div>
			
		<!-- Newsletter Section -->
		<div class="w-full text-center sm:text-left">
				<div class="bg-background-elevated rounded-lg p-2">
				<p class="text-text-subtle text-base mb-6 text-center sm:text-left">
						Get our latest design trends, marketing insights, and project showcases delivered straight to your inbox. Join our community of creators and stay ahead of the curve.
					</p>
			<form class="flex flex-col sm:flex-row items-center bg-background border border-muted rounded-lg overflow-hidden w-full max-w-md mx-auto sm:mx-0">
					<input 
						type="email" 
						placeholder="Enter your email" 
						class="px-4 py-3 bg-transparent border-none outline-none focus:outline-none flex-grow text-text-subtle"
						required
					/>
				<button 
					type="submit" 
					class="px-6 py-3 text-accent font-body font-semibold transition-colors duration-300 hover:text-accent-hover"
				>
					Subscribe
				</button>
				</form>
				</div>
			</div>
		</div>
		<!-- Column 4: Map -->
		<div class="flex flex-col justify-center items-center lg:items-start">
			<div class="relative group">
				<img src={mapImg.src} alt="Avietho Location Map" class="w-88 h-88 rounded-full object-cover shadow-lg border-2 border-muted" />
					<a 
						href="https://maps.app.goo.gl/KyDMwmYMADs5c5LC7" 
						target="_blank" 
						rel="noopener noreferrer"
						class="absolute inset-0 z-10 flex items-center justify-center"
					>
					<div class="flex items-center justify-center">
						<img 
						src={landmarkImg.src} 
						alt="Avietho Landmark" 
						class="w-20 h-20 object-contain drop-shadow-xl transition-all duration-500 animate-bob hover:scale-110 icon-hover cursor-pointer" 
						/>
					</div>
				</a>
			</div>
		</div>
	</div>

		<style>
			@keyframes bob {
				0%, 100% { transform: translateY(-25px); }
				50% { transform: translateY(-40px); }
			}
			.animate-bob {
				animation: bob 2s ease-in-out infinite;
			}
		</style>

		<!-- Bottom Section: Copyright -->
		<div class="mt-12 pt-8 border-t border-muted">
			<p class="text-center text-text-muted text-base">
				© 2026 Avietho Digital Marketing. All rights reserved.
			</p>
		</div>
	</div>
</footer>