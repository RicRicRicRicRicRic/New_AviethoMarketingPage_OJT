---
// Footer.astro — site footer with contact information
// Uses design system tokens and Tailwind utilities
---

<footer class="w-full bg-background border-t border-muted">
	<div class="max-w-7xl mx-auto px-4 py-12 lg:py-16">
		<!-- Main content grid -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
			<!-- Left Column: Description -->
			<div class="max-w-md">
				<p class="text-text-subtle text-base leading-relaxed">
					Professional digital marketing solutions for businesses of all sizes. From website development to social media management, we help you grow your online presence.
				</p>
			</div>

			<!-- Right Column: Contact Information -->
			<div>
				<h3 class="font-heading text-foreground text-xl font-semibold mb-6">
					CONTACT US
				</h3>
				<div class="flex flex-col gap-4">
					<!-- Phone -->
					<a
						href="tel:+6397831987"
						class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
					>
						<span class="text-lg" aria-hidden="true">📞</span>
						<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
							+639 783 1987
						</span>
					</a>

					<!-- Email -->
					<a
						href="mailto:marketing.avietho@gmail.com"
						class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
					>
						<span class="text-lg" aria-hidden="true">📧</span>
						<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
							marketing.avietho@gmail.com
						</span>
					</a>

					<!-- Social Media -->
					<a
						href="https://www.facebook.com/avietho"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-3 text-text-subtle hover:text-accent transition-colors duration-200 group"
					>
						<span class="text-lg" aria-hidden="true">📱</span>
						<span class="text-base group-hover:translate-x-1 transition-transform duration-200">
							Facebook
						</span>
					</a>
				</div>
			</div>
		</div>

		<!-- Bottom Section: Copyright -->
		<div class="mt-12 pt-8 border-t border-muted">
			<p class="text-center text-text-muted text-sm">
				© 2025 Avietho Digital Marketing. All rights reserved.
			</p>
		</div>
	</div>
</footer>