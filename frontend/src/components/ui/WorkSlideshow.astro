---
// Work Slideshow Component
// Two-track infinite-scrolling carousel
// Top Track: Items 1-5 (Right-to-Left)
// Bottom Track: Items 6-11 (Left-to-Right)

interface WorkSlide {
	imagePath: string;
	alt: string;
}

const workSlides: WorkSlide[] = [
	{ imagePath: '/src/assets/slides/work_slide1.jpg', alt: 'Work example 1' },
	{ imagePath: '/src/assets/slides/work_slide2.jpg', alt: 'Work example 2' },
	{ imagePath: '/src/assets/slides/work_slide3.jpg', alt: 'Work example 3' },
	{ imagePath: '/src/assets/slides/work_slide4.jpg', alt: 'Work example 4' },
	{ imagePath: '/src/assets/slides/work_slide5.jpg', alt: 'Work example 5' },
	{ imagePath: '/src/assets/slides/work_slide6.jpg', alt: 'Work example 6' },
	{ imagePath: '/src/assets/slides/work_slide7.jpg', alt: 'Work example 7' },
	{ imagePath: '/src/assets/slides/work_slide8.jpg', alt: 'Work example 8' },
	{ imagePath: '/src/assets/slides/work_slide9.jpg', alt: 'Work example 9' },
	{ imagePath: '/src/assets/slides/work_slide10.jpg', alt: 'Work example 10' },
	{ imagePath: '/src/assets/slides/work_slide11.jpg', alt: 'Work example 11' },
];

// Split slides into two tracks
const topTrackSlides = workSlides.slice(0, 5); // Items 1-5
const bottomTrackSlides = workSlides.slice(5, 11); // Items 6-11

const topTrackData = JSON.stringify(topTrackSlides);
const bottomTrackData = JSON.stringify(bottomTrackSlides);
---

<div class="work-slideshow w-full py-8">
	<!-- Top Track: Items 1-5, Right-to-Left -->
	<div class="relative w-full overflow-hidden mb-6">
		<div class="track-container flex gap-8" id="top-track" data-slides={topTrackData}>
		</div>
		
		<!-- Gradient overlays for smooth edges -->
		<div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-background to-transparent z-20 pointer-events-none"></div>
		<div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-background to-transparent z-20 pointer-events-none"></div>
	</div>

	<!-- Bottom Track: Items 6-11, Left-to-Right -->
	<div class="relative w-full overflow-hidden">
		<div class="track-container flex gap-8" id="bottom-track" data-slides={bottomTrackData}>
		</div>
		
		<!-- Gradient overlays for smooth edges -->
		<div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-background to-transparent z-20 pointer-events-none"></div>
		<div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-background to-transparent z-20 pointer-events-none"></div>
	</div>
</div>

<script>
	interface WorkSlide {
		imagePath: string;
		alt: string;
	}

	// Render slides for a track
	const renderTrack = (trackId: string, slides: WorkSlide[]) => {
		const track = document.getElementById(trackId);
		if (!track) return;

		// Duplicate slides for seamless infinite scroll
		const duplicatedSlides = [...slides, ...slides];
		
		const html = duplicatedSlides.map(slide => `
			<div class="flex-shrink-0 w-72 md:w-80 lg:w-96">
				<div class="relative w-full aspect-video rounded-xl overflow-hidden shadow-2xl bg-background-card border border-white/10">
					<img 
						src="${slide.imagePath}" 
						alt="${slide.alt}" 
						class="w-full h-full object-cover"
						loading="lazy"
					/>
				</div>
			</div>
		`).join('');
		
		track.innerHTML = html;
	};

	// Initialize both tracks
	const topTrackData = document.getElementById('top-track')?.getAttribute('data-slides');
	const bottomTrackData = document.getElementById('bottom-track')?.getAttribute('data-slides');

	if (topTrackData) {
		const topSlides: WorkSlide[] = JSON.parse(topTrackData);
		renderTrack('top-track', topSlides);
	}

	if (bottomTrackData) {
		const bottomSlides: WorkSlide[] = JSON.parse(bottomTrackData);
		renderTrack('bottom-track', bottomSlides);
	}
</script>

<style>
	/* Top Track Animation: Right-to-Left */
	#top-track {
		animation: scroll-rtl 45s linear infinite;
	}

	/* Bottom Track Animation: Left-to-Right */
	#bottom-track {
		animation: scroll-ltr 54s linear infinite;
	}

	/* Pause animation on hover */
	.work-slideshow:hover .track-container {
		animation-play-state: paused;
	}

	/* Right-to-Left animation */
	@keyframes scroll-rtl {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	/* Left-to-Right animation */
	@keyframes scroll-ltr {
		from {
			transform: translateX(-50%);
		}
		to {
			transform: translateX(0);
		}
	}

	/* Ensure smooth rendering */
	.track-container {
		will-change: transform;
		backface-visibility: hidden;
		width: max-content;
	}
</style>