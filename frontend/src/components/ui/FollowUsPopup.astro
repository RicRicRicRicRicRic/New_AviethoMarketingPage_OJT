---
// Follow Us pop-up — a small floating card that invites the visitor to
// follow along on social once they're roughly halfway down the page.
// It auto-dismisses the moment the footer scrolls into view, so it never
// sits on top of the footer's own content, and stays dismissed if the
// visitor closes it manually.
//
// Reuses the Facebook/Instagram/TikTok/YouTube icon assets from
// Socials.astro, plus Messenger (inline SVG — no matching asset exists).
// All five now link to the company's real, confirmed profile URLs.
// Positioned bottom-RIGHT, stacked directly above ChatWidget.astro's
// floating bubble (fixed bottom:20px right:20px, 56px tall) so the two
// float in the same corner without overlapping.

import facebookIcon from '/src/assets/icons/facebook_icon.png';
import instagramIcon from '/src/assets/icons/instagram_icon.png';
import tiktokIcon from '/src/assets/icons/tiktok_icon.png';

interface SocialLink {
	name: string;
	href: string;
	// Existing PNG icon set (Socials.astro's assets). Messenger has no
	// matching asset in /src/assets/icons, so it's left undefined and
	// rendered with an inline SVG glyph instead — swap in a real
	// messenger_icon.png import here if/when one exists.
	src?: string;
}

const socialLinks: SocialLink[] = [
	{ name: 'Facebook', href: 'https://www.facebook.com/aviethodigital', src: facebookIcon.src },
	{ name: 'Messenger', href: 'https://m.me/aviethodigital' },
	{ name: 'Instagram', href: 'https://www.instagram.com/aviethodigital/', src: instagramIcon.src },
	{ name: 'TikTok', href: 'https://www.tiktok.com/@aviethodigital', src: tiktokIcon.src },
];
---

<div
	id="follow-us-popup"
	class="follow-us-popup"
	role="dialog"
	aria-label="Follow us on social media"
	aria-hidden="true"
>
	<button type="button" id="follow-us-close" class="follow-us-close" aria-label="Dismiss">
		<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M18 6 6 18" />
			<path d="m6 6 12 12" />
		</svg>
	</button>

	<p class="follow-us-eyebrow">Stay in the loop</p>
	<h2 class="follow-us-title">Follow Us</h2>

	<div class="follow-us-links">
		{socialLinks.map((s) => (
			<a href={s.href} class="follow-us-link" title={s.name} target="_blank" rel="noopener noreferrer">
				{s.src ? (
					<img src={s.src} alt={s.name} class="icon-idle" />
				) : (
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label={s.name}>
						<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
					</svg>
				)}
			</a>
		))}
	</div>
</div>

<style>
	.follow-us-popup {
		position: fixed;
		right: 20px;
		bottom: 96px; /* clears ChatWidget's 56px bubble + 20px offset, plus a gap */
		z-index: 10050; /* above ChatWidget's #chat-bubble (9999) / #chat-window (10000) */
		width: 240px;
		max-width: calc(100vw - 40px);
		padding: 20px 20px 18px;
		border-radius: 16px;
		background: var(--color-background-card, #1a1a1a);
		border: 1px solid var(--color-muted, rgba(255, 255, 255, 0.1));
		box-shadow: 0 20px 44px rgba(0, 0, 0, 0.45), 0 4px 14px rgba(0, 0, 0, 0.3);
		backdrop-filter: blur(6px);

		opacity: 0;
		transform: translateY(16px) scale(0.98);
		pointer-events: none;
		transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1), transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.follow-us-popup.is-visible {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.follow-us-close {
		position: absolute;
		top: 10px;
		right: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border-radius: 999px;
		border: none;
		background: transparent;
		color: var(--color-foreground, #f5f5f5);
		opacity: 0.5;
		cursor: pointer;
		transition: opacity 0.2s ease, background 0.2s ease;
	}
	.follow-us-close:hover {
		opacity: 1;
		background: var(--color-muted, rgba(255, 255, 255, 0.1));
	}

	.follow-us-eyebrow {
		font-family: var(--font-body, 'Montserrat', sans-serif);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-accent, #c9a44c);
		margin: 0 0 6px;
	}
	.follow-us-title {
		font-family: var(--font-heading, 'Playfair Display', serif);
		font-size: 20px;
		font-weight: 600;
		color: var(--color-foreground, #f5f5f5);
		margin: 0 0 16px;
	}

	.follow-us-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
	}
	.follow-us-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 999px;
		border: 1px solid var(--color-muted, rgba(255, 255, 255, 0.1));
		background: rgba(255, 255, 255, 0.03);
		transition: border-color 0.25s ease, transform 0.25s ease, background 0.25s ease;
	}
	.follow-us-link:hover {
		border-color: var(--color-accent, #c9a44c);
		background: rgba(201, 164, 76, 0.1);
		transform: translateY(-2px);
	}
	.follow-us-link img {
		width: 18px;
		height: 18px;
		object-fit: contain;
	}
	.follow-us-link svg {
		width: 18px;
		height: 18px;
		color: var(--color-foreground, #f5f5f5);
		opacity: 0.85;
		transition: color 0.25s ease, opacity 0.25s ease;
	}
	.follow-us-link:hover svg {
		color: var(--color-accent, #c9a44c);
		opacity: 1;
	}

	@media (max-width: 520px) {
		.follow-us-popup {
			right: 16px;
			left: 16px;
			width: auto;
			max-width: none;
			bottom: 88px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.follow-us-popup {
			transition: opacity 0.2s ease;
			transform: none;
		}
		.follow-us-popup.is-visible {
			transform: none;
		}
	}
</style>

<script>
	const popup = document.getElementById('follow-us-popup');
	const closeBtn = document.getElementById('follow-us-close');

	if (popup) {
		let dismissed = false;
		let footerVisible = false;

		const showPopup = () => {
			popup.classList.add('is-visible');
			popup.setAttribute('aria-hidden', 'false');
		};

		const hidePopup = () => {
			popup.classList.remove('is-visible');
			popup.setAttribute('aria-hidden', 'true');
		};

		const evaluateScrollPosition = () => {
			if (dismissed || footerVisible) return;

			const scrollTop = window.scrollY;
			const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
			const progress = scrollableHeight > 0 ? scrollTop / scrollableHeight : 0;

			if (progress >= 0.3) {
				showPopup();
			} else {
				hidePopup();
			}
		};

		window.addEventListener('scroll', evaluateScrollPosition, { passive: true });
		window.addEventListener('resize', evaluateScrollPosition);
		evaluateScrollPosition();

		closeBtn?.addEventListener('click', () => {
			dismissed = true;
			hidePopup();
		});

		// Auto-close the instant the footer comes into view, and let it
		// reappear if the visitor scrolls back up above the halfway point
		// without having explicitly dismissed it.
		const footer = document.querySelector('footer');
		if (footer) {
			const footerObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						footerVisible = entry.isIntersecting;
						if (footerVisible) {
							hidePopup();
						} else {
							evaluateScrollPosition();
						}
					});
				},
				{ threshold: 0 }
			);
			footerObserver.observe(footer);
		}
	}
</script>