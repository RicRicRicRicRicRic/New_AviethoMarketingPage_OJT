---
// ChatWidget.astro – Archive Assistant
// Floating chat widget that lets readers query the editorial archive via
// the standalone Flask backend (see /avietho-flask). Theme colors are read
// directly from the `skills.md` content-collection entry at build time —
// per our methodology, every asset (including that doc) is version-controlled
// content, not a hard-coded value duplicated across components.

import { getEntry } from "astro:content";

interface Props {
  title?: string;
  placeholder?: string;
}

const {
  title = "Archive Assistant",
  placeholder = "Ask about our reporting…",
} = Astro.props;

// Pull the `theme` object straight from skills.md's frontmatter
// (collection: "docs", slug: "skills") instead of restating the hex
// values here. Falls back to sane defaults only if the entry or field
// is ever missing, so the widget never hard-fails a build.
const skillsEntry = await getEntry("docs", "skills");

const themeData = skillsEntry?.data?.theme ?? {
  mode: "dark",
  background: "#0A0A0A",
  accent: "#C9A44C",
  textPrimary: "#F5F5F5",
};

const theme = {
  background: themeData.background,
  accent: themeData.accent,
  textPrimary: themeData.textPrimary,
  // Derived tokens not present in the schema — computed relative to the
  // sourced values rather than invented independently.
  surface: themeData.mode === "dark" ? "#151515" : "#F0F0F0",
  textMuted: themeData.mode === "dark" ? "#A3A3A3" : "#5A5A5A",
  border: themeData.mode === "dark" ? "#2A2A2A" : "#DDDDDD",
};
---

<div id="chat-widget-root" data-placeholder={placeholder} data-title={title}></div>

<script>
  // The Flask service is decoupled from the Astro frontend per our
  // architecture — all requests go through PUBLIC_FLASK_API_URL and hit
  // the archival chatbot endpoint directly. In a larger refactor this
  // fetch call belongs in src/lib/api/endpoints/chat.ts, but is kept
  // inline here to preserve the single-file widget structure.
  const API_URL: string = import.meta.env.PUBLIC_FLASK_API_URL || "http://localhost:5000";

  interface ChatResponse {
    reply?: string;
  }

  const root = document.getElementById("chat-widget-root") as HTMLDivElement;
  const title = root.dataset.title ?? "Archive Assistant";
  const placeholder = root.dataset.placeholder ?? "Ask about our reporting…";

  root.innerHTML = `
    <div id="chat-bubble" aria-label="Open ${title}">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </div>
    <div id="chat-window" style="display:none;">
      <div id="chat-header">
        <span>${title}</span>
        <button id="chat-close" aria-label="Close chat">&times;</button>
      </div>
      <div id="chat-messages"></div>
      <div id="chat-input-area">
        <input type="text" id="chat-input" placeholder="${placeholder}" />
        <button id="chat-send">Send</button>
      </div>
    </div>
  `;

  const bubble = document.getElementById("chat-bubble") as HTMLDivElement;
  const windowEl = document.getElementById("chat-window") as HTMLDivElement;
  const closeBtn = document.getElementById("chat-close") as HTMLButtonElement;
  const messagesEl = document.getElementById("chat-messages") as HTMLDivElement;
  const inputEl = document.getElementById("chat-input") as HTMLInputElement;
  const sendBtn = document.getElementById("chat-send") as HTMLButtonElement;

  bubble.addEventListener("click", () => {
    windowEl.style.display = "flex";
    bubble.style.display = "none";
    inputEl.focus();
  });

  closeBtn.addEventListener("click", () => {
    windowEl.style.display = "none";
    bubble.style.display = "flex";
  });

  function appendMessage(text: string, role: "user" | "bot"): void {
    const el = document.createElement("div");
    el.className = `chat-msg ${role}-msg`;
    el.textContent = text;
    messagesEl.appendChild(el);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  async function sendMessage(): Promise<void> {
    const message = inputEl.value.trim();
    if (!message) return;

    appendMessage(message, "user");
    inputEl.value = "";

    const thinking = document.createElement("div");
    thinking.className = "chat-msg bot-msg thinking";
    thinking.textContent = "Searching the archive…";
    messagesEl.appendChild(thinking);
    messagesEl.scrollTop = messagesEl.scrollHeight;

    try {
      const res = await fetch(`${API_URL}/chat`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message }),
      });
      const data: ChatResponse = await res.json();
      const reply = data.reply || "Sorry, something went wrong.";
      messagesEl.removeChild(thinking);
      appendMessage(reply, "bot");
    } catch (err) {
      messagesEl.removeChild(thinking);
      appendMessage("Error: Could not connect to the archive service.", "bot");
    }
  }

  sendBtn.addEventListener("click", sendMessage);
  inputEl.addEventListener("keypress", (e: KeyboardEvent) => {
    if (e.key === "Enter") sendMessage();
  });
</script>

<style define:vars={theme} is:global>
  /* ---------- Archive Assistant — Chat Widget Styles ---------- */
  #chat-bubble {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 56px;
    height: 56px;
    background-color: var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.45);
    z-index: 9999;
    transition: transform 0.15s ease;
  }
  #chat-bubble:hover {
    transform: scale(1.05);
  }
  #chat-window {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 360px;
    height: 480px;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
    display: none;
    flex-direction: column;
    z-index: 10000;
    overflow: hidden;
    font-family: inherit;
  }
  #chat-header {
    background: var(--surface);
    color: var(--textPrimary);
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  #chat-close {
    background: none;
    border: none;
    color: var(--textMuted);
    font-size: 20px;
    cursor: pointer;
    line-height: 1;
  }
  #chat-close:hover {
    color: var(--textPrimary);
  }
  #chat-messages {
    flex: 1;
    padding: 12px;
    overflow-y: auto;
    background: var(--background);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  #chat-input-area {
    display: flex;
    padding: 10px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  #chat-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 20px;
    outline: none;
    background: var(--background);
    color: var(--textPrimary);
  }
  #chat-input::placeholder {
    color: var(--textMuted);
  }
  #chat-input:focus {
    border-color: var(--accent);
  }
  #chat-send {
    margin-left: 8px;
    padding: 8px 16px;
    background: var(--accent);
    color: var(--background);
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-weight: 600;
  }
  #chat-send:hover {
    filter: brightness(1.1);
  }
  .chat-msg {
    max-width: 80%;
    padding: 8px 12px;
    border-radius: 12px;
    line-height: 1.4;
    word-wrap: break-word;
    font-size: 14px;
  }
  .user-msg {
    align-self: flex-end;
    background: var(--accent);
    color: var(--background);
    border-bottom-right-radius: 4px;
  }
  .bot-msg {
    align-self: flex-start;
    background: var(--surface);
    color: var(--textPrimary);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    white-space: pre-wrap;
  }
  .bot-msg.thinking {
    color: var(--textMuted);
    font-style: italic;
  }
</style>
