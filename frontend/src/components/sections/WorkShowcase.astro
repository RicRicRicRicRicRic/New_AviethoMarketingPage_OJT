---
// Work showcase section - displaying portfolio/work examples
interface Props {
	title?: string;
}

const { title = 'Our Work' } = Astro.props;
---

<section class="py-20 px-4 bg-[#0F0F0F]">
	<div class="max-w-6xl mx-auto">
		<h2 class="text-3xl md:text-4xl font-bold text-center text-[#C9A44C] mb-12">
			{title}
		</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<slot name="work-item-1" />
			<slot name="work-item-2" />
			<slot name="work-item-3" />
		</div>
	</div>
</section>