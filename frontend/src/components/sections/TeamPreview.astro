---
// Team preview section - showcasing team members
interface Props {
	title?: string;
}

const { title = 'Our Team' } = Astro.props;
---

<section class="py-20 px-4 bg-[#0F0F0F]">
	<div class="max-w-6xl mx-auto">
		<h2 class="text-3xl md:text-4xl font-bold text-center text-[#C9A44C] mb-12">
			{title}
		</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
			<slot name="team-member-1" />
			<slot name="team-member-2" />
			<slot name="team-member-3" />
			<slot name="team-member-4" />
		</div>
	</div>
</section>