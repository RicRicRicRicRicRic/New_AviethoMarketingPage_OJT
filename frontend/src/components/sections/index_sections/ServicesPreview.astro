---
// Services preview section - overview of offered services
import Image from 'astro/components/Image.astro';

type ServiceId = 'digital-pr' | 'social-media' | 'video-production' | 'post-production' | 'live-streaming' | 'specialized';

interface Service {
	id: ServiceId;
	title: string;
	description: string;
	iconPath: string;
	href: string;
}

interface Props {
	title?: string;
	services?: Service[];
}

// Type-safe icon mapping
const iconMap: Record<ServiceId, string> = {
	'digital-pr': '/src/assets/icons/publicrelations_icon.png',
	'social-media': '/src/assets/icons/mulimediaBranding_icon.png',
	'video-production': '/src/assets/icons/digitalSocialMediaMarketing_icon.png',
	'post-production': '/src/assets/icons/webDevelopment_icon.png',
	'live-streaming': '/src/assets/icons/liveStream_icon.png',
	'specialized': '/src/assets/icons/Specialized_icon.png'
};

const { 
	title = 'Our Services',
	services = [
		{
			id: 'digital-pr',
			title: 'Digital PR',
			description: 'Earned coverage, trusted voices, and a reputation that holds up under scrutiny across the channels your audience already follows.',
			iconPath: iconMap['digital-pr'],
			href: '/services#digital-pr'
		},
		{
			id: 'social-media',
			title: 'Social Media',
			description: 'Strategy-led content, community management, and measurement that keep a brand active between campaigns.',
			iconPath: iconMap['social-media'],
			href: '/services#social-media'
		},
		{
			id: 'video-production',
			title: 'Video Production',
			description: 'Corporate, live, commercial, and documentary work produced to hold up beautifully on any screen.',
			iconPath: iconMap['video-production'],
			href: '/services#video-production'
		},
		{
			id: 'post-production',
			title: 'Post-Production',
			description: 'Editing, grading, sound, and motion work that turn raw footage into a polished, compelling story.',
			iconPath: iconMap['post-production'],
			href: '/services#post-production'
		},
		{
			id: 'live-streaming',
			title: 'Live Streaming',
			description: 'Comprehensive, high-quality live broadcasting solutions for everything from personal social media to professional business events and large-scale enterprise conferences.',
			iconPath: iconMap['live-streaming'],
			href: '/services#live-streaming'
		},
		{
			id: 'specialized',
			title: 'Specialized',
			description: 'Specialized finishing services, including drone videography, accessibility compliance, video SEO, and visual infographics, to perfectly optimize and round out your media campaigns.',
			iconPath: iconMap['specialized'],
			href: '/services#specialized'
		}
	]
} = Astro.props;
---

<section id="services" class="px-4 py-40 bg-background-elevated w-full h-full ">
	<div class="w-full h-full flex flex-col">
		<h2 class="text-3xl md:text-4xl font-bold text-center text-accent mb-12">
			{title}
		</h2>
		
		<div id="services-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
			{services.map((service) => (
				<a 
					href={service.href}
					class="service-card block opacity-0 translate-y-8 transition-all duration-700 ease-out bg-white/5 border border-white/10 backdrop-blur-md rounded-xl p-6 hover:border-accent/50 hover:bg-white/10 group"
				>
					<div class="flex justify-center mb-4">
					<Image 
						src={service.iconPath}
						alt={`${service.title} icon`}
						class="h-8 w-8 icon-idle group-hover:icon-hover"
						width={32}
						height={32}
					/>
					</div>
					<h3 class="text-xl font-semibold text-white mb-3 text-center">
						{service.title}
					</h3>
					<p class="text-gray-300 text-sm leading-relaxed text-center">
						{service.description}
					</p>
				</a>
			))}
		</div>
	</div>
</section>

<script>
	// Intersection Observer for smooth entry animation
	const observerOptions = {
		root: null,
		rootMargin: '0px',
		threshold: 0.1
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				// Add animation class when section enters viewport
				const cards = entry.target.querySelectorAll('.service-card');
				cards.forEach((card, index) => {
					setTimeout(() => {
						card.classList.remove('opacity-0', 'translate-y-8');
						card.classList.add('opacity-100', 'translate-y-0');
					}, index * 100); // Staggered animation
				});
			} else {
				// Remove animation class when section leaves viewport
				const cards = entry.target.querySelectorAll('.service-card');
				cards.forEach((card) => {
					card.classList.remove('opacity-100', 'translate-y-0');
					card.classList.add('opacity-0', 'translate-y-8');
				});
			}
		});
	}, observerOptions);

	// Observe the services grid
	const servicesGrid = document.getElementById('services-grid');
	if (servicesGrid) {
		observer.observe(servicesGrid);
	}
</script>