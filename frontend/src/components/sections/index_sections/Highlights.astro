---
// Interactive video gallery section
interface Props {
	title?: string;
}

const { title = 'HIGHLIGHTS' } = Astro.props;

const videoClips = [
	{ id: 1, source: 'youtube', videoId: 'uZMcbP0_S7c', title: 'Highlight Reel 01' },
	{ id: 2, source: 'youtube', videoId: 'PJJpbt_Kdmw', title: 'Highlight Reel 02' },
	{ id: 3, source: 'youtube', videoId: 'XCBVNsZzp1Q', title: 'Highlight Reel 03' },
	{ id: 4, source: 'youtube', videoId: '9WA-p-Gg8ME', title: 'Highlight Reel 04' },
	{ id: 5, source: 'youtube', videoId: 'oDw1xoDZmMc', title: 'Highlight Reel 05' },
	{ id: 6, source: 'youtube', videoId: 'ns_bKg8kRyc', title: 'Highlight Reel 06' },
	{ id: 7, source: 'youtube', videoId: 'yEMBg5qzo_Y', title: 'Highlight Reel 07' },
	{
		id: 8,
		source: 'drive',
		driveId: '1KaP05RRopQ1gv_E0EzMwR7fIKm9EuglG',
		title: 'Highlight Reel 08',
		youtubeLink: 'https://www.youtube.com/live/AbE31iQNTzY',
	},
	{
		id: 9,
		source: 'drive',
		driveId: '1zXKoeMGaM1orDQbQtAOD0TC2DcFPSinO',
		title: 'Highlight Reel 09',
		youtubeLink: 'https://www.youtube.com/live/u-lQt-wPCqw',
	},
	{
		id: 10,
		source: 'drive',
		driveId: '1N3G53eGTryBSBD60upjwL4Qmb-M5uQm8',
		title: 'Highlight Reel 10',
		youtubeLink: 'https://www.youtube.com/live/Uw29e-tUW3Y',
	},
	{
		id: 12,
		source: 'drive',
		driveId: '1OC1du1SRHl2N44s6GiI2wq2MwxTTaslV',
		title: 'Highlight Reel 12',
		youtubeLink: 'https://www.youtube.com/live/07QdJJ3XXFs',
	},
	{
		id: 13,
		source: 'drive',
		driveId: '1LqmU9YkyZJTSnW4vJblm9JG_0tcLJwPq',
		title: 'Highlight Reel 13',
		youtubeLink: 'https://www.youtube.com/live/AhegrxF80J4',
	},
];
---

<section class="py-40 px-4 w-full h-full overflow-hidden">
	<div class="max-w-7xl mx-auto relative h-[600px]">
		<!-- Header with Vertical Bar -->
		<div class="flex items-center justify-center mb-8">
			<!-- Header Content (centered) -->
			<div class="text-center">
				<p class="text-xs uppercase tracking-widest text-accent mb-3 font-medium">
					What Sets Us Apart
				</p>
				<h2 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold text-foreground mb-4">
					{title}
				</h2>
			</div>
		</div>

		<!-- Video clip data, passed to the client script as JSON (single source of truth) -->
		<div id="videoClipsData" class="hidden" data-clips={JSON.stringify(videoClips)}></div>

		<!-- Video Gallery Container -->
		<div class="relative w-full h-[500px] flex items-center justify-center">

		<!-- Active Video Viewport (Centered) -->
		<div id="activeVideoViewport" class="absolute inset-0 flex items-center justify-center z-10 transition-all duration-500 ease-out group">
			<div id="activeVideoBox" class="relative w-full max-w-4xl aspect-video bg-background-card rounded-lg overflow-hidden cursor-pointer">
				<!-- YouTube player mounts here -->
				<div id="activeVideoPlayer" class="w-full h-full"></div>

				<!-- Google Drive clips mount here instead (kept as a separate node so the
				     YouTube player's DOM node is never destroyed when switching sources).
				     Drive embeds ship their own native controls, so pointer-events stay on. -->
				<div id="driveVideoPlayer" class="hidden absolute inset-0 w-full h-full"></div>

				<!-- Edge Fade Overlay (purely decorative, non-interactive) -->
				<div class="video-edge-fade absolute inset-0 pointer-events-none"></div>

				<!-- Play/Pause Overlay Icon -->
				<div id="playPauseOverlay" class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300">
					<svg id="playIcon" class="w-20 h-20 text-white drop-shadow-2xl" fill="currentColor" viewBox="0 0 24 24">
						<path d="M8 5v14l11-7z"/>
					</svg>
				</div>

				<!-- Video Progress Bar -->
				<div id="progressBarContainer" class="absolute bottom-12 left-0 right-0 h-1 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
					<div id="progressBar" class="h-full bg-accent w-0"></div>
				</div>

				<!-- Video Title Overlay -->
				<div id="videoTitleOverlay" class="absolute top-0 left-0 right-0 p-6 bg-gradient-to-b from-black/80 to-transparent transition-opacity duration-300 opacity-0 group-hover:opacity-100">
					<h3 id="videoTitle" class="text-xl md:text-2xl font-heading font-bold text-foreground">
						{videoClips[0].title}
					</h3>
				</div>

				<!-- Mute/Unmute Button (visible on hover) -->
				<button
					id="muteToggle"
					class="absolute top-4 right-4 p-3 bg-background/50 backdrop-blur-sm rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20"
					aria-label="Toggle mute"
				>
					<!-- Mute Icon (hidden by default — sound starts unmuted) -->
					<svg id="muteIcon" class="w-6 h-6 icon-idle-svg group-hover:icon-hover-svg hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
					</svg>
					<!-- Unmute Icon (shown by default — sound starts unmuted) -->
					<svg id="unmuteIcon" class="w-6 h-6 icon-idle-svg group-hover:icon-hover-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
					</svg>
				</button>

				<!-- Watch on YouTube link (Drive clips with a corresponding YouTube link only —
				     shown/hidden and pointed to the right URL by the client script) -->
				<a
					id="driveYoutubeLink"
					href="#"
					target="_blank"
					rel="noopener noreferrer"
					class="hidden absolute top-4 right-4 items-center gap-2 px-3 py-2 bg-background/50 backdrop-blur-sm rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20 text-xs font-medium text-foreground"
					aria-label="Watch on YouTube"
				>
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
						<path d="M21.582 7.186a2.51 2.51 0 00-1.768-1.778C18.254 5 12 5 12 5s-6.254 0-7.814.408a2.51 2.51 0 00-1.768 1.778A26.28 26.28 0 002 12a26.28 26.28 0 00.418 4.814 2.51 2.51 0 001.768 1.778C5.746 19 12 19 12 19s6.254 0 7.814-.408a2.51 2.51 0 001.768-1.778A26.28 26.28 0 0022 12a26.28 26.28 0 00-.418-4.814zM10 15V9l5.196 3z"/>
					</svg>
					Watch on YouTube
				</a>
			</div>
		</div>

		<!-- Video Gallery List (Centered, visible during navigation) -->
			<div id="videoGalleryList" class="absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 scale-90 overflow-hidden">
			<div id="videoGalleryTrack" class="flex flex-col gap-4 px-4">
				{videoClips.map((clip, index) => (
					<div class="video-gallery-item flex-shrink-0 w-64 aspect-video bg-background-card rounded-lg overflow-hidden cursor-pointer transition-transform duration-300 hover:scale-105" data-index={index}>
						<img
							src={clip.source === 'drive'
								? `https://drive.google.com/thumbnail?id=${clip.driveId}&sz=w640`
								: `https://img.youtube.com/vi/${clip.videoId}/hqdefault.jpg`}
							alt=""
							class="w-full h-full object-cover video-gallery-thumb"
							loading={clip.source === 'drive' ? 'eager' : 'lazy'}
							decoding="async"
							referrerpolicy="no-referrer"
						/>
					</div>
				))}
			</div>
			</div>

		<!-- Vertical Bar with Draggable Pointer (on the right) -->
			<div class="absolute right-0 top-1/2 -translate-y-1/2 w-12 h-64 flex-shrink-0 z-20">
				<div class="w-1 h-64 bg-white/10 rounded-full absolute left-1/4 -translate-x-1/2 top-0"></div>
			<img
				src="/src/assets/icons/pointer_icon.png"
				alt="Draggable pointer"
				class="absolute left-1/2 -translate-x-[calc(50%-1px)] cursor-grab active:cursor-grabbing w-6 h-6 icon-idle hover:icon-hover"
				id="dragPointer"
			/>
			</div>
		</div>
	</div>
</section>

<style>
	/* The YouTube IFrame API replaces #activeVideoPlayer with an <iframe>.
	   Force that iframe to fill the box exactly like the old <video> did,
	   and let clicks pass through to our own custom controls layer. */
	#activeVideoPlayer {
		position: relative;
		width: 100%;
		height: 100%;
	}
	#activeVideoPlayer iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}
	#progressBar {
		transition: width 100ms linear;
	}
	/* Soft fade on all four edges of the active video, sitting above the
	   iframe/player but below the title, mute button, and progress bar.
	   Uses the theme's background color so the video edges blend into
	   the page instead of just darkening. */
	.video-edge-fade {
		z-index: 5;
		background:
			linear-gradient(to bottom, hsl(var(--background)) 0%, transparent 25%),
			linear-gradient(to top, hsl(var(--background)) 0%, transparent 25%),
			linear-gradient(to right, hsl(var(--background)) 0%, transparent 18%),
			linear-gradient(to left, hsl(var(--background)) 0%, transparent 18%);
	}
	/* Smooth crossfade whenever the active video is swapped */
	#activeVideoPlayer.is-switching {
		opacity: 0.25;
		transition: opacity 180ms ease-out;
	}
	#activeVideoPlayer {
		opacity: 1;
		transition: opacity 220ms ease-in;
	}
</style>

<script>
	// Interactive video gallery with drag-to-scroll, backed by the YouTube IFrame Player API
	(() => {
		type VideoClip = { id: number; title: string; source?: 'youtube' | 'drive'; videoId?: string; driveId?: string; youtubeLink?: string };

		const dataEl = document.getElementById('videoClipsData');
		let videoClips: VideoClip[] = [];
		try {
			videoClips = JSON.parse(dataEl?.getAttribute('data-clips') || '[]');
		} catch {
			videoClips = [];
		}
		if (videoClips.length === 0) return;

		const pointer = document.getElementById('dragPointer') as HTMLImageElement | null;
		const activeVideoViewport = document.getElementById('activeVideoViewport') as HTMLDivElement | null;
		const videoGalleryList = document.getElementById('videoGalleryList') as HTMLDivElement | null;
		const galleryTrack = document.getElementById('videoGalleryTrack') as HTMLDivElement | null;
		const activeVideoBox = document.getElementById('activeVideoBox') as HTMLDivElement | null;
		const playerMount = document.getElementById('activeVideoPlayer') as HTMLDivElement | null;
		const driveMount = document.getElementById('driveVideoPlayer') as HTMLDivElement | null;
		const videoTitle = document.getElementById('videoTitle') as HTMLHeadingElement | null;
		const muteToggle = document.getElementById('muteToggle') as HTMLButtonElement | null;
		const muteIcon = document.getElementById('muteIcon') as SVGSVGElement | null;
		const unmuteIcon = document.getElementById('unmuteIcon') as SVGSVGElement | null;
		const progressBar = document.getElementById('progressBar') as HTMLDivElement | null;
		const progressBarContainer = document.getElementById('progressBarContainer') as HTMLDivElement | null;
		const playPauseOverlay = document.getElementById('playPauseOverlay') as HTMLDivElement | null;
		const driveYoutubeLink = document.getElementById('driveYoutubeLink') as HTMLAnchorElement | null;
		const playIcon = document.getElementById('playIcon') as SVGSVGElement | null;
		const galleryItems = document.querySelectorAll('.video-gallery-item');

		// If a thumbnail fails to load (Drive's thumbnail endpoint can be flaky for some
		// files), hide the broken image instead of showing the browser's broken-image icon —
		// the card's own background color shows through as a clean fallback.
		document.querySelectorAll('.video-gallery-thumb').forEach((img) => {
			img.addEventListener('error', () => {
				(img as HTMLImageElement).style.display = 'none';
			});
		});

		if (!pointer || !activeVideoViewport || !videoGalleryList || !playerMount) return;

		let isDragging = false;
		let startY = 0;
		let startTop = 0;
		let currentVideoIndex = 0;
		let isMuted = false;
		let hasInteracted = false;
		let player: any = null;
		let playerReady = false;
		let progressRafId = 0;
		let itemPitch = 0; // vertical distance between gallery item centers
		let trackHeight = 0; // total stacked height of the gallery track
		const titleCache = new Map<string, string>();
		const failedVideoIndices = new Set<number>();
		let driveVisibilityTimer = 0;

		const bar = pointer.parentElement;
		if (!bar) return;

		let barHeight = bar.clientHeight;
		let centerPosition = barHeight / 2;

		// Initialize pointer position to center
		pointer.style.position = 'absolute';
		pointer.style.top = `${centerPosition}px`;
		pointer.style.transform = 'translate(-50%, -50%)';

		// Initialize first gallery item as active
		galleryItems.forEach((item, idx) => {
			if (idx === 0) {
				item.classList.add('ring-2', 'ring-accent');
				item.classList.remove('opacity-50');
			} else {
				item.classList.remove('ring-2', 'ring-accent');
				item.classList.add('opacity-50');
			}
		});

		// Measure the gallery track so we know how far apart each thumbnail sits.
		// Re-run on drag start too, in case of resizes/layout shifts.
		const measureTrack = () => {
			if (!galleryTrack || galleryItems.length === 0) return;
			const first = galleryItems[0] as HTMLElement;
			if (galleryItems.length > 1) {
				const second = galleryItems[1] as HTMLElement;
				itemPitch = second.offsetTop - first.offsetTop;
			} else {
				itemPitch = first.offsetHeight;
			}
			trackHeight = galleryTrack.scrollHeight;
		};
		measureTrack();

		// Slide the track so the item at `floatIndex` (can be fractional while dragging)
		// sits centered in the visible window — this is what makes every thumbnail
		// reachable instead of the later ones overflowing off the page.
		const positionTrack = (floatIndex: number, animate = false) => {
			if (!galleryTrack || itemPitch === 0) return;
			const clamped = Math.max(0, Math.min(videoClips.length - 1, floatIndex));
			const targetCenter = clamped * itemPitch + itemPitch / 2;
			const translateY = trackHeight / 2 - targetCenter;
			galleryTrack.style.transition = animate ? 'transform 0.35s cubic-bezier(0.4, 0, 0.2, 1)' : 'none';
			galleryTrack.style.transform = `translateY(${translateY}px)`;
		};
		positionTrack(0);

		const setPlayIcon = (isPlaying: boolean) => {
			if (!playIcon || !playPauseOverlay) return;
			// Pause glyph vs. play glyph
			playIcon.innerHTML = isPlaying
				? '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>'
				: '<path d="M8 5v14l11-7z"/>';
			playPauseOverlay.style.opacity = isPlaying ? '0' : '1';
		};

		// Pull the video ID out of any common YouTube URL shape (watch?v=, live/, youtu.be/,
		// embed/, shorts/) — used to fetch a Drive clip's title from its paired YouTube video.
		const extractYouTubeId = (url: string): string => {
			try {
				const u = new URL(url);
				if (u.hostname.includes('youtu.be')) return u.pathname.slice(1).split('/')[0] || '';
				const match = u.pathname.match(/\/(live|embed|shorts)\/([^/?]+)/);
				if (match) return match[2];
				return u.searchParams.get('v') || '';
			} catch {
				return '';
			}
		};

		// The YouTube video ID used to look up/cache a clip's real title: its own videoId
		// for YouTube clips, or the ID pulled from youtubeLink for Drive clips that have one.
		const titleLookupId = (clip: VideoClip): string =>
			clip.source === 'drive' ? extractYouTubeId(clip.youtubeLink || '') : clip.videoId || '';

		// Fetch a video's real title via YouTube's oEmbed endpoint (CORS-friendly, no API key needed).
		// Drive clips without a youtubeLink skip this — there's no equivalent public endpoint for
		// Drive files, so they just keep the title supplied in videoClips.
		const fetchTitle = async (clip: VideoClip, index: number) => {
			const lookupId = titleLookupId(clip);
			if (!lookupId) return;
			if (titleCache.has(lookupId)) {
				applyTitleIfActive(index, titleCache.get(lookupId)!);
				return;
			}
			try {
				const res = await fetch(
					`https://www.youtube.com/oembed?url=${encodeURIComponent(
						`https://www.youtube.com/watch?v=${lookupId}`
					)}&format=json`
				);
				if (!res.ok) throw new Error('oEmbed request failed');
				const data = await res.json();
				const realTitle = typeof data?.title === 'string' && data.title ? data.title : clip.title;
				titleCache.set(lookupId, realTitle);
				applyTitleIfActive(index, realTitle);
			} catch {
				// Network/oEmbed unavailable — keep the fallback title, no need to surface an error
			}
		};

		const applyTitleIfActive = (index: number, text: string) => {
			if (index === currentVideoIndex && videoTitle) {
				videoTitle.textContent = text;
			}
		};

		// Google Drive's embed exposes no JS API to play/pause it from the parent page.
		// The only reliable way to start/stop it programmatically is to mount/unmount the
		// iframe itself — loading it (with the autoplay param) starts playback, clearing
		// it out stops playback dead. This is what makes "pause on scroll out" possible.
		const loadDriveIframe = (clip: VideoClip) => {
			if (!driveMount || clip.source !== 'drive' || !clip.driveId) return;
			driveMount.innerHTML = `<iframe src="https://drive.google.com/file/d/${clip.driveId}/preview?autoplay=1" title="${clip.title}" frameborder="0" allow="autoplay" allowfullscreen style="width:100%;height:100%;"></iframe>`;
		};
		const pauseDriveIframe = () => {
			if (!driveMount) return;
			driveMount.innerHTML = '';
		};

		// Smooth, frame-synced progress bar (replaces the old 'timeupdate' polling)
		const tickProgress = () => {
			if (player && playerReady && progressBar && typeof player.getDuration === 'function') {
				const duration = player.getDuration();
				const currentTime = player.getCurrentTime();
				if (duration > 0) {
					progressBar.style.width = `${Math.min(100, (currentTime / duration) * 100)}%`;
				}
			}
			progressRafId = requestAnimationFrame(tickProgress);
		};

		const updateActiveVideo = (index: number) => {
			currentVideoIndex = index;
			const clip = videoClips[index];
			if (!clip || !videoTitle) return;

			// Show fallback title immediately, then swap in the real one once fetched
			const lookupId = titleLookupId(clip);
			videoTitle.textContent = (lookupId && titleCache.get(lookupId)) || clip.title;
			fetchTitle(clip, index);

			if (progressBar) progressBar.style.width = '0%';

			// "Watch on YouTube" link: only relevant for Drive clips that have one
			if (driveYoutubeLink) {
				if (clip.source === 'drive' && clip.youtubeLink) {
					driveYoutubeLink.href = clip.youtubeLink;
					driveYoutubeLink.classList.remove('hidden');
					driveYoutubeLink.classList.add('flex');
				} else {
					driveYoutubeLink.classList.add('hidden');
					driveYoutubeLink.classList.remove('flex');
				}
			}

			if (clip.source === 'drive') {
				// Pause the YouTube player (it stays mounted, just hidden) and switch
				// to the Drive iframe, which brings its own native controls.
				if (player && playerReady && typeof player.pauseVideo === 'function') {
					player.pauseVideo();
				}
				if (playerMount) playerMount.classList.add('hidden');
				if (driveMount) {
					driveMount.classList.remove('hidden');
					loadDriveIframe(clip);
				}
				// Drive embeds don't expose a JS API, so the custom progress bar,
				// mute button, and play/pause overlay don't apply — hide them.
				progressBarContainer?.classList.add('hidden');
				muteToggle?.classList.add('hidden');
				playPauseOverlay?.classList.add('hidden');
				return;
			}

			// YouTube clip: restore the controls Drive clips hide, and show the YT mount again
			progressBarContainer?.classList.remove('hidden');
			muteToggle?.classList.remove('hidden');
			playPauseOverlay?.classList.remove('hidden');
			if (driveMount) {
				driveMount.classList.add('hidden');
				driveMount.innerHTML = '';
			}
			if (playerMount) playerMount.classList.remove('hidden');

			if (player && playerReady && typeof player.loadVideoById === 'function' && clip.videoId) {
				playerMount?.classList.add('is-switching');
				player.loadVideoById(clip.videoId);
				isMuted ? player.mute() : player.unMute();
				setTimeout(() => playerMount?.classList.remove('is-switching'), 200);
			} else if (playerMount && clip.videoId) {
				// API failed to load — graceful fallback to a plain embed with native controls
				playerMount.innerHTML = `<iframe src="https://www.youtube.com/embed/${clip.videoId}?autoplay=1&mute=1&playsinline=1" title="${clip.title}" frameborder="0" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen style="pointer-events:auto;"></iframe>`;
			}
		};

		// Add click handlers to gallery items
		galleryItems.forEach((item, index) => {
			item.addEventListener('click', () => {
				hasInteracted = true;
				updateActiveVideo(index);
				highlightGalleryItem(index);
				positionTrack(index, true);
				// Return pointer to center
				pointer.style.transition = 'top 0.5s ease-out';
				pointer.style.top = `${centerPosition}px`;
				setTimeout(() => {
					pointer.style.transition = 'none';
				}, 500);
			});
		});

		const highlightGalleryItem = (index: number) => {
			galleryItems.forEach((item, idx) => {
				if (idx === index) {
					item.classList.add('ring-2', 'ring-accent');
					item.classList.remove('opacity-50');
				} else {
					item.classList.remove('ring-2', 'ring-accent');
					item.classList.add('opacity-50');
				}
			});
		};

		// Mute/Unmute toggle
		if (muteToggle && muteIcon && unmuteIcon) {
			muteToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				isMuted = !isMuted;
				if (player && playerReady) {
					isMuted ? player.mute() : player.unMute();
				}
				muteIcon.classList.toggle('hidden', !isMuted);
				unmuteIcon.classList.toggle('hidden', isMuted);
			});
		}

		// Play/Pause toggle on click anywhere in the video box (iframe has pointer-events:none,
		// so this click reliably fires — the old code relied on a <video> click listener that
		// doesn't work once the source is a cross-origin YouTube iframe).
		// Drive clips use their own native controls, so this is skipped for those.
		if (activeVideoBox) {
			activeVideoBox.addEventListener('click', () => {
				hasInteracted = true;
				if (videoClips[currentVideoIndex]?.source === 'drive') return;
				if (!player || !playerReady) return;
				const state = player.getPlayerState();
				if (state === 1 /* YT.PlayerState.PLAYING */) {
					player.pauseVideo();
				} else {
					player.playVideo();
				}
			});
		}

		// Intersection Observer for auto-play/pause. YouTube clips use the JS API directly;
		// Drive clips have no JS API, so "pause" means unmounting the iframe and "play"
		// means remounting it with autoplay — see loadDriveIframe/pauseDriveIframe above.
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const activeClip = videoClips[currentVideoIndex];

					if (activeClip?.source === 'drive') {
						clearTimeout(driveVisibilityTimer);
						// Wait a beat before actually acting — a normal scroll gesture can
						// cross the 50% visibility threshold back and forth a few times in
						// quick succession, and reacting to every one of those was tearing
						// the iframe down and rebuilding it repeatedly (looked like the video
						// kept restarting/changing). This settles on the final state instead.
						driveVisibilityTimer = window.setTimeout(() => {
							if (entry.isIntersecting) {
								if (driveMount && driveMount.innerHTML === '') {
									loadDriveIframe(activeClip);
								}
							} else {
								pauseDriveIframe();
							}
						}, 200);
						return;
					}

					if (!player || !playerReady) return;
					const state = player.getPlayerState();
					if (entry.isIntersecting) {
						if (!hasInteracted || state !== 2 /* PAUSED */) {
							player.playVideo();
						}
					} else {
						player.pauseVideo();
					}
				});
			},
			{ root: null, rootMargin: '0px', threshold: 0.5 }
		);
		observer.observe(activeVideoViewport);

		// ---- YouTube IFrame API bootstrap ----
		const win = window as any;

		const createPlayer = () => {
			const firstClip = videoClips[0];
			player = new win.YT.Player(playerMount, {
				videoId: firstClip.videoId,
				width: '100%',
				height: '100%',
				playerVars: {
					autoplay: 1,
					mute: 0,
					controls: 0,
					disablekb: 1,
					modestbranding: 1,
					rel: 0,
					playsinline: 1,
					iv_load_policy: 3,
					enablejsapi: 1,
				},
				events: {
					onReady: () => {
						playerReady = true;
						player.unMute();
						player.playVideo();
						setPlayIcon(true);
						progressRafId = requestAnimationFrame(tickProgress);
						fetchTitle(videoClips[0], 0);

						// Most browsers block autoplay-with-sound unless the visitor already
						// interacted with the site. Detect that and fall back to a muted
						// autoplay (which browsers always allow) so the video still plays,
						// updating the mute button to match reality.
						setTimeout(() => {
							// Skip entirely if a Drive clip is already what's on screen — this
							// only concerns the (possibly now-hidden) YouTube player's own state.
							if (videoClips[currentVideoIndex]?.source === 'drive') return;
							if (player.getPlayerState() !== 1 /* PLAYING */) {
								isMuted = true;
								player.mute();
								player.playVideo();
								muteIcon?.classList.remove('hidden');
								unmuteIcon?.classList.add('hidden');
							}
						}, 1200);
					},
					onStateChange: (event: any) => {
						// The YouTube player is never actually destroyed when switching to a
						// Drive clip — it's just paused and hidden, so it can still fire events
						// on its own. Ignore all of them while it isn't the thing on screen,
						// otherwise a background "video ended" loop-restart, etc. can leak
						// through and disturb whatever Drive clip is actually showing.
						if (videoClips[currentVideoIndex]?.source === 'drive') return;
						if (event.data === 1) setPlayIcon(true); // playing
						if (event.data === 2) setPlayIcon(false); // paused
						if (event.data === 0) {
							// Video ended — loop it manually (single-video loop without the
							// old 'playlist' trick, so looping keeps working after loadVideoById)
							player.seekTo(0, true);
							player.playVideo();
						}
					},
					onError: (event: any) => {
						// Same reasoning as onStateChange above: a hidden, backgrounded
						// YouTube player can still throw errors of its own. Never let those
						// change what's on screen while a Drive clip is the active one.
						if (videoClips[currentVideoIndex]?.source === 'drive') return;

						// Only these codes mean "this exact video will never play here" —
						// deleted/invalid (2, 100), private (101/150 also cover embedding
						// disabled), or an HTML5 player fault (5). Anything else, leave it alone.
						const permanentCodes = [2, 5, 100, 101, 150];
						if (!permanentCodes.includes(event.data)) return;

						// Mark this one as broken and look for the next clip that hasn't
						// already failed — but only ever step forward through the list once,
						// so a run of broken videos can't cascade endlessly or bounce around.
						failedVideoIndices.add(currentVideoIndex);
						for (let step = 1; step <= videoClips.length; step++) {
							const candidate = (currentVideoIndex + step) % videoClips.length;
							if (!failedVideoIndices.has(candidate)) {
								updateActiveVideo(candidate);
								highlightGalleryItem(candidate);
								return;
							}
						}
						// Every clip has already failed once — stop here rather than loop forever.
					},
				},
			});
		};

		const loadYouTubeApi = () => {
			if (win.YT && win.YT.Player) {
				createPlayer();
				return;
			}
			if (document.getElementById('youtube-iframe-api')) {
				// Script already requested elsewhere on the page — just wait for it
				const prevCallback = win.onYouTubeIframeAPIReady;
				win.onYouTubeIframeAPIReady = () => {
					prevCallback && prevCallback();
					createPlayer();
				};
				return;
			}
			const tag = document.createElement('script');
			tag.id = 'youtube-iframe-api';
			tag.src = 'https://www.youtube.com/iframe_api';
			tag.onerror = () => {
				// Graceful degradation: no JS API available, fall back to a plain embed
				if (playerMount) {
					playerMount.innerHTML = `<iframe src="https://www.youtube.com/embed/${videoClips[0].videoId}?autoplay=1&mute=1&playsinline=1" title="${videoClips[0].title}" frameborder="0" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen style="pointer-events:auto;"></iframe>`;
				}
			};
			document.head.appendChild(tag);
			win.onYouTubeIframeAPIReady = createPlayer;
		};

		loadYouTubeApi();

		// ---- Drag-to-scroll pointer (mouse + touch) ----
		const beginDrag = (clientY: number) => {
			// Recompute bar and track geometry fresh each drag, so resizes/layout shifts don't desync anything
			barHeight = bar.clientHeight;
			centerPosition = barHeight / 2;
			measureTrack();

			isDragging = true;
			startY = clientY;
			startTop = parseInt(pointer.style.top) || centerPosition;
			pointer.style.cursor = 'grabbing';
			pointer.style.transition = 'none';
			pointer.style.transform = 'translate(-50%, -50%)';
		};

		const updateDrag = (clientY: number) => {
			if (!isDragging) return;

			const deltaY = clientY - startY;
			let newTop = startTop + deltaY;

			// Constrain movement within the bar
			const maxTop = barHeight;
			newTop = Math.max(1, Math.min(maxTop, newTop));
			pointer.style.top = `${newTop}px`;

			// Calculate distance from center (0 to 1, where 1 is at the edge)
			const distanceFromCenter = Math.abs(newTop - centerPosition) / (barHeight / 2);
			const clampedDistance = Math.min(distanceFromCenter, 1);

			// Hide center video and show gallery list during drag
			if (clampedDistance > 0.1) {
				activeVideoViewport.style.opacity = '0';
				activeVideoViewport.style.pointerEvents = 'none';
				videoGalleryList.style.opacity = '1';
				videoGalleryList.style.pointerEvents = 'auto';
				videoGalleryList.style.transform = 'scale(1)';
			}

			// Map pointer position to video index for navigation
			const videoCount = videoClips.length;
			const normalizedPosition = Math.max(0, Math.min(1, (newTop - 1) / (barHeight - 2))); // 0 to 1
			const floatIndex = normalizedPosition * (videoCount - 1);

			// Slide the thumbnail track to follow the pointer 1:1 — this is what keeps
			// every item reachable and visible instead of the later ones overflowing
			// off the bottom of the page.
			positionTrack(floatIndex);

			const targetIndex = Math.round(floatIndex);
			const clampedIndex = Math.max(0, Math.min(videoCount - 1, targetIndex));

			if (clampedIndex !== currentVideoIndex) {
				updateActiveVideo(clampedIndex);
				galleryItems.forEach((item, idx) => {
					if (idx === clampedIndex) {
						item.classList.add('ring-2', 'ring-accent', 'scale-105');
						item.classList.remove('opacity-50');
					} else {
						item.classList.remove('ring-2', 'ring-accent', 'scale-105');
						item.classList.add('opacity-50');
					}
				});
			}
		};

		const endDrag = () => {
			if (!isDragging) return;
			isDragging = false;
			hasInteracted = true;
			pointer.style.cursor = 'grab';

			pointer.style.transition = 'top 0.5s ease-out';
			positionTrack(currentVideoIndex, true);

			const selectedItem = galleryItems[currentVideoIndex] as HTMLElement | undefined;

			if (selectedItem && videoGalleryList.parentElement) {
				const parentContainer = videoGalleryList.parentElement;
				const parentRect = parentContainer.getBoundingClientRect();
				const itemRect = selectedItem.getBoundingClientRect();

				const parentCenterX = parentRect.left + parentRect.width / 2;
				const parentCenterY = parentRect.top + parentRect.height / 2;
				const itemCenterX = itemRect.left + itemRect.width / 2;
				const itemCenterY = itemRect.top + itemRect.height / 2;

				const relativeOffsetX = itemCenterX - parentCenterX;
				const relativeOffsetY = itemCenterY - parentCenterY;

				videoGalleryList.style.opacity = '0';
				videoGalleryList.style.pointerEvents = 'none';
				activeVideoViewport.style.opacity = '1';
				activeVideoViewport.style.pointerEvents = 'auto';
				activeVideoViewport.style.transform = `translate(${relativeOffsetX}px, ${relativeOffsetY}px) scale(0.1)`;
				activeVideoViewport.style.transition = 'none';

				// Force reflow
				activeVideoViewport.offsetHeight;

				activeVideoViewport.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
				activeVideoViewport.style.transform = 'translate(0, 0) scale(1)';

				galleryItems.forEach((item, idx) => {
					if (idx !== currentVideoIndex) {
						(item as HTMLElement).style.opacity = '0';
					}
				});

				setTimeout(() => {
					activeVideoViewport.style.transition = 'none';
					activeVideoViewport.style.transform = '';

					galleryItems.forEach((item, idx) => {
						const htmlItem = item as HTMLElement;
						htmlItem.style.transition = 'none';
						htmlItem.style.opacity = '';
						htmlItem.style.transform = '';

						if (idx === currentVideoIndex) {
							item.classList.add('ring-2', 'ring-accent');
							item.classList.remove('opacity-50');
						} else {
							item.classList.remove('ring-2', 'ring-accent');
							item.classList.add('opacity-50');
						}
					});

					if (player && playerReady && videoClips[currentVideoIndex]?.source !== 'drive') {
						player.playVideo();
					}
				}, 500);
			}

			requestAnimationFrame(() => {
				pointer.style.top = `${centerPosition}px`;
				pointer.style.transform = 'translate(-50%, -50%)';

				const handleTransitionEnd = () => {
					pointer.style.transition = 'none';
					pointer.removeEventListener('transitionend', handleTransitionEnd);
				};
				pointer.addEventListener('transitionend', handleTransitionEnd);
			});
		};

		// Mouse events
		pointer.addEventListener('mousedown', (e) => {
			beginDrag(e.clientY);
			e.preventDefault();
		});
		window.addEventListener('mousemove', (e) => updateDrag(e.clientY));
		window.addEventListener('mouseup', endDrag);

		// Touch events (the original component had no mobile drag support at all)
		pointer.addEventListener(
			'touchstart',
			(e) => {
				if (e.touches.length === 0) return;
				beginDrag(e.touches[0].clientY);
			},
			{ passive: true }
		);
		window.addEventListener(
			'touchmove',
			(e) => {
				if (!isDragging || e.touches.length === 0) return;
				updateDrag(e.touches[0].clientY);
			},
			{ passive: true }
		);
		window.addEventListener('touchend', endDrag);
		window.addEventListener('touchcancel', endDrag);

		// Stop the progress rAF loop if the page/tab is torn down (Astro view-transitions, etc.)
		document.addEventListener('astro:before-swap', () => {
			if (progressRafId) cancelAnimationFrame(progressRafId);
			if (player && typeof player.destroy === 'function') player.destroy();
		});
	})();
</script>