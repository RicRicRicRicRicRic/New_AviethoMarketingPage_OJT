---
// Website development section - showcasing web development capabilities
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Website Development', 
	description = 'Custom web solutions built with modern technologies.' 
} = Astro.props;

import webdev_mobileVerGif from '../../../assets/gif/webdev_mobileVers.gif';
import webdev_desktopVersGif from '../../../assets/gif/webdev_desktopVers.gif';

// Content data for the switcher
const contentData = [
	{
		id: 'frontend',
		label: 'Frontend',
		title: 'Frontend Technologies',
		content: '⚛️ React, ⚡ Next.js, 🎨 Tailwind CSS, 🔷 TypeScript'
	},
	{
		id: 'backend',
		label: 'Backend',
		title: 'Backend Technologies',
		content: '🟢 Node.js, 🐍 Python, ☕ Java, 🔵 PHP'
	},
	{
		id: 'database',
		label: 'Database/Cloud',
		title: 'Database & Cloud',
		content: '🐘 PostgreSQL, 🍃 MongoDB, ☁️ AWS, 🔷 Vercel'
	},
	{
		id: 'tools',
		label: 'Tools/CMS',
		title: 'Tools & CMS',
		content: '📝 WordPress, 🛒 Shopify, 🎨 Figma, 📊 Google Analytics'
	}
];
---

<section class="py-20 px-4 py-40 w-full h-full ">
	<div class="w-full h-full">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
			<div>
				<!-- Switcher Buttons -->
				<div class="flex flex-wrap gap-2 mb-6">
					{contentData.map((item) => (
						<button
							data-switcher-btn={item.id}
							class="switcher-btn px-4 py-2 rounded-full border border-white/10 hover:border-accent transition-all duration-300 text-sm font-body text-gray-300 hover:text-accent"
						>
							{item.label}
						</button>
					))
					}
				</div>

				<!-- Dynamic Content Area -->
				<div id="content-display" class="transition-opacity duration-300">
					<h2 class="text-3xl md:text-4xl font-heading text-accent mb-6" id="content-title">
						{contentData[0].title}
					</h2>
					<p class="text-lg font-body text-gray-300 mb-6 leading-relaxed" id="content-paragraph">
						{contentData[0].content}
					</p>
				</div>

			<ul class="space-y-3">
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Static-first architecture for optimal performance</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">WCAG 2.1 AA accessibility compliance</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Secure, decoupled backend integration</span>
				</li>
				<li class="flex items-start">
					<span class="text-accent mr-2">✓</span>
					<span class="text-gray-300">Responsive design for all devices</span>
				</li>
			</ul>
			</div>
			<div class="flex flex-col items-center">
				<!-- Animation Wrapper -->
				<div class="relative w-full flex justify-center items-center min-h-[400px]">
					<!-- Mobile Glass Container -->
					<div 
						id="mobile-container"
						class="mobile-container absolute rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-4 w-[300px] h-[400px] overflow-hidden transition-all duration-500 translate-x-0 opacity-100 z-10"
					>
						<img 
							src={webdev_mobileVerGif.src} 
							alt="Mobile view demonstration"
							class="block w-full h-full object-contain"
							loading="lazy"
						/>
					</div>

					<!-- Desktop Glass Container -->
					<div 
						id="desktop-container"
						class="desktop-container absolute rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-4 w-[450px] h-[350px] overflow-hidden transition-all duration-500 translate-x-full opacity-0"
					>
						<img 
							src={webdev_desktopVersGif.src} 
							alt="Desktop view demonstration"
							class="block w-full h-full object-contain"
							loading="lazy"
						/>
					</div>
				</div>

				<!-- Toggle Buttons -->
				<div class="flex gap-4 mt-6">
					<button 
						id="desktop-btn"
						class="px-6 py-3 rounded-full border border-accent text-accent hover:bg-accent hover:text-black transition-all duration-300 text-sm font-body font-semibold"
					>
						Desktop View
					</button>
					<button 
						id="mobile-btn"
						class="px-6 py-3 rounded-full border border-white/10 text-gray-300 hover:border-accent hover:text-accent transition-all duration-300 text-sm font-body font-semibold"
					>
						Mobile View
					</button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	// Content data (duplicated for client-side access)
	const contentData = [
		{
			id: 'frontend',
			title: 'Frontend Technologies',
			content: '⚛️ React, ⚡ Next.js, 🎨 Tailwind CSS, 🔷 TypeScript'
		},
		{
			id: 'backend',
			title: 'Backend Technologies',
			content: '🟢 Node.js, 🐍 Python, ☕ Java, 🔵 PHP'
		},
		{
			id: 'database',
			title: 'Database & Cloud',
			content: '🐘 PostgreSQL, 🍃 MongoDB, ☁️ AWS, 🔷 Vercel'
		},
		{
			id: 'tools',
			title: 'Tools & CMS',
			content: '📝 WordPress, 🛒 Shopify, 🎨 Figma, 📊 Google Analytics'
		}
	];

	// Get DOM elements for content switcher
	const buttons = document.querySelectorAll('[data-switcher-btn]');
	const contentDisplay = document.getElementById('content-display');
	const contentTitle = document.getElementById('content-title');
	const contentParagraph = document.getElementById('content-paragraph');

	// Get DOM elements for image toggle
	const desktopBtn = document.getElementById('desktop-btn');
	const mobileBtn = document.getElementById('mobile-btn');
	const mobileContainer = document.getElementById('mobile-container');
	const desktopContainer = document.getElementById('desktop-container');

	// Set initial active state for content switcher
	if (buttons.length > 0) {
		buttons[0].classList.add('border-accent', 'text-accent');
	}

	// Set initial state for image toggle (show mobile by default)
	if (mobileContainer && desktopContainer) {
		mobileContainer.classList.remove('translate-x-full', 'opacity-0');
		mobileContainer.classList.add('translate-x-0', 'opacity-100', 'z-10');
		desktopContainer.classList.add('translate-x-full', 'opacity-0');
		desktopContainer.classList.remove('translate-x-0', 'opacity-100', 'z-10');
	}

	// Add click handlers to content switcher buttons
	buttons.forEach(button => {
		button.addEventListener('click', () => {
			const targetId = button.getAttribute('data-switcher-btn');
			const content = contentData.find(item => item.id === targetId);

			if (content && contentDisplay && contentTitle && contentParagraph) {
				// Update button states
				buttons.forEach(btn => {
					btn.classList.remove('border-accent', 'text-accent');
				});
				button.classList.add('border-accent', 'text-accent');

				// Fade out
				contentDisplay.style.opacity = '0';

				// Update content and fade in
				setTimeout(() => {
					contentTitle.textContent = content.title;
					contentParagraph.textContent = content.content;
					contentDisplay.style.opacity = '1';
				}, 300);
			}
		});
	});

	// Add click handlers to view toggle buttons
	if (desktopBtn && mobileBtn && mobileContainer && desktopContainer) {
		desktopBtn.addEventListener('click', () => {
			// Show desktop, hide mobile
			mobileContainer.classList.remove('translate-x-0', 'opacity-100', 'z-10');
			mobileContainer.classList.add('translate-x-full', 'opacity-0');
			desktopContainer.classList.remove('translate-x-full', 'opacity-0');
			desktopContainer.classList.add('translate-x-0', 'opacity-100', 'z-10');

			// Update button styles
			desktopBtn.classList.add('border-accent', 'text-accent');
			desktopBtn.classList.remove('border-white/10', 'text-gray-300');
			mobileBtn.classList.remove('border-accent', 'text-accent');
			mobileBtn.classList.add('border-white/10', 'text-gray-300');
		});

		mobileBtn.addEventListener('click', () => {
			// Show mobile, hide desktop
			desktopContainer.classList.remove('translate-x-0', 'opacity-100', 'z-10');
			desktopContainer.classList.add('-translate-x-full', 'opacity-0');
			mobileContainer.classList.remove('translate-x-full', '-translate-x-full', 'opacity-0');
			mobileContainer.classList.add('translate-x-0', 'opacity-100', 'z-10');

			// Update button styles
			mobileBtn.classList.add('border-accent', 'text-accent');
			mobileBtn.classList.remove('border-white/10', 'text-gray-300');
			desktopBtn.classList.remove('border-accent', 'text-accent');
			desktopBtn.classList.add('border-white/10', 'text-gray-300');
		});
	}
</script>