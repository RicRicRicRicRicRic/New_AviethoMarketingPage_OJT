---
// Website development section - showcasing web development capabilities
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Website Development', 
	description = 'Custom web solutions built with modern technologies.' 
} = Astro.props;

import webdev_mobileVerGif from '../../../assets/gif/webdev_mobileVers.gif';
import webdev_desktopVersGif from '../../../assets/gif/webdev_desktopVers.gif';
import desktop_icon from '../../../assets/icons/desktop_icon.png';
import mobile_icon from '../../../assets/icons/mobile_icon.png';

// Content data for the switcher
const contentData = [
	{
		id: 'frontend',
		label: 'Frontend',
		title: 'Frontend Technologies',
		content: '⚛️ React, ⚡ Next.js, 🎨 Tailwind CSS, 🔷 TypeScript'
	},
	{
		id: 'backend',
		label: 'Backend',
		title: 'Backend Technologies',
		content: '🟢 Node.js, 🐍 Python, ☕ Java, 🔵 PHP'
	},
	{
		id: 'database',
		label: 'Database/Cloud',
		title: 'Database & Cloud',
		content: '🐘 PostgreSQL, 🍃 MongoDB, ☁️ AWS, 🔷 Vercel'
	},
	{
		id: 'tools',
		label: 'Tools/CMS',
		title: 'Tools & CMS',
		content: '📝 WordPress, 🛒 Shopify, 🎨 Figma, 📊 Google Analytics'
	}
];
---

<section class="py-20 px-4 py-40 w-full h-full ">
	<div class="w-full h-full">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
			<div>
				<!-- Switcher Buttons -->
				<div class="flex flex-wrap gap-2 mb-6">
					{contentData.map((item) => (
						<button
							data-switcher-btn={item.id}
							class="switcher-btn px-4 py-2 rounded-full border border-white/10 hover:border-accent transition-all duration-300 text-sm font-body text-gray-300 hover:text-accent"
						>
							{item.label}
						</button>
					))
					}
				</div>

				<!-- Dynamic Content Area -->
				<div id="content-display" class="transition-opacity duration-300">
					<h2 class="text-3xl md:text-4xl font-heading text-accent mb-6" id="content-title">
						{contentData[0].title}
					</h2>
					<p class="text-lg font-body text-gray-300 mb-6 leading-relaxed shine-item" id="content-paragraph">
						{contentData[0].content}
					</p>
				</div>

				<ul class="space-y-3">
					<li class="flex items-start">
						<span class="text-accent mr-2">✓</span>
						<span class="text-gray-300">Static-first architecture for optimal performance</span>
					</li>
					<li class="flex items-start">
						<span class="text-accent mr-2">✓</span>
						<span class="text-gray-300">WCAG 2.1 AA accessibility compliance</span>
					</li>
					<li class="flex items-start">
						<span class="text-accent mr-2">✓</span>
						<span class="text-gray-300">Secure, decoupled backend integration</span>
					</li>
					<li class="flex items-start">
						<span class="text-accent mr-2">✓</span>
						<span class="text-gray-300">Responsive design for all devices</span>
					</li>
				</ul>
			</div>
			<div class="flex flex-col items-center">
				<!-- Animation Wrapper -->
				<div class="relative w-full flex justify-center items-center min-h-[400px] overflow-hidden">
					<!-- Mobile Glass Container -->
					<div 
						id="mobile-container"
						class="mobile-container absolute rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-4 w-[300px] h-[400px] overflow-hidden transition-all duration-500 translate-x-0 opacity-100 z-10"
					>
						<img 
							src={webdev_mobileVerGif.src} 
							alt="Mobile view demonstration"
							class="block w-full h-full object-contain"
							loading="lazy"
						/>
					</div>

					<!-- Desktop Glass Container -->
					<div 
						id="desktop-container"
						class="desktop-container absolute rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-4 w-[450px] h-[350px] overflow-hidden transition-all duration-500 translate-x-full opacity-0"
					>
						<img 
							src={webdev_desktopVersGif.src} 
							alt="Desktop view demonstration"
							class="block w-full h-full object-contain"
							loading="lazy"
						/>
					</div>
				</div>

				<!-- Toggle Buttons -->
				<div class="flex gap-4 mt-6">
					<button 
						id="desktop-btn"
						class="group w-14 h-14 flex items-center justify-center p-0 rounded-full border border-accent text-accent transition-all duration-300 text-sm font-body font-semibold"
					>
						<img 
							src={desktop_icon.src} 
							alt="Desktop view" 
							class="w-6 h-6 object-contain icon-idle group-hover:icon-hover"
						/>
					</button>
					<button 
						id="mobile-btn"
						class="group w-14 h-14 flex items-center justify-center p-0 rounded-full border border-white/10 text-gray-300 hover:border-accent hover:text-accent transition-all duration-300 text-sm font-body font-semibold"
					>
						<img 
							src={mobile_icon.src} 
							alt="Mobile view" 
							class="w-6 h-6 object-contain icon-idle group-hover:icon-hover"
						/>
					</button>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes shine {
		0% { transform: translateX(-100%); }
		100% { transform: translateX(100%); }
	}
	.animate-shine::after {
		animation: shine 1.5s ease-in-out;
	}
	.shine-item {
		position: relative;
		overflow: hidden;
		padding: 0.75rem;
		border-radius: 0.5rem;
	}
	.shine-item::after {
		content: '';
		position: absolute;
		inset: 0;
		transform: translateX(-100%);
		background: linear-gradient(to right, transparent, var(--color-accent), transparent);
		opacity: 0.2;
		pointer-events: none;
	}
	/* Active switcher button styling */
	.switcher-btn.border-accent {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}
	
	/* Hover effect for active switcher buttons */
	.switcher-btn.border-accent:hover {
		border-color: var(--color-accent-hover);
		color: var(--color-accent-hover);
	}
</style>

<script>
	// Content data (duplicated for client-side access)
	const contentData = [
		{
			id: 'frontend',
			title: 'Frontend Technologies',
			content: '⚛️ React, ⚡ Next.js, 🎨 Tailwind CSS, 🔷 TypeScript'
		},
		{
			id: 'backend',
			title: 'Backend Technologies',
			content: '🟢 Node.js, 🐍 Python, ☕ Java, 🔵 PHP'
		},
		{
			id: 'database',
			title: 'Database & Cloud',
			content: '🐘 PostgreSQL, 🍃 MongoDB, ☁️ AWS, 🔷 Vercel'
		},
		{
			id: 'tools',
			title: 'Tools & CMS',
			content: '📝 WordPress, 🛒 Shopify, 🎨 Figma, 📊 Google Analytics'
		}
	];

	// View configuration mapping
	const viewConfig: Record<string, { container: HTMLElement | null; btn: HTMLElement | null; show: string[]; hide: string[] }> = {
		mobile: {
			container: document.getElementById('mobile-container'),
			btn: document.getElementById('mobile-btn'),
			show: ['translate-x-0', 'opacity-100', 'z-10'],
			hide: ['translate-x-full', 'opacity-0']
		},
		desktop: {
			container: document.getElementById('desktop-container'),
			btn: document.getElementById('desktop-btn'),
			show: ['translate-x-0', 'opacity-100', 'z-10'],
			hide: ['translate-x-full', 'opacity-0']
		}
	};

	// Unified setView function
	const setView = (type: 'mobile' | 'desktop') => {
		const { container, btn, show, hide } = viewConfig[type];
		const otherType = type === 'mobile' ? 'desktop' : 'mobile';
		const other = viewConfig[otherType];

		// Update containers
		if (container) {
			container.classList.remove(...hide);
			container.classList.add(...show);
		}
		if (other.container) {
			other.container.classList.remove(...show);
			other.container.classList.add(...hide);
		}

		// Update buttons and icon states
		if (btn && other.btn) {
			// Update button border and text colors
			btn.classList.add('border-accent', 'text-accent');
			btn.classList.remove('border-white/10', 'text-gray-300');
			other.btn.classList.remove('border-accent', 'text-accent');
			other.btn.classList.add('border-white/10', 'text-gray-300');

			// Update icon states
			const activeIcon = btn.querySelector('img');
			const inactiveIcon = other.btn.querySelector('img');
			
			if (activeIcon) {
				activeIcon.classList.remove('icon-idle');
				activeIcon.classList.add('icon-hover');
			}
			if (inactiveIcon) {
				inactiveIcon.classList.remove('icon-hover');
				inactiveIcon.classList.add('icon-idle');
			}
		}

		// Save preference
		localStorage.setItem('websiteDevelopmentView', type);
	};

	// Initialize view (default to mobile on first visit)
	const viewPreference = localStorage.getItem('websiteDevelopmentView');
	setView((viewPreference === 'desktop' ? 'desktop' : 'mobile'));

	// Content switcher logic
	const buttons = document.querySelectorAll('[data-switcher-btn]');
	const contentDisplay = document.getElementById('content-display');
	const contentTitle = document.getElementById('content-title');
	const contentParagraph = document.getElementById('content-paragraph');
	let shineTimeout: number | null = null;

	// Set initial active state
	if (buttons.length > 0) {
		buttons[0].classList.add('border-accent', 'text-accent');
	}

	// Add click handlers to content switcher buttons
	buttons.forEach(button => {
		button.addEventListener('click', () => {
			const targetId = button.getAttribute('data-switcher-btn');
			const content = contentData.find(item => item.id === targetId);

			if (content && contentDisplay && contentTitle && contentParagraph) {
				// Update button states
				buttons.forEach(btn => btn.classList.remove('border-accent', 'text-accent'));
				button.classList.add('border-accent', 'text-accent');

				// Fade out, update content, fade in
				contentDisplay.style.opacity = '0';
				setTimeout(() => {
					contentTitle.textContent = content.title;
					contentParagraph.textContent = content.content;
					contentDisplay.style.opacity = '1';
					
				// Trigger shine effect on content paragraph (once per switch)
				const contentPara = document.getElementById('content-paragraph');
				if (contentPara) {
					// Clear any pending timeout to prevent conflicts
					if (shineTimeout !== null) {
						clearTimeout(shineTimeout);
					}
					
					contentPara.classList.remove('animate-shine');
					// Force reflow to restart animation
					void contentPara.offsetWidth;
					contentPara.classList.add('animate-shine');
					
					// Remove class after animation completes
					shineTimeout = window.setTimeout(() => {
						contentPara.classList.remove('animate-shine');
						shineTimeout = null;
					}, 1500);
				}
				}, 300);
			}
		});
	});

	// Add click handlers to view toggle buttons
	document.getElementById('desktop-btn')?.addEventListener('click', () => setView('desktop'));
	document.getElementById('mobile-btn')?.addEventListener('click', () => setView('mobile'));
</script>