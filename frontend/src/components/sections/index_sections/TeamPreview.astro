---
// Team Preview Section
// Displays team members with interactive slideshow
// No autoplay - updates only on user input

import TeamSlideshow from '../../ui/TeamSlideshow.astro';
import migz from '../../../assets/imgs/migz.png';
import jojo from '../../../assets/imgs/jojo.png';
import rickie from '../../../assets/imgs/rickie.png';
import gella from "../../../assets/imgs/gella.png";

interface TeamMember {
	name: string;
	jobTitle: string;
	description: string;
	imagePath: string;
}

const teamMembers: TeamMember[] = [
	{
		name: 'Jojo Bayais',
		jobTitle: 'Photographer',
		description: 'Jojo Bayais is a talented photographer and project coordinator who blends creative vision with efficient logistics. He excels at capturing compelling imagery while ensuring smooth project execution through strong communication and artistic intuition.',
		imagePath: jojo.src
	},
	{
		name: 'Migz Junsay',
		jobTitle: 'Creative Director',
		description: 'Migz Junsay is a versatile Creative Director with over a decade of experience in video editing, 3D animation, graphic design, and photography. He transforms ideas into captivating visual stories, guiding projects from concept to final production with artistic and technical expertise.',
		imagePath: migz.src,
	},
	{
		name: 'Gella J. Aboratigue',
		jobTitle: 'Online Editor',
		description: 'Gella J. Aboratigue is an Online Editor and BA Communication graduate with expertise in content writing, social media management, Canva design, PR, and field productions. She crafts engaging narratives and enjoys pop culture, music, sitcoms, mystery thrillers, and learning languages.',
		imagePath: gella.src,
	},
	{
		name: 'Rickie Javier',
		jobTitle: 'Public Relations Specialist & Social Media Manager',
		description: 'Rickie Javier, Editor-in-Chief of Avietho Digital, is a skilled PR specialist and social media manager with a background in Journalism. She excels at content strategy, team leadership, and brand communication across multiple platforms.',
		imagePath: rickie.src,
	}
];

let currentIndex = 0;

// Helper function to format description with bold name
function formatDescription(description: string, name: string): string {
	const nameIndex = description.indexOf(name);
	if (nameIndex === -1) return description;
	
	const beforeName = description.substring(0, nameIndex);
	const afterName = description.substring(nameIndex + name.length);
	
	return `${beforeName}<span class="font-bold">${name}</span>${afterName}`;
}
---

<section class="py-20 px-4 py-40 bg-background-elevated w-full h-full ">
	<div class="w-full h-full">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center max-w-7xl mx-auto">
			
			<!-- Left Column: Name and Job Title -->
			<div class="flex flex-col items-center text-center lg:justify-center lg:text-left lg:items-start space-y-4">
				<div id="team-info" class="transition-all duration-500 ease-in-out">
					<h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-2 transition-all duration-500 ease-in-out" id="team-name">
						{teamMembers[currentIndex].name}
					</h2>
					<p class="text-lg md:text-xl lg:text-2xl text-accent font-medium transition-all duration-500 ease-in-out" id="team-job-title">
						{teamMembers[currentIndex].jobTitle}
					</p>
				</div>
			</div>

			<!-- Middle Column: Image Slideshow -->
			<div class="flex flex-col justify-center items-center">
				<TeamSlideshow teamMembers={teamMembers} currentIndex={currentIndex} />
			</div>

			<!-- Right Column: Description -->
			<div class="flex flex-col justify-center items-center text-center lg:text-left lg:items-start">
				<div id="team-description" class="transition-all duration-500 ease-in-out">
					<p class="text-base md:text-lg text-foreground/80 leading-relaxed transition-all duration-500 ease-in-out" id="team-desc" set:html={formatDescription(teamMembers[currentIndex].description, teamMembers[currentIndex].name)}>
					</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	// Helper function to format description with bold name (client-side version)
	function formatDescription(description: string, name: string): string {
		const nameIndex = description.indexOf(name);
		if (nameIndex === -1) return description;
		
		const beforeName = description.substring(0, nameIndex);
		const afterName = description.substring(nameIndex + name.length);
		
		return `${beforeName}<span class="font-bold">${name}</span>${afterName}`;
	}

	// Text update functionality for team info
	const nameEl = document.getElementById('team-name');
	const jobTitleEl = document.getElementById('team-job-title');
	const descEl = document.getElementById('team-desc');
	const teamInfo = document.getElementById('team-info');
	const teamDescription = document.getElementById('team-description');

	// Listen for custom slideshow events to update text
	document.addEventListener('slideshowChanged', (e: any) => {
		const { member } = e.detail;
		
		if (nameEl && jobTitleEl && descEl && teamInfo && teamDescription) {
			// Fade out
			nameEl.style.opacity = '0';
			nameEl.style.transform = 'translateY(-10px)';
			jobTitleEl.style.opacity = '0';
			jobTitleEl.style.transform = 'translateY(-10px)';
			descEl.style.opacity = '0';
			descEl.style.transform = 'translateY(10px)';

			// Update and fade in
			setTimeout(() => {
				nameEl.textContent = member.name;
				nameEl.style.opacity = '1';
				nameEl.style.transform = 'translateY(0)';
				
				jobTitleEl.textContent = member.jobTitle;
				jobTitleEl.style.opacity = '1';
				jobTitleEl.style.transform = 'translateY(0)';
				
				// Use innerHTML to render bold name
				descEl.innerHTML = formatDescription(member.description, member.name);
				descEl.style.opacity = '1';
				descEl.style.transform = 'translateY(0)';
			}, 200);
		}
	});
</script>
