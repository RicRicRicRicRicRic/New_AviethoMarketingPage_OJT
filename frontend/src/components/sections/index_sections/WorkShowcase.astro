---
// Work showcase section - displaying portfolio/work examples
// Uses WorkSlideshow component for infinite-looping horizontal slider

import WorkSlideshow from '../../ui/WorkSlideshow.astro';
---

<section class="py-20 px-4 bg-background-elevated w-full h-full ">
	<div class="w-full">
		<!-- Heading using font-heading style -->
		<h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-center text-accent mb-12">
			Behind the Work
		</h2>
		
		<!-- Work Slideshow Component -->
		<WorkSlideshow />
	</div>
</section>