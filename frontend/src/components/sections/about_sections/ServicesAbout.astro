<!-- Blur/Fade CSS and utility modifications -->
<style>
    #services-carousel {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    #services-carousel::-webkit-scrollbar {
        display: none;
    }
    
    /* Dynamic styling applied via Intersection Observer classes */
    .carousel-item {
        opacity: 0.35;
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .carousel-item .item-image-container {
        filter: blur(6px);
        transition: filter 0.5s ease;
    }
    
    /* Target active/centered slide element explicitly */
    .carousel-item.is-active {
        opacity: 1;
    }
    .carousel-item.is-active .item-image-container {
        filter: blur(0px);
    }
</style>

<!-- Infinite Bidirectional Center Focus Carousel Logic -->
<script>
    const carousel = document.getElementById('services-carousel') as HTMLDivElement | null;
    const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement | null;

    if (carousel && prevBtn && nextBtn) {
        const originalItems = Array.from(carousel.querySelectorAll('.carousel-item')) as HTMLElement[];
        const totalOriginals = originalItems.length;
        const gap = 24; // Tailwind gap-6 is 24px

        // 1. Clone items BOTH to the start and end so Left & Right work infinitely
        originalItems.slice().reverse().forEach(item => {
            const clone = item.cloneNode(true) as HTMLElement;
            clone.setAttribute('aria-hidden', 'true');
            carousel.prepend(clone);
        });

        originalItems.forEach(item => {
            const clone = item.cloneNode(true) as HTMLElement;
            clone.setAttribute('aria-hidden', 'true');
            carousel.appendChild(clone);
        });

        const getStep = (): number => {
            const card = carousel.querySelector('.carousel-item') as HTMLElement | null;
            return (card ? card.offsetWidth : 320) + gap;
        };

        const getSetWidth = (): number => getStep() * totalOriginals;

        // 2. Center the carousel on page load without animation
        const initCarousel = () => {
            carousel.style.scrollBehavior = 'auto';
            carousel.scrollLeft = getSetWidth();
        };

        initCarousel();
        window.addEventListener('resize', initCarousel);

        // 3. Setup IntersectionObserver to track the element exactly in the middle of the viewport
        const observerOptions = {
            root: carousel,
            rootMargin: '0px -33% 0px -33%', // Limits threshold detection space down to the center column zone
            threshold: 0.4
        };

        const observerCallback = (entries: IntersectionObserverEntry[]) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-active');
                } else {
                    entry.target.classList.remove('is-active');
                }
            });
        };

        const observer = new IntersectionObserver(observerCallback, observerOptions);
        
        // Target all items inclusive of injected clones
        const updateObservations = () => {
            carousel.querySelectorAll('.carousel-item').forEach(item => observer.observe(item));
        };
        updateObservations();

        // 4. Silent reset when crossing clone boundaries
        let isScrolling = false;
        let scrollTimeout: ReturnType<typeof setTimeout> | undefined;

        const checkAndResetBoundary = () => {
            const setWidth = getSetWidth();
            if (carousel.scrollLeft < setWidth - gap) {
                carousel.style.scrollBehavior = 'auto';
                carousel.scrollLeft += setWidth;
            } 
            else if (carousel.scrollLeft >= setWidth * 2 - gap) {
                carousel.style.scrollBehavior = 'auto';
                carousel.scrollLeft -= setWidth;
            }
        };

        carousel.addEventListener('scroll', () => {
            if (scrollTimeout) clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
                if (!isScrolling) {
                    checkAndResetBoundary();
                }
            }, 150);
        });

        // 5. Button Controls
        nextBtn.addEventListener('click', () => {
            if (isScrolling) return;
            isScrolling = true;

            carousel.style.scrollBehavior = 'smooth';
            carousel.scrollLeft += getStep();

            setTimeout(() => {
                isScrolling = false;
                checkAndResetBoundary();
            }, 400); 
        });

        prevBtn.addEventListener('click', () => {
            if (isScrolling) return;
            isScrolling = true;

            carousel.style.scrollBehavior = 'smooth';
            carousel.scrollLeft -= getStep();

            setTimeout(() => {
                isScrolling = false;
                checkAndResetBoundary();
            }, 400);
        });
    }
</script>