									d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
								></path>
							</svg>
						</div>
						<div class="flex-1">
							<h4 class="text-lg font-bold text-foreground mb-1">
								Official Website
							</h4>
							<p class="text-sm text-text-muted leading-relaxed">
								Visit our official website to explore our
								services, portfolio, and everything Avietho
								Digital has to offer.
							</p>
						</div>
					</div>
					<a
						href="https://www.aviethodigital.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-6 py-2.5 border border-accent text-accent font-medium rounded-full transition-all duration-300 hover:bg-accent hover:text-background"
					>
						Visit Website
						<svg
							class="w-4 h-4"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>

	<script>
		(function () {
			const slideshow = document.getElementById("facebook-slideshow");
			if (!slideshow) return;

			const slides = slideshow.querySelectorAll(".slide");
			const prevBtn = slideshow.querySelector("#prev-slide");
			const nextBtn = slideshow.querySelector("#next-slide");
			const dots = slideshow.querySelectorAll(".pagination-dot");

			let currentSlide = 0;
			const totalSlides = slides.length;
			let autoplayInterval: number | null = null;
			const autoplayDelay = 4500; // 4.5 seconds
			let isPaused = false;

			// Show a specific slide
			function showSlide(index: number) {
				// Wrap around
				if (index < 0) index = totalSlides - 1;
				if (index >= totalSlides) index = 0;

				currentSlide = index;

				// Update slides
				slides.forEach((slide, i) => {
					const el = slide as HTMLElement;
					if (i === currentSlide) {
						el.classList.add("active");
						el.style.display = "block";
					} else {
						el.classList.remove("active");
						el.style.display = "none";
					}
				});

				// Update dots
				dots.forEach((dot, i) => {
					if (i === currentSlide) {
						dot.classList.add("bg-accent");
						dot.classList.remove("bg-foreground/30");
					} else {
						dot.classList.remove("bg-accent");
						dot.classList.add("bg-foreground/30");
					}
				});

				// Update arrow direction based on current slide
				if (nextBtn) {
					const svg = nextBtn.querySelector("svg");
					if (svg) {
						if (currentSlide === 1) {
							svg.classList.add("rotate-180");
						} else {
							svg.classList.remove("rotate-180");
						}
					}
				}
			}

			// Navigate to next/previous slide
			function nextSlide() {
				showSlide(currentSlide + 1);
			}

			function prevSlide() {
				showSlide(currentSlide - 1);
			}

			// Start autoplay
			function startAutoplay() {
				stopAutoplay();
				autoplayInterval = window.setInterval(() => {
					if (!isPaused) {
						// Single button toggle auto-navigates back and forth
						if (currentSlide === 1) {
							prevSlide();
						} else {
							nextSlide();
						}
					}
				}, autoplayDelay);
			}

			// Stop autoplay
			function stopAutoplay() {
				if (autoplayInterval) {
					window.clearInterval(autoplayInterval);
					autoplayInterval = null;
				}
			}

			// Event listeners for navigation buttons
			if (prevBtn) {
				prevBtn.addEventListener("click", () => {
					prevSlide();
					startAutoplay(); // Reset timer
				});
			}

			if (nextBtn) {
				nextBtn.addEventListener("click", () => {
					if (currentSlide === 1) {
						prevSlide();
					} else {
						nextSlide();
					}
					startAutoplay(); // Reset timer
				});
			}

			// Event listeners for pagination dots
			dots.forEach((dot) => {
				dot.addEventListener("click", () => {
					const slideIndex = parseInt(
						(dot as HTMLElement).getAttribute("data-slide") ?? "0",
						10,
					);
					showSlide(slideIndex);
					startAutoplay(); // Reset timer
				});
			});

			// Pause autoplay on hover
			slideshow.addEventListener("mouseenter", () => {
				isPaused = true;
			});

			slideshow.addEventListener("mouseleave", () => {
				isPaused = false;
			});

			// Touch swipe support
			let touchStartX = 0;
			let touchEndX = 0;

			slideshow.addEventListener(
				"touchstart",
				(e) => {
					touchStartX = e.changedTouches[0].screenX;
				},
				{ passive: true },
			);

			slideshow.addEventListener(
				"touchend",
				(e) => {
					touchEndX = e.changedTouches[0].screenX;
					handleSwipe();
				},
				{ passive: true },
			);

			function handleSwipe() {
				const swipeThreshold = 50;
				const diff = touchStartX - touchEndX;

				if (Math.abs(diff) > swipeThreshold) {
					if (diff > 0) {
						nextSlide(); // Swipe left
					} else {
						prevSlide(); // Swipe right
					}
					startAutoplay(); // Reset timer
				}
			}

			// Keyboard navigation
			slideshow.addEventListener("keydown", (e) => {
				if (e.key === "ArrowLeft") {
					prevSlide();
					startAutoplay();
				} else if (e.key === "ArrowRight") {
					nextSlide();
					startAutoplay();
				}
			});

			// Make slideshow focusable for keyboard navigation
			slideshow.setAttribute("tabindex", "0");

			// Initialize
			showSlide(0);
			startAutoplay();
		})();
	</script>
</section>

<style>
	.slide {
		display: none;
		opacity: 0;
		transition: opacity 0.6s ease-in-out;
	}

	.slide.active {
		display: block;
		opacity: 1;
	}

	.pagination-dot:hover {
		transform: scale(1.2);
	}

	#prev-slide:focus,
	#next-slide:focus {
		outline: 2px solid #c1a44c;
		outline-offset: 2px;
	}
</style>
